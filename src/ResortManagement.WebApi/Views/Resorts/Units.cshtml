@{
    ViewData["Title"] = "Units Catalog Inventory";
    var units = ViewBag.Units as List<dynamic> ?? new List<dynamic>();
    var locations = ViewBag.Locations as List<string> ?? new List<string>();
    
    var availCount = units.Count(u => u.Status == "Available");
    var occupCount = units.Count(u => u.Status == "Occupied");
    var maintCount = units.Count(u => u.Status == "Maintenance");
    
    var minBeds = units.Any() ? units.Min(u => u.MaxOccupancy) : 1;
    var maxBeds = units.Any() ? units.Max(u => u.MaxOccupancy) : 8;
}

<main class="flex-1 pt-32 pb-20 px-margin-mobile md:px-margin-tablet lg:px-margin-desktop w-full max-w-container-max mx-auto">
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6">
        <div>
            <h1 class="text-display-lg-mobile md:text-display-lg font-bold text-primary mb-2">Portfolio Management</h1>
            <p class="text-body-lg text-on-surface-variant max-w-2xl mb-4">Monitor availability, coordinate housekeeping, and manage your luxury chalets across all alpine destinations.</p>
            <div class="flex gap-2">
                <button onclick="window.location.href='/resorts/units/create'" class="text-label-sm text-on-primary bg-primary px-4 py-2 rounded-full hover:bg-primary/95 transition-colors font-semibold flex items-center gap-1 shadow-sm">
                    <span class="material-symbols-outlined text-[16px]">add</span> Register Unit
                </button>
                <button onclick="window.location.href='/resorts/unit-types/create'" class="text-label-sm text-secondary border border-secondary px-4 py-2 rounded-full hover:bg-secondary/5 transition-colors font-semibold flex items-center gap-1 shadow-sm">
                    <span class="material-symbols-outlined text-[16px]">add_home</span> Add Room Type
                </button>
            </div>
        </div>
        <div class="flex gap-4">
            <div class="bg-white p-4 rounded-xl shadow-sm border border-outline-variant/30 min-w-[120px]">
                <p class="text-label-sm text-on-surface-variant uppercase tracking-wider mb-1">Total Units</p>
                <p class="text-headline-lg text-primary font-bold">@ViewBag.TotalUnits</p>
            </div>
            <div class="bg-white p-4 rounded-xl shadow-sm border border-outline-variant/30 min-w-[120px]">
                <p class="text-label-sm text-on-surface-variant uppercase tracking-wider mb-1">Occupancy</p>
                <p class="text-headline-lg text-secondary font-bold">@ViewBag.Occupancy%</p>
            </div>
        </div>
    </div>
    
    <!-- Layout Grid: Sidebar + Main Grid -->
    <div class="flex flex-col lg:flex-row gap-gutter">
        <!-- Advanced Filtering Sidebar (Glassmorphic) -->
        <aside class="w-full lg:w-72 shrink-0">
            <div class="sticky top-28 bg-white/70 backdrop-blur-xl border border-white/40 shadow-sm rounded-xl p-6">
                <div class="flex justify-between items-center mb-6 border-b border-outline-variant/30 pb-4">
                    <h2 class="text-headline-md text-primary font-bold">Filters</h2>
                    <button onclick="resetFilters();" class="text-label-sm text-secondary hover:text-primary transition-colors font-semibold">Reset All</button>
                </div>
                
                <!-- Filter Section: Status -->
                <div class="mb-6">
                    <h3 class="text-label-md text-on-surface mb-3 uppercase tracking-wider font-semibold">Status</h3>
                    <div class="space-y-3">
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input checked id="filter-avail" class="rounded border-outline-variant text-secondary focus:ring-secondary/20 bg-surface-container-lowest w-5 h-5 transition-all" type="checkbox"/>
                            <span class="text-body-md text-on-surface-variant group-hover:text-primary transition-colors">Available</span>
                            <span class="ml-auto bg-surface-container text-on-surface-variant text-label-sm px-2 py-0.5 rounded-full font-semibold">@availCount</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input checked id="filter-occup" class="rounded border-outline-variant text-secondary focus:ring-secondary/20 bg-surface-container-lowest w-5 h-5 transition-all" type="checkbox"/>
                            <span class="text-body-md text-on-surface-variant group-hover:text-primary transition-colors">Occupied</span>
                            <span class="ml-auto bg-surface-container text-on-surface-variant text-label-sm px-2 py-0.5 rounded-full font-semibold">@occupCount</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input checked id="filter-maint" class="rounded border-outline-variant text-secondary focus:ring-secondary/20 bg-surface-container-lowest w-5 h-5 transition-all" type="checkbox"/>
                            <span class="text-body-md text-on-surface-variant group-hover:text-primary transition-colors">Maintenance</span>
                            <span class="ml-auto bg-surface-container text-on-surface-variant text-label-sm px-2 py-0.5 rounded-full font-semibold">@maintCount</span>
                        </label>
                    </div>
                </div>
                
                <!-- Filter Section: Location -->
                <div class="mb-6 border-t border-outline-variant/20 pt-4">
                    <h3 class="text-label-md text-on-surface mb-3 uppercase tracking-wider font-semibold">Location</h3>
                    <div class="relative mb-3">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline-variant text-[20px]">search</span>
                        <input id="search-input" class="w-full bg-surface-container-lowest border border-outline-variant/50 rounded-lg pl-10 pr-4 py-2 text-body-md focus:border-secondary focus:ring-2 focus:ring-secondary/10 transition-all outline-none" placeholder="Search destinations..." type="text"/>
                    </div>
                    <div class="flex flex-wrap gap-2" id="location-tags-container">
                        @foreach (var loc in locations)
                        {
                            var cleanLoc = loc.Replace(" Resort", "").Replace(" Retreat", "").Replace(" Estate", "");
                            <span onclick="toggleLocationTag(this, '@loc')" class="location-tag px-3 py-1 bg-surface-container hover:bg-surface-container-high text-on-surface-variant rounded-full text-label-sm cursor-pointer transition-all duration-200">@cleanLoc</span>
                        }
                    </div>
                </div>
                
                <!-- Filter Section: Capacity -->
                <div class="border-t border-outline-variant/20 pt-4">
                    <div class="flex justify-between items-center mb-2">
                        <h3 class="text-label-md text-on-surface uppercase tracking-wider font-semibold">Bedrooms</h3>
                        <span id="bedrooms-value" class="text-label-sm text-secondary font-bold">@minBeds+ Beds</span>
                    </div>
                    <input id="bedrooms-slider" class="w-full accent-secondary cursor-pointer" max="@maxBeds" min="@minBeds" type="range" value="@minBeds"/>
                    <div class="flex justify-between text-label-sm text-on-surface-variant mt-2 font-medium">
                        <span>@minBeds+ Beds</span>
                        <span>@maxBeds+ Beds</span>
                    </div>
                </div>
            </div>
        </aside>
        
        <!-- Unit Grid -->
        <div class="flex-1">
            <!-- Client-side filter Empty State (Hidden by default) -->
            <div id="empty-state" style="display: none;" class="bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-12 text-center text-on-surface-variant flex flex-col items-center justify-center shadow-sm w-full transition-all duration-300">
                <span class="material-symbols-outlined text-[48px] text-outline/40 mb-4">filter_list_off</span>
                <h3 class="text-headline-md font-bold text-primary mb-2">No Matching Units</h3>
                <p class="text-body-md text-on-surface-variant max-w-md">No luxury chalets match your active filters. Try resetting filters or adjust sliders to broaden your search.</p>
            </div>

            <div id="units-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-gutter align-content-start">
                @if (units.Count == 0)
                {
                    <div class="col-span-1 md:col-span-2 xl:col-span-3 bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-12 text-center text-on-surface-variant flex flex-col items-center justify-center shadow-sm w-full">
                        <span class="material-symbols-outlined text-[48px] text-outline/40 mb-4">bed</span>
                        <h3 class="text-headline-md font-bold text-primary mb-2">No Units Found</h3>
                        <p class="text-body-md text-on-surface-variant max-w-md">There are no room units registered yet. Click "Register Unit" above to add your first unit dynamically.</p>
                    </div>
                }
                else
                {
                    foreach (var u in units)
                    {
                        var statusColor = u.Status == "Available" ? "bg-secondary/90 text-on-secondary" : (u.Status == "Occupied" ? "bg-primary-container/90 text-on-primary-container" : "bg-error-container/90 text-on-error-container");
                        var statusDot = u.Status == "Available" ? "bg-white animate-pulse" : "";
                        var statusIcon = u.Status == "Available" ? "" : (u.Status == "Occupied" ? "person" : "build");
                        
                        var imageUrl = "https://lh3.googleusercontent.com/aida-public/AB6AXuBBtmfr9S1_kufizmLmq234fYY1dPwq4OceLMKS2V_3jlFjk6bJnoPsmQ6m6fjRtQLNIs1I4g4F2QQ1N6DK49W6EdbS82LrwGVT91_FFy6GgcQ_KKHTKPoFIiov__f1N-rhJiETC2R4KIfn7ibTn7Ob0K5H0P1SNhDYQWytN2MdQ7-wUyHxq22KaYMGESumf0JWJJubfiI-QlG1_0qwhLE6eDerUml3TXy7Va6250uB-1w3mH_VZra1qyvUbkqfrr9kSy7g85h9-Oig";
                        if (u.UnitTypeName.Contains("Villa")) imageUrl = "https://lh3.googleusercontent.com/aida-public/AB6AXuBSEiJcQZ0h0A-6npESsAc-pKEmGLPnGsbHLr7bIYGhKYkQCNfHaUkgmTiMTU3z28EMZNBxZ2Q1i7tsIKLbGcyerqmuG8MzgZZhfR5v16x6Wcf9tAiCw75KN39w9o0Tn7Rj2wrZAPGkdLncNlmkWM2qUlJq03krjpis1iQabRiYBPhYHdLn8sFHhp30YEUf4REDYKY2tAGsnKVFp4rUxvpN4gl-QwxVBB2DaejvnGJQTBpuP5j-wghf7MGz1tZZU7HmLb6rEKHf6BDN";
                        if (u.UnitTypeName.Contains("Suite")) imageUrl = "https://lh3.googleusercontent.com/aida-public/AB6AXuCAT0d5yECFJhAWXKmNsyG4QgtMJs0b9nHs5yGcrI9zhk5b-9FqJeDcSWwaC0i2qItirczsm11dO3UsMLMoeZWjw9xN6Z768RH6ok1_fPRrmVFgmHY6N0w_RiZ-Zzn27spspseJiJA0qImIzYnjuvogrS4WNknweyWLtlu2JJFxaNnsdf_FWLlhfD89DzgrJd7YPBrbHzI01WxnwkUTgkNGyVKXSgHesfM4E7CWf1MTq4X8GPor02imvHtA0AbJ8jYz1OMnsaTH3YX3";
    
                        <article class="unit-card bg-white rounded-xl overflow-hidden border border-outline-variant/30 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col"
                                 data-status="@u.Status"
                                 data-location="@u.ResortName"
                                 data-beds="@u.MaxOccupancy"
                                 data-number="@u.Number"
                                 data-type="@u.UnitTypeName">
                            <div class="h-64 relative overflow-hidden">
                                <img alt="@u.UnitTypeName interior" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="@imageUrl"/>
                                <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent opacity-60"></div>
                                <div class="absolute top-4 right-4 @statusColor backdrop-blur-md px-3 py-1 rounded-full text-label-sm flex items-center gap-1 shadow-sm font-semibold">
                                    @if (!string.IsNullOrEmpty(statusIcon))
                                    {
                                        <span class="material-symbols-outlined text-[14px]">@statusIcon</span>
                                    }
                                    else
                                    {
                                        <span class="w-2 h-2 rounded-full @statusDot"></span>
                                    }
                                    @u.Status
                                </div>
                                <div class="absolute bottom-4 left-4 right-4">
                                    <h3 class="text-headline-md font-bold text-white drop-shadow">Unit @u.Number</h3>
                                    <p class="text-label-md text-white/90 flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">home</span> @u.UnitTypeName</p>
                                </div>
                            </div>
                            <div class="p-6 flex flex-col flex-1">
                                <div class="flex justify-between items-start mb-6">
                                    <div class="flex flex-col gap-1">
                                        <div class="flex items-center gap-1 text-on-surface-variant text-label-md font-medium"><span class="material-symbols-outlined text-[18px]">king_bed</span> @u.MaxOccupancy Guests</div>
                                        <div class="flex items-center gap-1 text-on-surface-variant/80 text-label-sm"><span class="material-symbols-outlined text-[14px] text-secondary">location_on</span> @u.ResortName</div>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-headline-md text-primary font-bold">€@u.BasePrice.ToString("N2")</p>
                                        <p class="text-label-sm text-on-surface-variant font-medium">/ night</p>
                                    </div>
                                </div>
                                <div class="mt-auto grid grid-cols-2 gap-3 pt-4 border-t border-outline-variant/20">
                                    @if (u.Status == "Available")
                                    {
                                        <button onclick="alert('Stay dates successfully blocked for Unit @u.Number.');" class="bg-surface-container text-primary hover:bg-surface-container-high rounded-lg py-2 text-label-md font-semibold transition-colors flex items-center justify-center gap-2">
                                            <span class="material-symbols-outlined text-[18px]">calendar_month</span> Block Dates
                                        </button>
                                        <button onclick="alert('Housekeeping request has been dispatched.');" class="border border-outline-variant text-on-surface-variant hover:text-primary hover:border-primary rounded-lg py-2 text-label-md font-semibold transition-colors flex items-center justify-center gap-2">
                                            <span class="material-symbols-outlined text-[18px]">cleaning_services</span> Request Clean
                                        </button>
                                    }
                                    else if (u.Status == "Occupied")
                                    {
                                        <button onclick="window.location.href='/bookings'" class="col-span-2 bg-surface-container text-primary hover:bg-surface-container-high rounded-lg py-2 text-label-md font-semibold transition-colors flex items-center justify-center gap-2">
                                            <span class="material-symbols-outlined text-[18px]">receipt_long</span> View Booking
                                        </button>
                                    }
                                    else
                                    {
                                        <button onclick="window.location.href='/operations/maintenance'" class="col-span-2 bg-surface-container text-error hover:bg-error-container/50 rounded-lg py-2 text-label-md font-semibold transition-colors flex items-center justify-center gap-2">
                                            <span class="material-symbols-outlined text-[18px]">engineering</span> View Work Order
                                        </button>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                }
            </div>
        </div>
    </div>
</main>

<script>
    let activeLocation = "";

    document.addEventListener("DOMContentLoaded", function () {
        // Wire filters
        document.getElementById("filter-avail").addEventListener("change", applyFilters);
        document.getElementById("filter-occup").addEventListener("change", applyFilters);
        document.getElementById("filter-maint").addEventListener("change", applyFilters);
        
        document.getElementById("search-input").addEventListener("input", applyFilters);
        
        const slider = document.getElementById("bedrooms-slider");
        slider.addEventListener("input", function () {
            document.getElementById("bedrooms-value").textContent = this.value + "+ Beds";
            applyFilters();
        });
        
        applyFilters();
    });

    function toggleLocationTag(element, locationName) {
        const tags = document.querySelectorAll(".location-tag");
        
        if (activeLocation === locationName) {
            activeLocation = "";
            element.classList.remove("bg-primary", "text-on-primary");
            element.classList.add("bg-surface-container", "text-on-surface-variant");
        } else {
            activeLocation = locationName;
            tags.forEach(t => {
                t.classList.remove("bg-primary", "text-on-primary");
                t.classList.add("bg-surface-container", "text-on-surface-variant");
            });
            element.classList.remove("bg-surface-container", "text-on-surface-variant");
            element.classList.add("bg-primary", "text-on-primary");
        }
        applyFilters();
    }

    function applyFilters() {
        const showAvail = document.getElementById("filter-avail").checked;
        const showOccup = document.getElementById("filter-occup").checked;
        const showMaint = document.getElementById("filter-maint").checked;
        
        const searchQuery = document.getElementById("search-input").value.toLowerCase().trim();
        const minBeds = parseInt(document.getElementById("bedrooms-slider").value);
        
        const cards = document.querySelectorAll(".unit-card");
        let visibleCount = 0;

        cards.forEach(card => {
            const status = card.getAttribute("data-status");
            const location = card.getAttribute("data-location");
            const beds = parseInt(card.getAttribute("data-beds"));
            const number = card.getAttribute("data-number").toLowerCase();
            const type = card.getAttribute("data-type").toLowerCase();

            // Status Match
            let statusMatch = false;
            if (status === "Available" && showAvail) statusMatch = true;
            if (status === "Occupied" && showOccup) statusMatch = true;
            if (status === "Maintenance" && showMaint) statusMatch = true;

            // Location Match
            let locationMatch = true;
            if (activeLocation !== "" && location !== activeLocation) {
                locationMatch = false;
            }

            // Beds Match
            let bedsMatch = (beds >= minBeds);

            // Search Query Match
            let searchMatch = true;
            if (searchQuery !== "") {
                searchMatch = number.includes(searchQuery) || type.includes(searchQuery) || location.toLowerCase().includes(searchQuery);
            }

            if (statusMatch && locationMatch && bedsMatch && searchMatch) {
                card.style.display = "flex";
                setTimeout(() => { card.style.opacity = "1"; }, 10);
                visibleCount++;
            } else {
                card.style.opacity = "0";
                card.style.display = "none";
            }
        });

        // Show/Hide Empty State
        const emptyState = document.getElementById("empty-state");
        if (visibleCount === 0) {
            if (emptyState) emptyState.style.display = "flex";
        } else {
            if (emptyState) emptyState.style.display = "none";
        }
    }

    function resetFilters() {
        document.getElementById("filter-avail").checked = true;
        document.getElementById("filter-occup").checked = true;
        document.getElementById("filter-maint").checked = true;
        document.getElementById("search-input").value = "";
        
        const slider = document.getElementById("bedrooms-slider");
        slider.value = slider.getAttribute("min");
        document.getElementById("bedrooms-value").textContent = slider.value + "+ Beds";
        
        activeLocation = "";
        const tags = document.querySelectorAll(".location-tag");
        tags.forEach(t => {
            t.classList.remove("bg-primary", "text-on-primary");
            t.classList.add("bg-surface-container", "text-on-surface-variant");
        });
        
        applyFilters();
    }
</script>
