@{
    ViewData["Title"] = "Resort Portfolio Overview";
    var resorts = ViewBag.Resorts as List<dynamic> ?? new List<dynamic>();
}

<main class="pt-[120px] pb-20 px-margin-mobile md:px-margin-tablet lg:px-margin-desktop max-w-container-max mx-auto w-full">
    <!-- Header Section -->
    <header class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-display-lg-mobile md:text-display-lg font-bold text-primary mb-2">Resort Portfolio</h1>
            <p class="text-body-lg text-on-surface-variant">Manage and monitor your luxury properties.</p>
        </div>
        <div class="flex gap-4">
            <div class="glass-panel rounded-full px-6 py-3 flex items-center gap-4 shadow-sm border border-white/50">
                <div class="flex flex-col">
                    <span class="text-label-sm text-on-surface-variant uppercase tracking-wider">Total Occupancy</span>
                    <span class="text-headline-md text-primary font-bold">@ViewBag.OverallOccupancy%</span>
                </div>
                <div class="w-px h-8 bg-outline-variant/30"></div>
                <div class="flex flex-col">
                    <span class="text-label-sm text-on-surface-variant uppercase tracking-wider">Active Units</span>
                    <span class="text-headline-md text-primary font-bold">@ViewBag.OverallActiveUnits</span>
                </div>
            </div>
        </div>
    </header>
    
    <!-- Bento Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter mb-12">
        <!-- Map View (Takes up 8 columns on large screens) -->
        <div class="lg:col-span-8 rounded-xl overflow-hidden glass-panel relative h-[400px] shadow-sm border border-white/60">
            <!-- Dynamic Google Map Embed -->
            <iframe id="resort-map" class="w-full h-full border-0 opacity-90 transition-opacity duration-300" src="about:blank" allowfullscreen loading="lazy"></iframe>
        </div>
        
        <!-- Stats/Distribution (Takes up 4 columns on large screens) -->
        <div class="lg:col-span-4 flex flex-col gap-gutter">
            <!-- Unit Distribution -->
            <div class="glass-panel rounded-xl p-6 flex-1 flex flex-col justify-between shadow-sm">
                <h3 class="text-label-md text-on-surface-variant uppercase tracking-wider mb-6 font-semibold">Unit Distribution</h3>
                <div class="flex-1 flex flex-col justify-center gap-6">
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <div class="flex items-center gap-3">
                                <div class="w-3 h-3 rounded-full bg-primary"></div>
                                <span class="text-body-md text-on-surface font-medium">Luxury Chalets</span>
                            </div>
                            <span class="text-label-md font-bold text-primary">@ViewBag.LuxuryChaletsCount</span>
                        </div>
                        <div class="w-full bg-surface-variant rounded-full h-1.5">
                            <div class="bg-primary h-1.5 rounded-full" style="width: @(ViewBag.LuxuryChaletsPct)%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <div class="flex items-center gap-3">
                                <div class="w-3 h-3 rounded-full bg-secondary"></div>
                                <span class="text-body-md text-on-surface font-medium">Private Villas</span>
                            </div>
                            <span class="text-label-md font-bold text-primary">@ViewBag.VillasCount</span>
                        </div>
                        <div class="w-full bg-surface-variant rounded-full h-1.5">
                            <div class="bg-secondary h-1.5 rounded-full" style="width: @(ViewBag.VillasPct)%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <div class="flex items-center gap-3">
                                <div class="w-3 h-3 rounded-full bg-tertiary-container"></div>
                                <span class="text-body-md text-on-surface font-medium">Penthouses</span>
                            </div>
                            <span class="text-label-md font-bold text-primary">@ViewBag.SuitesCount</span>
                        </div>
                        <div class="w-full bg-surface-variant rounded-full h-1.5">
                            <div class="bg-tertiary-container h-1.5 rounded-full" style="width: @(ViewBag.SuitesPct)%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Featured Resorts Portfolio Gallery -->
    <div>
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-headline-md font-bold text-primary">Featured Properties</h2>
            <div class="flex gap-2">
                <button onclick="window.location.href='/resorts/create'" class="text-label-md text-on-primary bg-primary px-5 py-2 rounded-full hover:bg-primary/95 transition-colors font-semibold flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">add</span> Add Resort
                </button>
                <button onclick="window.location.href='/resorts/units'" class="text-label-md text-secondary border border-secondary px-5 py-2 rounded-full hover:bg-secondary/5 transition-colors font-semibold flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">grid_on</span> View Detailed Units
                </button>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @if (resorts.Count > 0)
            {
                foreach (var resort in resorts)
                {
                    var imageUrl = "https://lh3.googleusercontent.com/aida-public/AB6AXuCb2fiu2TJHpYSCspoxkOY2AmtBmxXjpVWvF0GMoECIP5cDA-x8eYdBoYMswtzelsS358RduM_PFTv2TLB4V1CKkHGn633MrOCcyuDIRHrQKn-liYPJ9o2J2eaG346cYpys9U6qO0HnUEOqp6z_ZrX-2lIHFGzq4yGQR6FTetDnxhRQAT7iWIHH3E9bZ-9Jp0rOA9YK0QtibDO78CP8rkz2Oy6UTK3tS1BV6Mogus2WEbSkY51xCzeV9FEmIMEIGLBiUTIESZuUr5Y4";
                    if (resort.Name.Contains("Lakeside")) imageUrl = "https://lh3.googleusercontent.com/aida-public/AB6AXuCVd9qZWAU37goVbZU_w7FHZQ7kWCJUGltR1CttxVgfhVQslI4jt5O8VR4IsmnQmxzT2QyhTQALH5MP7YrGAKn0TUmRdFj9af0KmJkwylCLfhPZhCnfThMgWMpb4VbGR1zyYbRChiSH-ps7K2C4s-567FoZCkm28NSp3hhN2nbHoUtnziFBcuLSAHtf06NBWpe2D1B6ZfWCtk0PLSWs5d3QdqqnwNoicF1XOLLCgf5lLv7ppqNulrfa_We1X1y_5plpNDgs-Bq9qkqF";
                    if (resort.Name.Contains("Grand") || resort.Name.Contains("Estate")) imageUrl = "https://lh3.googleusercontent.com/aida-public/AB6AXuDrvUL3ZOIGdagSWDiEFU5r6z6sQP9GFOMt3Um-ZBp7sdpmr7q-mgcTsh7x62ws87dTkKr7-wfCaFzXVrO6pDjyn5Eq2fTUc_Ce0qs1YeciXE15cDgo3SNrKzOq8KknQXh3wAbjJBCs0NB6ownmN8W6ClFKGe-tB5vawX7aQ-3Ac6whAjS8mII03htojM3mbm4T_VbKxHB3VLCCPhT1JipG7DnmBfhbZ6QhmL5UFKA2FQ6WiGaaAVU-_N1inp9kqAw3oZRqAFsZwP2p";
                    
                    <div class="glass-panel featured-resort-card rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300 flex flex-col group cursor-pointer border border-white/40" onclick="focusResortMap('@resort.Name', '@resort.Address', this)">
                        <div class="h-64 relative overflow-hidden">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                            <img alt="@resort.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="@imageUrl"/>
                            <div class="absolute top-4 right-4 z-20">
                                <span class="bg-white/90 backdrop-blur-sm text-primary text-label-sm font-bold px-3 py-1 rounded-full border border-white/50 flex items-center gap-1 shadow-sm">
                                    <span class="material-symbols-outlined text-[14px]">star</span> 9.8
                                </span>
                            </div>
                            <div class="absolute bottom-4 left-4 z-20">
                                <h3 class="text-headline-md font-bold text-white mb-1">@resort.Name</h3>
                                <p class="text-label-md text-white/90 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[16px]">location_on</span> @resort.Address
                                </p>
                            </div>
                        </div>
                        <div class="p-6 bg-white flex-1 flex flex-col justify-between">
                            <div class="grid grid-cols-3 gap-4 mb-6">
                                <div class="text-center">
                                    <p class="text-label-sm text-on-surface-variant mb-1">Units</p>
                                    <p class="text-label-md text-primary font-bold">@resort.TotalUnits</p>
                                </div>
                                <div class="text-center border-l border-r border-outline-variant/30">
                                    <p class="text-label-sm text-on-surface-variant mb-1">Occupancy</p>
                                    <p class="text-label-md text-secondary font-bold">@resort.Occupancy%</p>
                                </div>
                                <div class="text-center">
                                    <p class="text-label-sm text-on-surface-variant mb-1">RevPAR</p>
                                    <p class="text-label-md text-primary font-bold">€@resort.RevPAR.ToString("N2")</p>
                                </div>
                            </div>
                            <button onclick="event.stopPropagation(); window.location.href='/resorts/units'" class="w-full py-2 border border-outline-variant text-primary text-label-md rounded-lg group-hover:bg-primary group-hover:text-on-primary transition-all duration-300 font-semibold">
                                Manage Property Units
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-1 md:col-span-2 lg:col-span-3 bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-12 text-center text-on-surface-variant flex flex-col items-center justify-center shadow-sm">
                    <span class="material-symbols-outlined text-[48px] text-outline/40 mb-4">apartment</span>
                    <h3 class="text-headline-md font-bold text-primary mb-2">No Resorts Found</h3>
                    <p class="text-body-md text-on-surface-variant max-w-md">There are no resorts registered under your portfolio yet. Click "Add Resort" to register your properties dynamically.</p>
                </div>
            }
        </div>
    </div>
</main>

<script>
    function focusResortMap(name, address, cardElement) {
        // Highlight selected card
        const cards = document.querySelectorAll('.featured-resort-card');
        cards.forEach(c => {
            c.classList.remove('border-secondary/40', 'shadow-md');
            c.classList.add('border-white/40');
        });
        
        if (cardElement) {
            cardElement.classList.remove('border-white/40');
            cardElement.classList.add('border-secondary/40', 'shadow-md');
        }

        const map = document.getElementById('resort-map');
        if (map) {
            map.style.opacity = '0';
            setTimeout(() => {
                map.src = 'https://maps.google.com/maps?q=' + encodeURIComponent(name + ', ' + address) + '&t=&z=14&ie=UTF8&iwloc=&output=embed';
                map.style.opacity = '0.9';
            }, 300);
        }
    }
    
    // Auto-focus first resort on load
    document.addEventListener("DOMContentLoaded", () => {
        const firstCard = document.querySelector('.featured-resort-card');
        if (firstCard) {
            firstCard.click();
        }
    });
</script>

