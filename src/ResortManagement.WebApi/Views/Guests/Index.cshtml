@{
    ViewData["Title"] = "Loyalty Relations Registry";
    var customers = ViewBag.Customers as List<dynamic>;
}

<div class="workspace-header">
    <div>
        <h1 class="header-title">Guest Relations</h1>
        <p class="header-meta">Manage your high-value clientele, review loyalty status, and track lifetime stays and spending.</p>
    </div>
</div>

<!-- Loyalty Summary Cards -->
<div class="dashboard-grid" style="margin-bottom: 40px;">
    <!-- platinum count -->
    <div class="glass-card metric-card">
        <div class="metric-icon-box blue" style="background-color: rgba(205,154,95,0.1); color: var(--tertiary);">
            <svg viewBox="0 0 24 24"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/></svg>
        </div>
        <div class="metric-info" style="flex-grow: 1;">
            <span class="metric-label">Total Platinum Guests</span>
            <span class="metric-value">142</span>
        </div>
        <span class="status-pill success" style="font-size: 11px; font-weight: 600;">+12% this Q</span>
    </div>

    <!-- avg spend -->
    <div class="glass-card metric-card">
        <div class="metric-icon-box teal">
            <svg viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="metric-info" style="flex-grow: 1;">
            <span class="metric-label">Average Spend / Stay</span>
            <span class="metric-value">$18.5k</span>
        </div>
        <span class="status-pill success" style="font-size: 11px; font-weight: 600;">+$2.1k YOY</span>
    </div>

    <!-- booking velocity -->
    <div class="glass-card metric-card">
        <div class="metric-icon-box gold" style="background-color: rgba(0, 106, 102, 0.08); color: var(--secondary);">
            <svg viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <div class="metric-info" style="flex-grow: 1;">
            <span class="metric-label">Booking Velocity</span>
            <span class="metric-value" style="color: var(--secondary);">High</span>
        </div>
    </div>
</div>

<!-- Search & Filtering Bar -->
<div class="glass-card" style="padding: 16px; margin-bottom: 32px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
    <div style="display: flex; gap: 8px;">
        <button class="btn btn-primary" style="padding: 8px 18px; font-size: 13px;">All Guests</button>
        <button class="btn btn-secondary" style="padding: 8px 18px; font-size: 13px;">Platinum</button>
        <button class="btn btn-secondary" style="padding: 8px 18px; font-size: 13px;">Gold</button>
    </div>
    <div style="position: relative; width: 280px;">
        <input class="form-control" type="text" placeholder="Search by name, email..." style="padding-left: 36px; padding-top: 10px; padding-bottom: 10px;" />
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-disabled);"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </div>
</div>

<!-- Guest Cards Grid -->
<div class="dashboard-grid">
    <!-- Guest 1 -->
