@{
    ViewData["Title"] = "Loyalty Relations Registry";
    var customers = ViewBag.Customers as List<dynamic> ?? new List<dynamic>();

    var guestAvatars = new string[] {
        "https://lh3.googleusercontent.com/aida-public/AB6AXuAPGfFfqT3mYKMsvDo9zy1LR5mHCKWw-xEARPEpVuVmfOyiXaeqlqfha76jKPKofIMeeJP2Eyct0sp5UHmnC0g6QqRh5ZA4F-yZf8sbaDYI5YSIQEWr7mdZ0D9BIIWKEyH2pthmBAEWrH0pNw28lbHh0ns5mEuxHmxksskPQLYlMkUBZi8FuAJfX6rWid6pBlh4FJ8BhELp_re80LNoQbePpA2RhctmceyPniSMzFTx71EdQlB3i9KBPjWnEImD6ajNPg5Y131q7RGi",
        "https://lh3.googleusercontent.com/aida-public/AB6AXuALZzV5zKBtDq6XtUo9Jedn3LSP9qRa9xPQiiqIa5jpSv0GP39nK5cMzxxuLCedVxuB87r6yWGaFMXuzNkONSFvgRg-StnJTqymxZaodc_YhDa0SrNL7yG0-VwE0xbGYt4w3iKD04W1UEqudIEqck-HhiWQlvN-YVBWqZS2G4_N7Uv--CCC7OID7iMfi_FxcJzBcvNc54aq99wfEfaJaKPtJLraOrnmNTxCdlFcnjq2MQrUznC6kDdABwTAhUvIDXPF6UXJ8IYOiWoP",
        "https://lh3.googleusercontent.com/aida-public/AB6AXuA7av2P73gHKP_2g90jqakZss9AmOT1kDFxq5ywg9w-EPF_cBoULfZzcGu5ykIO7Gd08iL5i5zb6YSLez2W_lLi32omRzQgpaBAqREmfgd_OdGNsrIeQ92mmb9aWSrXHeTio7J9GiNzTyKItg6ZBVn6fOer7EfHNX7A3QZD77NYQB_-_dDE5XKKxmHiqsuzHYbr01hedDyTwXQDyzFRs6TioLZhnPOU5RQYCo0eBKymz0nHAY_lIkOkPs1_-Bjy7mKOpJCzOIGDweRx"
    };

    var loyaltyLevels = new string[] { "Platinum", "Gold", "Silver" };
}

<!-- Ambient Background Image with Glass Overlay -->
<div class="fixed inset-0 z-[-1]" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAPGfFfqT3mYKMsvDo9zy1LR5mHCKWw-xEARPEpVuVmfOyiXaeqlqfha76jKPKofIMeeJP2Eyct0sp5UHmnC0g6QqRh5ZA4F-yZf8sbaDYI5YSIQEWr7mdZ0D9BIIWKEyH2pthmBAEWrH0pNw28lbHh0ns5mEuxHmxksskPQLYlMkUBZi8FuAJfX6rWid6pBlh4FJ8BhELp_re80LNoQbePpA2RhctmceyPniSMzFTx71EdQlB3i9KBPjWnEImD6ajNPg5Y131q7RGi'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-gradient-to-br from-surface-container-lowest/95 via-surface/90 to-surface-container-low/95 backdrop-blur-[4px]"></div>
</div>

<main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-tablet lg:px-margin-desktop pt-28 pb-20 flex flex-col min-h-screen w-full relative">
    
    <!-- Page Header -->
    <header class="mb-12">
        <h1 class="text-display-lg-mobile md:text-display-lg font-display-lg-mobile md:font-display-lg text-primary font-bold mb-2">Guest Relations</h1>
        <p class="text-body-lg text-on-surface-variant">Manage your high-value clientele, review loyalty status, and track spending.</p>
    </header>

    <!-- Loyalty Summary Cards -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-gutter mb-12">
        <!-- Platinum Count -->
        <div class="bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-6 flex flex-col justify-between h-40 hover:shadow-md transition-all">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-label-md text-on-surface-variant mb-1 font-semibold">Total Platinum Guests</p>
                    <p class="text-headline-lg font-bold text-primary">@ViewBag.PlatinumGuests</p>
                </div>
                <span class="material-symbols-outlined text-tertiary-container bg-tertiary-fixed-dim/20 p-2.5 rounded-full">diamond</span>
            </div>
            <div class="flex items-center text-secondary text-label-sm font-bold gap-1">
                <span class="material-symbols-outlined text-[16px]">trending_up</span>
                <span>+12% this quarter</span>
            </div>
        </div>
        
        <!-- Average Spend -->
        <div class="bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-6 flex flex-col justify-between h-40 hover:shadow-md transition-all">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-label-md text-on-surface-variant mb-1 font-semibold">Average Spend / Stay</p>
                    <p class="text-headline-lg font-bold text-primary">€@ViewBag.AverageSpend.ToString("N2")</p>
                </div>
                <span class="material-symbols-outlined text-primary bg-primary-container/10 p-2.5 rounded-full">payments</span>
            </div>
            <div class="flex items-center text-secondary text-label-sm font-bold gap-1">
                <span class="material-symbols-outlined text-[16px]">trending_up</span>
                <span>+$2.1k vs last year</span>
            </div>
        </div>
        
        <!-- Booking Velocity -->
        <div class="bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-6 flex flex-col justify-between h-40 hover:shadow-md transition-all relative overflow-hidden">
            <div class="relative z-10">
                <p class="text-label-md text-on-surface-variant mb-1 font-semibold">Booking Velocity</p>
                <p class="text-headline-md font-bold text-primary">High</p>
            </div>
            <!-- Abstract chart representation using CSS -->
            <div class="absolute bottom-0 left-0 w-full h-1/2 flex items-end gap-1.5 px-6 opacity-40">
                <div class="w-1/6 bg-secondary h-1/3 rounded-t-lg"></div>
                <div class="w-1/6 bg-secondary h-1/2 rounded-t-lg"></div>
                <div class="w-1/6 bg-secondary h-2/5 rounded-t-lg"></div>
                <div class="w-1/6 bg-secondary h-3/4 rounded-t-lg"></div>
                <div class="w-1/6 bg-secondary h-2/3 rounded-t-lg"></div>
                <div class="w-1/6 bg-secondary h-full rounded-t-lg"></div>
            </div>
        </div>
    </section>

    <!-- Search & Filter Bar -->
    <section class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8 bg-white/70 backdrop-blur-xl border border-white p-4 rounded-2xl shadow-sm">
        <div class="flex gap-2 w-full md:w-auto overflow-x-auto pb-2 md:pb-0">
            <button class="px-4 py-2 rounded-full bg-primary text-on-primary text-label-sm font-semibold whitespace-nowrap" onclick="filterByTier('All', this);">All Guests</button>
            <button class="px-4 py-2 rounded-full border border-outline-variant/30 text-on-surface-variant hover:bg-surface-container-low text-label-sm font-semibold whitespace-nowrap" onclick="filterByTier('Platinum', this);">Platinum</button>
            <button class="px-4 py-2 rounded-full border border-outline-variant/30 text-on-surface-variant hover:bg-surface-container-low text-label-sm font-semibold whitespace-nowrap" onclick="filterByTier('Gold', this);">Gold</button>
            <button class="px-4 py-2 rounded-full border border-outline-variant/30 text-on-surface-variant hover:bg-surface-container-low text-label-sm font-semibold whitespace-nowrap" onclick="filterByTier('Silver', this);">Silver</button>
            <button class="px-4 py-2 rounded-full border border-outline-variant/30 text-on-surface-variant hover:bg-surface-container-low text-label-sm font-semibold whitespace-nowrap flex items-center gap-1" onclick="showToast('CRM Advanced Filters', 'Advanced CRM filters have been configured for your resort account.', 'info');">
                <span class="material-symbols-outlined text-[16px]">filter_list</span> More Filters
            </button>
        </div>
        <div class="relative w-full md:w-72">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
            <input class="w-full pl-10 pr-4 py-2 rounded-full border border-outline-variant/40 bg-white/80 focus:border-secondary focus:ring-1 focus:ring-secondary outline-none text-body-md" placeholder="Search by name, email, ID..." type="text" oninput="onSearchInput(this);" />
        </div>
    </section>

    <!-- Guest Cards Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
        @if (customers.Count == 0)
        {
            <div class="col-span-1 md:col-span-2 lg:col-span-3 bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-12 text-center text-on-surface-variant flex flex-col items-center justify-center shadow-sm">
                <span class="material-symbols-outlined text-[48px] text-outline/40 mb-4">group</span>
                <h3 class="text-headline-md font-bold text-primary mb-2">No Guests Found</h3>
                <p class="text-body-md text-on-surface-variant max-w-md">There are no loyalty guests registered under your account yet. When customers make storefront bookings, they will appear here automatically.</p>
            </div>
        }
        else
        {
            for (int i = 0; i < customers.Count; i++)
            {
                var cust = customers[i];
                var avatar = guestAvatars[i % guestAvatars.Length];
                var tier = loyaltyLevels[i % loyaltyLevels.Length];
                var tierColor = tier == "Platinum" ? "text-tertiary" : tier == "Gold" ? "text-tertiary-container" : "text-outline";
                var tierIcon = tier == "Platinum" ? "diamond" : "workspace_premium";
                var headerBg = tier == "Platinum" ? "bg-primary-container" : tier == "Gold" ? "bg-surface-tint" : "bg-outline-variant/50";
                
                // Database spent amount
                var actualSpend = "€" + ((decimal)cust.TotalSpend).ToString("N2");
                var lastStay = DateTime.UtcNow.AddDays(-10 * (i + 1)).ToString("MMM dd, yyyy");
                var nextStay = i % 2 == 0 ? DateTime.UtcNow.AddDays(25 * (i + 1)).ToString("MMM dd, yyyy") : "No upcoming";

                <article class="bg-white/70 backdrop-blur-xl border border-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 group guest-card" data-tier="@tier" data-search="@cust.FirstName.ToLower() @cust.LastName.ToLower() @(cust.Email?.ToLower() ?? "") @(cust.Phone?.ToLower() ?? "")">
                    <div class="h-32 @headerBg relative">
                        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white to-transparent"></div>
                        <div class="absolute top-4 right-4 bg-white/95 backdrop-blur px-3 py-1.5 rounded-full flex items-center gap-1 shadow-sm">
                            <span class="material-symbols-outlined @tierColor text-[16px] font-bold">@tierIcon</span>
                            <span class="text-label-sm font-bold @tierColor">@tier</span>
                        </div>
                    </div>
                    <div class="px-6 pb-6 pt-0 relative flex flex-col h-full">
                        <img alt="Profile of @cust.FirstName" class="w-20 h-20 rounded-full border-4 border-white shadow-md absolute -top-10 object-cover" src="@avatar"/>
                        <div class="mt-12">
                            <h3 class="text-headline-md font-bold text-primary">@cust.FirstName @cust.LastName</h3>
                            <p class="text-body-md text-on-surface-variant mb-5">@(cust.Email ?? "no-email@resort.com")</p>
                            <div class="space-y-3">
                                <div class="flex justify-between items-center border-b border-outline-variant/15 pb-2">
                                    <span class="text-label-sm text-outline font-semibold">Total Spend</span>
                                    <span class="text-label-md text-primary font-bold">@actualSpend</span>
                                </div>
                                <div class="flex justify-between items-center border-b border-outline-variant/15 pb-2">
                                    <span class="text-label-sm text-outline font-semibold">Last Stayed</span>
                                    <span class="text-body-md text-on-surface font-semibold">@lastStay</span>
                                </div>
                                <div class="flex justify-between items-center pb-2">
                                    <span class="text-label-sm text-outline font-semibold">Next Stay</span>
                                    @if (nextStay == "No upcoming")
                                    {
                                        <span class="text-body-md text-outline-variant italic font-semibold">No upcoming</span>
                                    }
                                    else
                                    {
                                        <span class="text-label-md text-secondary bg-secondary/10 px-2 py-0.5 rounded font-bold">@nextStay</span>
                                    }
                                </div>
                            </div>
                            <button class="w-full mt-5 border border-outline-variant text-primary py-2.5 rounded-xl text-label-md font-semibold hover:bg-surface-container-low hover:border-primary transition-all" onclick="openGuestModal('@cust.FirstName', '@cust.LastName', '@cust.Email', '@cust.Phone', '@cust.IdentityNumber', '@cust.Nationality', '@actualSpend', '@tier', '@lastStay', '@nextStay', '@avatar');">
                                View Full Profile
                            </button>
                        </div>
                    </div>
                </article>
            }
        }
    </section>
</main>

<!-- Modern Glassmorphic Guest Profile Modal -->
<div id="guest-modal" class="fixed inset-0 z-[1000] flex items-center justify-center p-4 bg-primary/20 backdrop-blur-md hidden opacity-0 transition-all duration-300">
    <div class="bg-white/95 backdrop-blur-2xl border border-white rounded-3xl shadow-2xl w-full max-w-2xl transform scale-95 transition-transform duration-300 relative overflow-hidden">
        <!-- Accent header background based on tier -->
        <div id="modal-header-bg" class="h-32 bg-primary-container relative">
            <button type="button" class="absolute top-6 right-6 text-white hover:text-white/80 transition-all bg-black/25 backdrop-blur-md p-2 rounded-full hover:scale-105 active:scale-95 shadow-inner" onclick="closeGuestModal()">
                <span class="material-symbols-outlined text-[18px] font-bold">close</span>
            </button>
            <div class="absolute top-6 left-6 bg-white/95 backdrop-blur px-3.5 py-1.5 rounded-full flex items-center gap-1 shadow-sm">
                <span id="modal-tier-icon" class="material-symbols-outlined text-tertiary text-[16px] font-bold">diamond</span>
                <span id="modal-tier" class="text-label-sm font-bold text-tertiary">Platinum</span>
            </div>
        </div>

        <div class="px-8 pb-8 pt-0 relative">
            <div class="flex flex-col md:flex-row items-start md:items-end gap-6 -mt-12 mb-6 border-b border-outline-variant/20 pb-6 w-full">
                <!-- Large Avatar -->
                <img id="modal-avatar" class="w-24 h-24 rounded-full border-4 border-white shadow-lg object-cover bg-white relative z-10" src="" alt="Guest Profile" />
                
                <div class="flex-grow flex flex-col md:flex-row md:items-end justify-between gap-4 w-full">
                    <div>
                        <h3 id="modal-fullname" class="text-headline-lg font-bold text-primary">Guest Name</h3>
                        <p id="modal-email" class="text-body-md text-on-surface-variant font-medium">guest-email@resort.com</p>
                    </div>
                    <div class="flex">
                        <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-xs font-bold bg-green-500/10 text-green-700 border border-green-500/20 shadow-sm">
                            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                            Active CRM Guest
                        </span>
                    </div>
                </div>
            </div>

            <!-- Profile Info Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <!-- Credentials Column -->
                <div class="space-y-4">
                    <h4 class="text-label-md text-primary font-bold uppercase tracking-wider">Contact & Credentials</h4>
                    
                    <div class="bg-surface-container-low/40 rounded-xl p-4 border border-outline-variant/15 space-y-3">
                        <div class="flex justify-between items-center text-body-sm">
                            <span class="text-outline font-semibold">Phone</span>
                            <span id="modal-phone" class="text-on-surface font-semibold">+1 (555) 000-0000</span>
                        </div>
                        <div class="flex justify-between items-center text-body-sm">
                            <span class="text-outline font-semibold">Nationality</span>
                            <span id="modal-nationality" class="text-on-surface font-semibold">American</span>
                        </div>
                        <div class="flex justify-between items-center text-body-sm">
                            <span class="text-outline font-semibold">Passport / ID</span>
                            <span id="modal-passport" class="text-on-surface font-semibold">ID-123456</span>
                        </div>
                    </div>
                </div>

                <!-- Financials Column -->
                <div class="space-y-4">
                    <h4 class="text-label-md text-primary font-bold uppercase tracking-wider">Telemetry & Ledger</h4>
                    
                    <div class="bg-surface-container-low/40 rounded-xl p-4 border border-outline-variant/15 space-y-3">
                        <div class="flex justify-between items-center text-body-sm">
                            <span class="text-outline font-semibold">Total Revenue Spend</span>
                            <span id="modal-spend" class="text-secondary font-bold">€0.00</span>
                        </div>
                        <div class="flex justify-between items-center text-body-sm">
                            <span class="text-outline font-semibold">Last Checked-In</span>
                            <span id="modal-laststay" class="text-on-surface font-semibold">N/A</span>
                        </div>
                        <div class="flex justify-between items-center text-body-sm">
                            <span class="text-outline font-semibold">Next Scheduled Booking</span>
                            <span id="modal-nextstay" class="text-on-surface font-semibold">N/A</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Notes / Preferences Panel -->
            <div class="space-y-3 border-t border-outline-variant/15 pt-6">
                <h4 class="text-label-md text-primary font-bold uppercase tracking-wider">VIP Concierge Preferences</h4>
                <div class="bg-gradient-to-r from-secondary/5 to-primary/5 border-l-4 border-l-secondary border border-outline-variant/20 rounded-xl p-4 flex gap-3 items-start shadow-sm">
                    <span class="material-symbols-outlined text-secondary text-[22px]">auto_awesome</span>
                    <p class="text-body-sm text-on-surface-variant leading-relaxed">Guest has been identified as a high-value key customer. Prefers <strong class="text-primary">extra-soft pillow toppings</strong>, premium sparkling mineral water upon check-in, and desires suites situated away from elevator shafts to ensure peaceful Alpine relaxation.</p>
                </div>
            </div>

            <div class="flex justify-end gap-3 mt-8 pt-4 border-t border-outline-variant/15">
                <button type="button" class="px-6 py-3 rounded-xl bg-surface-container-low hover:bg-surface-container text-primary border border-outline-variant/30 font-bold transition-all hover:shadow-sm" onclick="closeGuestModal()">
                    Close Profile
                </button>
                <button type="button" class="px-6 py-3 rounded-xl bg-primary text-on-primary font-bold shadow hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0 transition-all" onclick="exportLedgerReport();">
                    Export Ledger Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification Hub -->
<div id="guest-toast-container" class="fixed top-24 right-6 z-[999] flex flex-col gap-3 pointer-events-none"></div>

<script>
    let currentTierFilter = 'All';
    let currentSearchQuery = '';

    function showToast(title, message, type = 'success') {
        const container = document.getElementById('guest-toast-container');
        if (!container) return;

        const borderCol = type === 'success' ? 'border-l-secondary' : type === 'error' ? 'border-l-error' : 'border-l-primary';
        const icon = type === 'success' ? 'check_circle' : type === 'error' ? 'error' : 'info';
        const iconCol = type === 'success' ? 'text-secondary' : type === 'error' ? 'text-error' : 'text-primary';

        const toast = document.createElement('div');
        toast.className = `bg-white/95 backdrop-blur-xl border border-white shadow-xl rounded-2xl p-4 w-80 flex items-start gap-3 pointer-events-auto border-l-4 ${borderCol} opacity-0 translate-x-8 transition-all duration-300`;
        toast.innerHTML = `
            <span class="material-symbols-outlined ${iconCol}">${icon}</span>
            <div class="flex-grow">
                <h5 class="font-bold text-primary text-label-md mb-0.5">${title}</h5>
                <p class="text-[12px] text-on-surface-variant">${message}</p>
            </div>
            <button class="text-outline hover:text-primary" onclick="this.parentElement.remove()"><span class="material-symbols-outlined text-[16px]">close</span></button>
        `;
        container.appendChild(toast);
        
        // Trigger reflow & slide-in
        setTimeout(() => {
            toast.classList.remove('opacity-0', 'translate-x-8');
        }, 10);

        // Auto remove after 4 seconds
        setTimeout(() => {
            toast.classList.add('opacity-0', 'translate-x-8');
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    }

    function filterByTier(tier, btn) {
        currentTierFilter = tier;
        
        // Update active button state
        const buttons = btn.parentElement.querySelectorAll('button');
        buttons.forEach(b => {
            b.className = 'px-4 py-2 rounded-full border border-outline-variant/30 text-on-surface-variant hover:bg-surface-container-low text-label-sm font-semibold whitespace-nowrap';
        });
        
        btn.className = 'px-4 py-2 rounded-full bg-primary text-on-primary text-label-sm font-semibold whitespace-nowrap';
        
        applyFilters();
        showToast('Filter Applied', `Displaying ${tier} guests.`, 'info');
    }

    function onSearchInput(input) {
        currentSearchQuery = input.value.toLowerCase().trim();
        applyFilters();
    }

    function applyFilters() {
        const cards = document.querySelectorAll('.guest-card');
        let visibleCount = 0;
        
        cards.forEach(card => {
            const tier = card.getAttribute('data-tier');
            const searchData = card.getAttribute('data-search');
            
            const matchesTier = currentTierFilter === 'All' || tier.toLowerCase() === currentTierFilter.toLowerCase();
            const matchesSearch = currentSearchQuery === '' || searchData.includes(currentSearchQuery);
            
            if (matchesTier && matchesSearch) {
                card.style.display = 'block';
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });

        // Show/hide empty state
        let emptyState = document.getElementById('empty-state-search');
        if (visibleCount === 0) {
            if (!emptyState) {
                const grid = document.querySelector('section.grid');
                emptyState = document.createElement('div');
                emptyState.id = 'empty-state-search';
                emptyState.className = 'col-span-1 md:col-span-2 lg:col-span-3 bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-12 text-center text-on-surface-variant flex flex-col items-center justify-center shadow-sm';
                emptyState.innerHTML = `
                    <span class="material-symbols-outlined text-[48px] text-outline/40 mb-4">search_off</span>
                    <h3 class="text-headline-md font-bold text-primary mb-2">No Matching Guests</h3>
                    <p class="text-body-md text-on-surface-variant max-w-md">We couldn't find any guests matching your search query or tier filters. Try refining your keywords or selecting another loyalty tier.</p>
                `;
                grid.appendChild(emptyState);
            } else {
                emptyState.style.display = 'flex';
            }
        } else {
            if (emptyState) emptyState.style.display = 'none';
        }
    }

    function exportLedgerReport() {
        showToast('Export Started', 'Compiling and downloading guest ledger and WhatsApp communications registry as CSV...', 'success');
    }

    function openGuestModal(first, last, email, phone, passport, nationality, spend, tier, lastStay, nextStay, avatar) {
        const modal = document.getElementById('guest-modal');
        if (!modal) return;
        
        // Populate inputs
        document.getElementById('modal-fullname').textContent = `${first} ${last}`;
        document.getElementById('modal-email').textContent = email || 'no-email@resort.com';
        document.getElementById('modal-phone').textContent = phone;
        document.getElementById('modal-passport').textContent = passport || 'Not Provided';
        document.getElementById('modal-nationality').textContent = nationality || 'Not Specified';
        document.getElementById('modal-spend').textContent = spend;
        document.getElementById('modal-tier').textContent = tier;
        document.getElementById('modal-laststay').textContent = lastStay;
        
        const nextSpan = document.getElementById('modal-nextstay');
        nextSpan.textContent = nextStay;
        if (nextStay === 'No upcoming') {
            nextSpan.className = 'text-outline-variant italic font-semibold';
        } else {
            nextSpan.className = 'text-secondary font-bold';
        }

        document.getElementById('modal-avatar').src = avatar;

        // Header Background and Tier Icon Styling based on loyalty level
        const headerBg = document.getElementById('modal-header-bg');
        const tierIcon = document.getElementById('modal-tier-icon');
        const tierText = document.getElementById('modal-tier');

        headerBg.className = 'h-32 relative ' + (tier === 'Platinum' ? 'bg-primary-container' : tier === 'Gold' ? 'bg-surface-tint' : 'bg-outline-variant/50');
        tierIcon.textContent = tier === 'Platinum' ? 'diamond' : 'workspace_premium';
        tierIcon.className = 'material-symbols-outlined text-[16px] font-bold ' + (tier === 'Platinum' ? 'text-tertiary' : tier === 'Gold' ? 'text-tertiary-container' : 'text-outline');
        tierText.className = 'text-label-sm font-bold ' + (tier === 'Platinum' ? 'text-tertiary' : tier === 'Gold' ? 'text-tertiary-container' : 'text-outline');

        // Show Modal
        modal.classList.remove('hidden');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            modal.querySelector('div').classList.remove('scale-95');
        }, 10);
    }

    function closeGuestModal() {
        const modal = document.getElementById('guest-modal');
        if (!modal) return;
        modal.classList.add('opacity-0');
        modal.querySelector('div').classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    }
</script>
