@{
    ViewData["Title"] = "Financial Overview & Invoices";
    var invoices = ViewBag.Invoices as List<dynamic> ?? new List<dynamic>();
}

<!-- Ambient Background Image with Glass Overlay -->
<div class="fixed inset-0 z-[-1]" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCvgn-mPhUYdsyc1Am9qBVRUFnyOCNbCkj8jPOqWYIMXIy8qCWt3ITtn_dBHbT2g5-xdLzVaq3huN-SrOV3sH1YXWqX2HJfDj0jv7Zk3CFwTV1e3hbvzXIr7k1g2SSanVfME98cCtPDfsAfebES9hiw3JQxHYp8V6-PgS1diVkA1zuEwWgrHuS239dOweQlJCt8G7_dOGik1SeXfJ0z0CRHe75j7CxR9o52K6HUONnNpL6mrNVu9Sncr-Q3kxJz6ikTSzJ5AUum0RBu'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-gradient-to-br from-surface-container-lowest/95 via-surface/90 to-surface-container-low/95 backdrop-blur-[4px]"></div>
</div>

<main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-tablet lg:px-margin-desktop pt-28 pb-20 flex flex-col min-h-screen w-full relative">
    
    <!-- Page Header -->
    <header class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary font-bold mb-2">Financial Overview</h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">Executive summary of revenue performance, pending transactions, and key metrics across the chalet portfolio.</p>
        </div>
        <div class="flex gap-4 w-full md:w-auto">
            <button class="flex-1 md:flex-none bg-white/80 border border-secondary text-secondary font-label-md text-label-md px-6 py-3 rounded-xl hover:bg-secondary/5 transition-all flex items-center justify-center gap-2 font-semibold shadow-sm" onclick="alert('Financial PDF report successfully compiled.');">
                <span class="material-symbols-outlined text-[20px]">download</span> Export Report
            </button>
        </div>
    </header>

    <!-- Key Metrics Bento Grid -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-gutter mb-12">
        <!-- RevPAR -->
        <div class="bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-6 md:p-8 flex flex-col justify-between hover:shadow-md transition-all duration-300 group">
            <div class="flex justify-between items-start mb-6">
                <div class="p-3 bg-primary-container/10 text-primary rounded-xl">
                    <span class="material-symbols-outlined text-[24px]">trending_up</span>
                </div>
                <span class="text-secondary text-label-md bg-secondary/10 px-3 py-1 rounded-full flex items-center gap-1 font-bold">Live Stats</span>
            </div>
            <div>
                <p class="text-label-md text-on-surface-variant mb-1 font-semibold">RevPAR (YTD)</p>
                <h3 class="text-headline-lg-mobile md:text-headline-lg font-bold text-primary">€@ViewBag.RevPAR.ToString("N2")</h3>
            </div>
        </div>
        
        <!-- ADR -->
        <div class="bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-6 md:p-8 flex flex-col justify-between hover:shadow-md transition-all duration-300 group relative overflow-hidden">
            <div class="absolute -right-10 -top-10 opacity-5 w-40 h-40 bg-secondary rounded-full blur-3xl"></div>
            <div class="flex justify-between items-start mb-6 relative z-10">
                <div class="p-3 bg-surface-variant/40 text-on-surface-variant rounded-xl">
                    <span class="material-symbols-outlined text-[24px]">sell</span>
                </div>
                <span class="text-secondary text-label-md bg-secondary/10 px-3 py-1 rounded-full flex items-center gap-1 font-bold">Live Stats</span>
            </div>
            <div class="relative z-10">
                <p class="text-label-md text-on-surface-variant mb-1 font-semibold">ADR (Average Daily Rate)</p>
                <h3 class="text-headline-lg-mobile md:text-headline-lg font-bold text-primary">€@ViewBag.ADR.ToString("N2")</h3>
            </div>
        </div>
        
        <!-- Total Revenue -->
        <div class="bg-primary rounded-2xl p-6 md:p-8 flex flex-col justify-between hover:shadow-lg transition-all duration-300 group border-none shadow-md">
            <div class="flex justify-between items-start mb-6">
                <div class="p-3 bg-white/10 text-on-primary rounded-xl backdrop-blur-md">
                    <span class="material-symbols-outlined text-[24px]">account_balance</span>
                </div>
                <span class="text-on-primary text-label-md bg-white/20 px-3 py-1 rounded-full flex items-center gap-1 font-bold">Live Stats</span>
            </div>
            <div>
                <p class="text-label-md text-primary-fixed-dim mb-1 font-semibold">Total Revenue (Q3)</p>
                <h3 class="text-headline-lg-mobile md:text-headline-lg font-bold text-on-primary">€@ViewBag.TotalRevenue.ToString("N2")</h3>
            </div>
        </div>
    </section>

    <!-- Charts Section -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-gutter mb-12">
        <!-- Main Revenue Area Chart -->
        <div class="lg:col-span-2 bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-6 flex flex-col h-[400px]">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-headline-md font-bold text-primary">Revenue Trends</h3>
                <select class="bg-surface-container-low border border-outline-variant/30 text-on-surface text-label-sm font-label-sm rounded-xl px-3 py-1.5 focus:ring-secondary focus:border-secondary outline-none transition-all">
                    <option>Last 6 Months</option>
                    <option>Year to Date</option>
                    <option>Last 12 Months</option>
                </select>
            </div>
            <div class="flex-grow relative w-full h-[280px]">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
        
        <!-- Occupancy/Payment Bar Chart -->
        <div class="bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-6 flex flex-col h-[400px]">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-headline-md font-bold text-primary">Collection Status</h3>
                <button class="text-on-surface-variant hover:text-primary"><span class="material-symbols-outlined">more_vert</span></button>
            </div>
            <div class="flex-grow relative w-full h-[280px]">
                <canvas id="collectionChart"></canvas>
            </div>
        </div>
    </section>

    <!-- Invoice Management & Timeline Layout -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
        <!-- Invoices List -->
        <div class="lg:col-span-2 bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-6 overflow-hidden flex flex-col">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
                <h3 class="text-headline-md font-bold text-primary">Recent Invoices</h3>
                <div class="flex gap-2 bg-surface-container-low/55 p-1 rounded-xl">
                    <button class="px-4 py-1.5 bg-white shadow-sm rounded-lg text-label-sm font-semibold text-primary transition-all">All</button>
                    <button class="px-4 py-1.5 rounded-lg text-label-sm font-semibold text-on-surface-variant hover:bg-surface-container-high transition-all" onclick="alert('Filtering list by Paid...');">Paid</button>
                    <button class="px-4 py-1.5 rounded-lg text-label-sm font-semibold text-on-surface-variant hover:bg-surface-container-high transition-all" onclick="alert('Filtering list by Overdue...');">Overdue</button>
                </div>
            </div>
            
            <div class="overflow-x-auto custom-scroll">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-outline-variant/30 text-label-sm text-on-surface-variant">
                            <th class="pb-3 font-bold">Invoice ID</th>
                            <th class="pb-3 font-bold">Client / Property</th>
                            <th class="pb-3 font-bold">Date</th>
                            <th class="pb-3 font-bold">Amount</th>
                            <th class="pb-3 font-bold">Status</th>
                            <th class="pb-3 font-bold"></th>
                        </tr>
                    </thead>
                    <tbody class="text-body-md">
                        @if (invoices.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="py-12 text-center text-on-surface-variant font-medium">
                                    <div class="flex flex-col items-center justify-center">
                                        <span class="material-symbols-outlined text-[48px] text-outline/40 mb-3">receipt_long</span>
                                        <p class="text-headline-sm font-bold text-primary mb-1">No Invoices Found</p>
                                        <p class="text-label-md text-on-surface-variant max-w-sm">No transaction invoices have been issued or recorded for your active properties yet.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var inv in invoices)
                            {
                                <tr class="border-b border-outline-variant/10 hover:bg-white/40 transition-colors">
                                    <td class="py-4 font-bold text-primary">#INV-@inv.InvoiceNumber</td>
                                    <td class="py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center text-label-sm font-bold">G</div>
                                            <div>
                                                <p class="text-primary font-bold text-sm leading-tight">Guest Onboard</p>
                                                <p class="text-on-surface-variant text-xs">#@inv.ShortId</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 text-on-surface-variant text-sm">@inv.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td class="py-4 font-bold text-primary">@inv.TotalAmount.ToString("C")</td>
                                    <td class="py-4">
                                        @{
                                            var badge = "bg-outline/10 text-on-surface-variant";
                                            var badgeColor = "bg-outline";
                                            if (inv.Status == "Paid")
                                            {
                                                badge = "bg-secondary/10 text-secondary";
                                                badgeColor = "bg-secondary";
                                            }
                                            else if (inv.Status == "Cancelled" || inv.Status == "Overdue")
                                            {
                                                badge = "bg-error/10 text-error";
                                                badgeColor = "bg-error";
                                            }
                                        }
                                        <span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-semibold @badge">
                                            <span class="w-1.5 h-1.5 rounded-full @badgeColor"></span> @inv.Status
                                        </span>
                                    </td>
                                    <td class="py-4 text-right">
                                        <button class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-[20px]">more_horiz</span></button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        <!-- Payment Tracking Timeline -->
        <div class="bg-white/70 backdrop-blur-xl border border-white rounded-2xl p-6 flex flex-col">
            <h3 class="text-headline-md font-bold text-primary mb-6">Recent Activity</h3>
            <div class="relative pl-6 border-l-2 border-outline-variant/30 flex flex-col gap-6 flex-grow">
                @if (ViewBag.RecentActivities.Count == 0)
                {
                    <div class="text-center py-12 text-on-surface-variant font-medium text-sm">
                        No recent transactions recorded.
                    </div>
                }
                else
                {
                    @foreach (var activity in ViewBag.RecentActivities)
                    {
                        var dotColor = "border-secondary";
                        var dotSubColor = "bg-secondary";
                        if (activity.Title.Contains("Failed") || activity.Title.Contains("Overdue"))
                        {
                            dotColor = "border-error";
                            dotSubColor = "bg-error";
                        }
                        else if (activity.Title.Contains("Generated"))
                        {
                            dotColor = "border-outline";
                            dotSubColor = "bg-outline";
                        }

                        <div class="relative">
                            <div class="absolute -left-[31px] bg-white p-1 rounded-full border-2 @dotColor z-10">
                                <div class="w-2 h-2 @dotSubColor rounded-full"></div>
                            </div>
                            <p class="text-label-sm text-on-surface-variant mb-1 font-semibold">@activity.Time.ToString("MMM dd, hh:mm tt")</p>
                            <p class="text-body-md text-primary font-bold">@activity.Title</p>
                            <p class="text-label-md text-on-surface-variant mt-1 leading-relaxed">@activity.Description</p>
                        </div>
                    }
                }
            </div>
            <button class="mt-6 text-secondary text-label-md font-bold hover:underline text-left" onclick="alert('Viewing comprehensive finance logs.');">
                View Full History
            </button>
        </div>
    </section>
</main>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Tailwind Colors extracted for Chart.js
            const colors = {
                primary: '#002741',
                secondary: '#006a66',
                secondaryLight: 'rgba(0, 106, 102, 0.1)',
                surfaceVariant: '#e2e2e5',
                onSurfaceVariant: '#42474e'
            };

            // Area Chart Gross Revenue
            const ctxRev = document.getElementById("revenueChart").getContext("2d");
            let grad = ctxRev.createLinearGradient(0, 0, 0, 300);
            grad.addColorStop(0, "rgba(0, 39, 65, 0.35)");
            grad.addColorStop(1, "rgba(0, 39, 65, 0)");

            new Chart(ctxRev, {
                type: 'line',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MonthsLabels)),
                    datasets: [{
                        label: 'Gross Revenue',
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MonthlyRevenue)),
                        borderColor: colors.primary,
                        backgroundColor: grad,
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: colors.primary,
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: colors.primary,
                            titleFont: { family: 'Inter', size: 13, weight: '600' },
                            bodyFont: { family: 'Inter', size: 13 },
                            padding: 12,
                            displayColors: false,
                            callbacks: {
                                label: function(context) {
                                    return '€ ' + context.parsed.y.toLocaleString();
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(194, 199, 206, 0.2)',
                                drawBorder: false,
                            },
                            ticks: {
                                color: colors.onSurfaceVariant,
                                font: { family: 'Inter', size: 12 },
                                callback: function(value) { return '€' + value.toLocaleString(); }
                            }
                        },
                        x: {
                            grid: { display: false, drawBorder: false },
                            ticks: {
                                color: colors.onSurfaceVariant,
                                font: { family: 'Inter', size: 12 }
                            }
                        }
                    },
                    interaction: {
                        intersect: false,
                        mode: 'index',
                    }
                }
            });

            // Stacked Bar Chart Collection Status
            const ctxColl = document.getElementById("collectionChart").getContext("2d");
            new Chart(ctxColl, {
                type: 'bar',
                data: {
                    labels: ['Q1', 'Q2', 'Q3'],
                    datasets: [
                        {
                            label: 'Collected',
                            data: [85, 90, 75],
                            backgroundColor: colors.secondary,
                            borderRadius: 4,
                            barPercentage: 0.6
                        },
                        {
                            label: 'Pending',
                            data: [15, 10, 25],
                            backgroundColor: 'rgba(194, 199, 206, 0.4)',
                            borderRadius: 4,
                            barPercentage: 0.6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                padding: 20,
                                font: { family: 'Inter', size: 12, weight: '500' },
                                color: colors.onSurfaceVariant
                            }
                        },
                        tooltip: {
                            backgroundColor: colors.primary,
                            titleFont: { family: 'Inter', size: 13, weight: '600' },
                            bodyFont: { family: 'Inter', size: 13 },
                            padding: 12,
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + context.parsed.y + '%';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            stacked: true,
                            max: 100,
                            grid: {
                                color: 'rgba(194, 199, 206, 0.2)',
                                drawBorder: false,
                            },
                            ticks: {
                                display: false
                            }
                        },
                        x: {
                            stacked: true,
                            grid: { display: false, drawBorder: false },
                            ticks: {
                                color: colors.onSurfaceVariant,
                                font: { family: 'Inter', size: 12 }
                            }
                        }
                    }
                }
            });
        });
    </script>
}
