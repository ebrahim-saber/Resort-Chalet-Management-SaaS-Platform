@{
    ViewData["Title"] = "Financial Overview & Invoices";
    var invoices = ViewBag.Invoices as List<dynamic>;
}

<div class="workspace-header">
    <div>
        <h1 class="header-title">Financial Overview</h1>
        <p class="header-meta">Executive summary of revenue performance, pending transactions, and key metrics across the chalet portfolio.</p>
    </div>
    <button class="btn btn-secondary" onclick="showLuxeAlert('Export Succeeded', 'Financial PDF report successfully compiled.', 'success')">
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
        Export Report
    </button>
</div>

<!-- Key Metrics Bento Grid -->
<div class="dashboard-grid" style="margin-bottom: 40px;">
    <!-- RevPAR -->
    <div class="glass-card metric-card">
        <div class="metric-icon-box blue">
            <svg viewBox="0 0 24 24"><path d="M23 6l-9.5 9.5-5-5L1 18M17 6h6v6"/></svg>
        </div>
        <div class="metric-info" style="flex-grow: 1;">
            <span class="metric-label">RevPAR (YTD)</span>
            <span class="metric-value">€1,245.00</span>
        </div>
        <span class="status-pill success" style="font-size: 11px; font-weight: 600;">+12.4% ↑</span>
    </div>

    <!-- ADR -->
    <div class="glass-card metric-card" style="position: relative; overflow: hidden;">
        <div class="metric-icon-box teal">
            <svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="2"/><circle cx="12" cy="12" r="2"/></svg>
        </div>
        <div class="metric-info" style="flex-grow: 1;">
            <span class="metric-label">ADR (Daily Average)</span>
            <span class="metric-value">€3,890.00</span>
        </div>
        <span class="status-pill success" style="font-size: 11px; font-weight: 600;">+5.2% ↑</span>
    </div>

    <!-- Total Revenue -->
    <div class="glass-card metric-card" style="background: var(--primary); color: #ffffff; border: none; box-shadow: 0 8px 30px rgba(0, 39, 65, 0.3);">
        <div class="metric-icon-box" style="background: rgba(255,255,255,0.2); color: #ffffff;">
            <svg viewBox="0 0 24 24" stroke="currentColor"><rect x="2" y="2" width="20" height="20" rx="2" ry="2"/><path d="M12 18V6M6 12h12"/></svg>
        </div>
        <div class="metric-info" style="flex-grow: 1;">
            <span class="metric-label" style="color: rgba(255,255,255,0.8);">Total Revenue (Q3)</span>
            <span class="metric-value" style="color: #ffffff;">€4.2M</span>
        </div>
        <span class="status-pill" style="font-size: 11px; font-weight: 600; background: rgba(255,255,255,0.2); color: #ffffff;">+18.9% ↑</span>
    </div>
</div>

<!-- Charts Section -->
<div style="display: grid; grid-template-columns: 2fr 1fr; gap: var(--grid-gap); margin-bottom: 40px; min-height: 380px;">
    <!-- Revenue Area Chart -->
    <div class="glass-card" style="display: flex; flex-direction: column;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h3 style="font-size: 18px; font-weight: 600; color: var(--primary);">Revenue Trends</h3>
            <select class="form-control" style="width: auto; padding: 6px 12px; font-size: 13px;">
                <option>Last 6 Months</option>
                <option>Year to Date</option>
                <option>Last 12 Months</option>
            </select>
        </div>
        <div style="flex-grow: 1; position: relative;">
            <canvas id="revenueChart" style="width: 100%; height: 100%; max-height: 250px;"></canvas>
        </div>
    </div>

    <!-- Collection Stacked Bar Chart -->
    <div class="glass-card" style="display: flex; flex-direction: column;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h3 style="font-size: 18px; font-weight: 600; color: var(--primary);">Collection Status</h3>
            <span style="font-size: 20px; color: var(--text-secondary); cursor: pointer;">•••</span>
        </div>
        <div style="flex-grow: 1; position: relative;">
            <canvas id="collectionChart" style="width: 100%; height: 100%; max-height: 250px;"></canvas>
        </div>
    </div>
</div>

<!-- Invoice Management Ledger -->
<div style="display: grid; grid-template-columns: 2fr 1fr; gap: var(--grid-gap); margin-bottom: 40px;">
    <!-- Recent Invoices Table -->
    <div class="glass-card" style="display: flex; flex-direction: column;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 style="font-size: 18px; font-weight: 600; color: var(--primary);">Recent Invoices</h3>
            <div style="display: flex; gap: 4px; background: rgba(0,0,0,0.03); padding: 4px; border-radius: var(--radius-sm);">
                <button class="btn" style="padding: 6px 12px; font-size: 12px; background: #ffffff; box-shadow: var(--shadow-soft);">All</button>
                <button class="btn btn-ghost" style="padding: 6px 12px; font-size: 12px; color: var(--text-secondary);">Paid</button>
                <button class="btn btn-ghost" style="padding: 6px 12px; font-size: 12px; color: var(--text-secondary);">Overdue</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Invoice ID</th>
                        <th>Guest / Property</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (invoices == null || invoices.Count == 0)
                    {
                        <!-- Fallback visual details matching Stitch Design exactly -->
                        <tr>
                            <td style="font-weight: 600;">INV-2023-142</td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--secondary-container); color: var(--secondary); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600;">EH</div>
                                    <div>
                                        <p style="margin: 0; font-weight: 600;">Elena Higgins</p>
                                        <span style="font-size: 11px; color: var(--text-secondary);">Chalet Zermatt Peak</span>
                                    </div>
                                </div>
                            </td>
                            <td>Oct 12, 2024</td>
                            <td style="font-weight: 600; color: var(--primary);">€24,500.00</td>
                            <td><span class="status-pill success">Paid</span></td>
                            <td style="text-align: right;"><span style="cursor: pointer; color: var(--text-secondary);">•••</span></td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">INV-2023-145</td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary-container); color: #ffffff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600;">MR</div>
                                    <div>
                                        <p style="margin: 0; font-weight: 600;">Marcus Rostova</p>
                                        <span style="font-size: 11px; color: var(--text-secondary);">Alpine Lodge Cortina</span>
                                    </div>
                                </div>
                            </td>
                            <td>Oct 15, 2024</td>
                            <td style="font-weight: 600; color: var(--primary);">€18,200.00</td>
                            <td><span class="status-pill danger">Overdue</span></td>
                            <td style="text-align: right;"><span style="cursor: pointer; color: var(--text-secondary);">•••</span></td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">INV-2023-148</td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--tertiary-container); color: var(--tertiary); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600;">SV</div>
                                    <div>
                                        <p style="margin: 0; font-weight: 600;">Sophia Varela</p>
                                        <span style="font-size: 11px; color: var(--text-secondary);">Chalet Mont Blanc</span>
                                    </div>
                                </div>
                            </td>
                            <td>Oct 18, 2024</td>
                            <td style="font-weight: 600; color: var(--primary);">€32,000.00</td>
                            <td><span class="status-pill warning">Draft</span></td>
                            <td style="text-align: right;"><span style="cursor: pointer; color: var(--text-secondary);">•••</span></td>
                        </tr>
                    }
                    else
                    {
                        foreach (var inv in invoices)
                        {
                            <tr>
                                <td style="font-weight: 600;">#INV-@inv.InvoiceNumber</td>
                                <td>Guest Onboard (#@inv.Id.ToString()[..5].ToUpper())</td>
                                <td>@inv.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td style="font-weight: 600; color: var(--primary);">@inv.TotalAmount.ToString("C")</td>
                                <td>
                                    @{
                                        var badge = "warning";
                                        if (inv.Status == "Paid") badge = "success";
                                        if (inv.Status == "Cancelled") badge = "danger";
                                    }
                                    <span class="status-pill @badge">@inv.Status</span>
                                </td>
                                <td style="text-align: right;"><span style="cursor: pointer; color: var(--text-secondary);">•••</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Payment Tracking Timeline -->
    <div class="glass-card" style="display: flex; flex-direction: column;">
        <h3 style="font-size: 18px; font-weight: 600; color: var(--primary); margin-bottom: 24px;">Recent Activity</h3>
        <div style="display: flex; flex-direction: column; gap: 24px; border-left: 2px solid var(--border-dark); padding-left: 20px; margin-left: 10px; flex-grow: 1;">
            <div style="position: relative;">
                <div style="position: absolute; left: -27px; top: 2px; width: 12px; height: 12px; border-radius: 50%; background: var(--secondary); border: 2px solid #ffffff;"></div>
                <span style="font-size: 11px; color: var(--text-secondary); display: block; margin-bottom: 4px;">Today, 10:42 AM</span>
                <p style="font-size: 14px; font-weight: 600; color: var(--primary); margin: 0;">Payment Received</p>
                <span style="font-size: 12px; color: var(--text-secondary);">€24,500 via Wire Transfer from Elena Higgins.</span>
            </div>

            <div style="position: relative;">
                <div style="position: absolute; left: -27px; top: 2px; width: 12px; height: 12px; border-radius: 50%; background: var(--text-disabled); border: 2px solid #ffffff;"></div>
                <span style="font-size: 11px; color: var(--text-secondary); display: block; margin-bottom: 4px;">Yesterday, 14:15 PM</span>
                <p style="font-size: 14px; font-weight: 600; color: var(--primary); margin: 0;">Invoice Generated</p>
                <span style="font-size: 12px; color: var(--text-secondary);">INV-2023-148 created for Chalet Mont Blanc.</span>
            </div>

            <div style="position: relative;">
                <div style="position: absolute; left: -27px; top: 2px; width: 12px; height: 12px; border-radius: 50%; background: var(--error); border: 2px solid #ffffff;"></div>
                <span style="font-size: 11px; color: var(--text-secondary); display: block; margin-bottom: 4px;">Oct 16, 09:00 AM</span>
                <p style="font-size: 14px; font-weight: 600; color: var(--primary); margin: 0;">Payment Overdue</p>
                <span style="font-size: 12px; color: var(--text-secondary);">Automated reminder sent to Marcus Rostova for INV-2023-145.</span>
            </div>
        </div>
        <button class="btn btn-ghost" style="padding: 0; font-size: 13px; text-decoration: underline; align-self: flex-start; margin-top: 20px;">View Full History</button>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Area Chart Gross Revenue
            const ctxRev = document.getElementById("revenueChart").getContext("2d");
            let grad = ctxRev.createLinearGradient(0, 0, 0, 200);
            grad.addColorStop(0, "rgba(0, 39, 65, 0.3)");
            grad.addColorStop(1, "rgba(0, 39, 65, 0)");

            new Chart(ctxRev, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Gross Revenue',
                        data: [1.2, 1.9, 1.5, 2.8, 3.2, 4.2],
                        borderColor: '#002741',
                        backgroundColor: grad,
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#002741',
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            ticks: { callback: function(value) { return '€' + value + 'M'; } }
                        }
                    }
                }
            });

            // Stacked Bar Chart Collection Status
            const ctxColl = document.getElementById("collectionChart").getContext("2d");
            new Chart(ctxColl, {
                type: 'bar',
                data: {
                    labels: ['Q1', 'Q2', 'Q3'],
                    datasets: [
                        {
                            label: 'Collected',
                            data: [85, 90, 75],
                            backgroundColor: '#006a66',
                            borderRadius: 4
                        },
                        {
                            label: 'Pending',
                            data: [15, 10, 25],
                            backgroundColor: '#e5e7eb',
                            borderRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom' } },
                    scales: {
                        y: { stacked: true, max: 100 },
                        x: { stacked: true }
                    }
                }
            });
        });
    </script>
}
