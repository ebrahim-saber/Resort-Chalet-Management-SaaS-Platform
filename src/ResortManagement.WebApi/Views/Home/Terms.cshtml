@{
    ViewData["Title"] = "Terms of Service - ChaletElite";
}

<!-- Ambient Background Image with Glass Overlay -->
<div class="fixed inset-0 z-[-1]" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAPGfFfqT3mYKMsvDo9zy1LR5mHCKWw-xEARPEpVuVmfOyiXaeqlqfha76jKPKofIMeeJP2Eyct0sp5UHmnC0g6QqRh5ZA4F-yZf8sbaDYI5YSIQEWr7mdZ0D9BIIWKEyH2pthmBAEWrH0pNw28lbHh0ns5mEuxHmxksskPQLYlMkUBZi8FuAJfX6rWid6pBlh4FJ8BhELp_re80LNoQbePpA2RhctmceyPniSMzFTx71EdQlB3i9KBPjWnEImD6ajNPg5Y131q7RGi'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-gradient-to-br from-surface-container-lowest/95 via-surface/90 to-surface-container-low/95 backdrop-blur-[6px]"></div>
</div>

<main class="flex-1 pt-32 pb-20 px-margin-mobile md:px-margin-tablet lg:px-margin-desktop w-full max-w-[800px] mx-auto relative">
    <div class="bg-white/75 backdrop-blur-xl border border-white rounded-2xl p-8 md:p-12 shadow-md hover:shadow-lg transition-all duration-300">
        <header class="mb-10 text-center">
            <span class="material-symbols-outlined text-[48px] text-primary bg-primary-container/20 p-4 rounded-full mb-4">gavel</span>
            <h1 class="text-display-md font-bold text-primary mb-2">Terms of Service</h1>
            <p class="text-body-md text-on-surface-variant">Last updated: June 2, 2026</p>
        </header>

        <article class="prose prose-slate max-w-none space-y-8 text-on-surface">
            <section class="space-y-3">
                <h2 class="text-headline-md font-bold text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-secondary">cloud</span>
                    1. SaaS License Grant
                </h2>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    ChaletElite grants you a non-exclusive, non-transferable, revocable license to access our multi-tenant luxury resort management platform. Usage is strictly governed by your active subscription plan capacity limits (Resorts, Units, and Staff accounts limits).
                </p>
            </section>

            <section class="space-y-3">
                <h2 class="text-headline-md font-bold text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-secondary">groups</span>
                    2. Acceptable Use Policy
                </h2>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    Users must maintain secure credentials. Sharing administrative accounts outside authorized organizational units is prohibited. You are responsible for ensuring that all guest data uploaded to the customer relations module conforms to local regulations.
                </p>
            </section>

            <section class="space-y-3">
                <h2 class="text-headline-md font-bold text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-secondary">payments</span>
                    3. Subscriptions & Billing
                </h2>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    Subscription fees are billed recurringly according to your selected plan. Failure to process monthly dues will restrict administrative access to portfolio configurations, while guest-facing storefront checkouts will be suspended until payment is verified.
                </p>
            </section>

            <section class="space-y-3">
                <h2 class="text-headline-md font-bold text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-secondary">breaking_news_alt</span>
                    4. Platform Modifications
                </h2>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    We continuously improve the platform. We reserve the right to deploy hotfixes, database migrations, and visual layouts to enhance security, page load times, and transaction flow without prior notice.
                </p>
            </section>
        </article>

        <div class="mt-12 pt-8 border-t border-outline-variant/30 flex justify-center">
            <button onclick="window.history.back();" class="text-label-md text-on-primary bg-primary px-8 py-3 rounded-full hover:bg-primary/95 transition-all font-semibold shadow-sm hover:shadow">
                Return to Previous Page
            </button>
        </div>
    </div>
</main>
