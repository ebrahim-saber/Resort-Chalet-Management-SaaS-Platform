<style>
    .tab-content.hidden {
        display: none !important;
    }
    .tab-content.active {
        display: block !important;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const navButtons = document.querySelectorAll('.nav-btn');
        const tabContents = document.querySelectorAll('.tab-content');

        navButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                // Reset all tabs
                navButtons.forEach(b => {
                    b.classList.remove('bg-secondary-container', 'text-on-secondary-container');
                    b.classList.add('text-on-surface-variant', 'hover:bg-surface-container-high');
                });
                tabContents.forEach(c => {
                    c.classList.add('hidden');
                    c.classList.remove('active');
                });

                // Set active tab
                btn.classList.add('bg-secondary-container', 'text-on-secondary-container');
                btn.classList.remove('text-on-surface-variant', 'hover:bg-surface-container-high');
                
                const targetId = btn.getAttribute('data-target');
                const targetTab = document.getElementById(targetId);
                if (targetTab) {
                    targetTab.classList.remove('hidden');
                    targetTab.classList.add('active');
                }
            });
        });

        // Check if there is an active tab target in URL hashes
        const hash = window.location.hash.substring(1);
        if (hash) {
            const targetBtn = document.querySelector(`.nav-btn[data-target="${hash}"]`);
            if (targetBtn) targetBtn.click();
        }

        // Auto slide-out toast message if present
        const toast = document.querySelector('#profile-toast-container > div');
        if (toast) {
            setTimeout(() => {
                toast.classList.remove('translate-x-full');
                toast.classList.add('translate-x-0');
            }, 10);
            setTimeout(() => {
                toast.classList.remove('translate-x-0');
                toast.classList.add('translate-x-full');
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }
    });

    // Team search and filter
    function filterTeam() {
        const query = document.getElementById('team-search').value.toLowerCase().trim();
        const dept = document.getElementById('dept-filter').value;
        const rows = document.querySelectorAll('.team-row');

        rows.forEach(row => {
            const name = row.getAttribute('data-name').toLowerCase();
            const email = row.getAttribute('data-email').toLowerCase();
            const rDept = row.getAttribute('data-dept');

            const matchesQuery = name.includes(query) || email.includes(query);
            const matchesDept = !dept || rDept === dept;

            if (matchesQuery && matchesDept) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    // Modal Control
    function openTeamModal() {
        const modal = document.getElementById('team-modal');
        modal.classList.remove('hidden');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            modal.querySelector('div').classList.remove('scale-95');
        }, 10);
    }

    function closeTeamModal() {
        const modal = document.getElementById('team-modal');
        modal.classList.add('opacity-0');
        modal.querySelector('div').classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    }

    // Client side password matching check
    function validatePasswordChange() {
        const newPass = document.getElementById('newPassword').value;
        const confPass = document.getElementById('confirmPassword').value;
        const errorText = document.getElementById('password-match-error');

        if (newPass !== confPass) {
            errorText.classList.remove('hidden');
            return false;
        }
        errorText.classList.add('hidden');
        return true;
    }

    function showProfileToast(title, message, type = 'success') {
        const container = document.getElementById('profile-toast-container');
        if (!container) return;

        const borderCol = type === 'success' ? 'border-l-secondary' : type === 'error' ? 'border-l-error' : 'border-l-primary';
        const icon = type === 'success' ? 'check_circle' : type === 'error' ? 'error' : 'info';
        const iconCol = type === 'success' ? 'text-secondary' : type === 'error' ? 'text-error' : 'text-primary';

        const toast = document.createElement('div');
        toast.className = `bg-white/95 backdrop-blur-xl border border-white shadow-xl rounded-2xl p-4 w-80 flex items-start gap-3 pointer-events-auto border-l-4 ${borderCol} opacity-0 translate-x-8 transition-all duration-300`;
        toast.innerHTML = `
            <span class="material-symbols-outlined ${iconCol}">${icon}</span>
            <div class="flex-grow">
                <h5 class="font-bold text-primary text-label-md mb-0.5">${title}</h5>
                <p class="text-[12px] text-on-surface-variant">${message}</p>
            </div>
            <button class="text-outline hover:text-primary" onclick="this.parentElement.remove()"><span class="material-symbols-outlined text-[16px]">close</span></button>
        `;
        container.appendChild(toast);
        
        // Trigger reflow & slide-in
        setTimeout(() => {
            toast.classList.remove('opacity-0', 'translate-x-8');
        }, 10);

        // Auto remove after 4 seconds
        setTimeout(() => {
            toast.classList.add('opacity-0', 'translate-x-8');
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    }
</script>
