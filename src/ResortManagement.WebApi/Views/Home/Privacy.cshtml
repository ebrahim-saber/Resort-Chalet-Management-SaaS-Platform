@{
    ViewData["Title"] = "Privacy Policy - ChaletElite";
}

<!-- Ambient Background Image with Glass Overlay -->
<div class="fixed inset-0 z-[-1]" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAPGfFfqT3mYKMsvDo9zy1LR5mHCKWw-xEARPEpVuVmfOyiXaeqlqfha76jKPKofIMeeJP2Eyct0sp5UHmnC0g6QqRh5ZA4F-yZf8sbaDYI5YSIQEWr7mdZ0D9BIIWKEyH2pthmBAEWrH0pNw28lbHh0ns5mEuxHmxksskPQLYlMkUBZi8FuAJfX6rWid6pBlh4FJ8BhELp_re80LNoQbePpA2RhctmceyPniSMzFTx71EdQlB3i9KBPjWnEImD6ajNPg5Y131q7RGi'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-gradient-to-br from-surface-container-lowest/95 via-surface/90 to-surface-container-low/95 backdrop-blur-[6px]"></div>
</div>

<main class="flex-1 pt-32 pb-20 px-margin-mobile md:px-margin-tablet lg:px-margin-desktop w-full max-w-[800px] mx-auto relative">
    <div class="bg-white/75 backdrop-blur-xl border border-white rounded-2xl p-8 md:p-12 shadow-md hover:shadow-lg transition-all duration-300">
        <header class="mb-10 text-center">
            <span class="material-symbols-outlined text-[48px] text-primary bg-primary-container/20 p-4 rounded-full mb-4">security</span>
            <h1 class="text-display-md font-bold text-primary mb-2">Privacy Policy</h1>
            <p class="text-body-md text-on-surface-variant">Last updated: June 2, 2026</p>
        </header>

        <article class="prose prose-slate max-w-none space-y-8 text-on-surface">
            <section class="space-y-3">
                <h2 class="text-headline-md font-bold text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-secondary">info</span>
                    1. Information We Collect
                </h2>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    We collect information to deliver a premium hospitality management experience. This includes guest contact details, billing history, payment preferences, operational housekeeping schedules, and employee logs. All operational data is strictly isolated within your designated database schema.
                </p>
            </section>

            <section class="space-y-3">
                <h2 class="text-headline-md font-bold text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-secondary">shield</span>
                    2. Data Security & Isolation
                </h2>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    ChaletElite employs advanced database isolation strategies. Operational database records implement strict global query filters ensuring zero cross-tenant data leakage. Secure cryptographic hashes are utilized for password verification, and all communications are encrypted over Transport Layer Security (TLS).
                </p>
            </section>

            <section class="space-y-3">
                <h2 class="text-headline-md font-bold text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-secondary">cookie</span>
                    3. Cookies & Session Management
                </h2>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    Our platform uses strictly necessary HTTPOnly secure cookies to manage employee login sessions, authenticate API requests, and retain layout preferences. No trackers or third-party advertising cookies are initialized inside the management dashboard.
                </p>
            </section>

            <section class="space-y-3">
                <h2 class="text-headline-md font-bold text-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-[24px] text-secondary">contact_support</span>
                    4. Contact Our Privacy Officer
                </h2>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    If you have questions regarding database encryption, GDPR compliance, or data retention policies within the ChaletElite SaaS framework, please reach out to our Concierge Support team.
                </p>
            </section>
        </article>

        <div class="mt-12 pt-8 border-t border-outline-variant/30 flex justify-center">
            <button onclick="window.history.back();" class="text-label-md text-on-primary bg-primary px-8 py-3 rounded-full hover:bg-primary/95 transition-all font-semibold shadow-sm hover:shadow">
                Return to Previous Page
            </button>
        </div>
    </div>
</main>
