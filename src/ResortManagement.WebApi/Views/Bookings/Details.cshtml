@{
    ViewData["Title"] = "Reservation Details";
}

<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 4px 20px 0 rgba(0, 39, 65, 0.05);
    }
</style>

<!-- Header context bar -->
<div class="w-full flex flex-col sm:flex-row items-start sm:items-center justify-between px-8 py-6 bg-surface-container-lowest border-b border-outline-variant/30 sticky top-16 z-30">
    <div class="flex items-center gap-4">
        <button onclick="window.location.href='/bookings'" class="p-2 rounded-full hover:bg-surface-container-high transition-colors text-primary flex items-center justify-center">
            <span class="material-symbols-outlined">arrow_back</span>
        </button>
        <div>
            <h1 class="text-headline-md font-headline-md text-primary">Reservation Details</h1>
            <p class="text-label-sm font-label-sm text-on-surface-variant mt-1">ID: @ViewBag.Reservation.Id</p>
        </div>
    </div>
    <div class="flex items-center gap-4 mt-4 sm:mt-0">
        <span class="px-4 py-2 rounded-full bg-secondary/10 text-secondary text-label-md font-bold uppercase">
            @ViewBag.Reservation.Status
        </span>
        <button onclick="window.print()" class="px-6 py-2 rounded-full bg-primary text-on-primary font-label-md hover:bg-primary/90 transition-colors shadow-lg">
            Print Details
        </button>
    </div>
</div>

<main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-tablet lg:px-margin-desktop py-12 grid grid-cols-1 lg:grid-cols-12 gap-gutter">
    <!-- Left Column: Guest & Stay Details -->
    <div class="lg:col-span-8 flex flex-col gap-gutter">
        <!-- Guest Profile Header -->
        <section class="glass-panel rounded-xl p-8 flex flex-col md:flex-row items-start md:items-center gap-6 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-secondary/10 rounded-bl-full blur-2xl pointer-events-none"></div>
            <img alt="Guest Profile" class="w-24 h-24 rounded-full object-cover border-4 border-white shadow-md" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBBUzTgd0K-HnvFRx86rZeg717REbva5yArZ5ppko7kiwtvCzRMwYKEljxw1ofvrW7A96-K-Yo0FvslfmnEM6SloUSVlfQlbRptNOpvDPUDtU5W3NzH8gys2Jvi8kxkwPX7d52yIJNBudksEKXJi7HRfr-WgyLqvsvcS5ifInSNEqCEcEPzsSXkpzVXZAvfFRBi33MIQP7f2L0mJfhw0KO2pkKKT_33A4yQejg6DddoBa-ixXMtS5KTQa3gkfFGukI34Dgp1PqgzVu0"/>
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                    <h2 class="text-headline-md font-headline-md text-primary">@ViewBag.Reservation.Customer.FullName</h2>
                    <span class="px-3 py-1 bg-tertiary-container/20 text-tertiary rounded-full text-label-sm font-label-sm flex items-center gap-1">
                        <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">star</span> VIP Tier
                    </span>
                </div>
                <div class="flex flex-wrap gap-4 text-body-md text-on-surface-variant font-medium">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-outline">mail</span>
                        @ViewBag.Reservation.Customer.Email
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-outline">phone</span>
                        @ViewBag.Reservation.Customer.Phone
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-outline">flag</span>
                        @ViewBag.Reservation.Customer.Nationality
                    </div>
                </div>
            </div>
        </section>

        <!-- Stay Information Bento -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
            <!-- Dates & Unit -->
            <div class="glass-panel rounded-xl p-8 flex flex-col justify-between">
                <div>
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-label-md font-label-md text-primary uppercase tracking-wider">Stay Details</h3>
                        <span class="px-3 py-1 bg-secondary/10 text-secondary rounded-full text-label-sm font-label-sm">Active Room Allocation</span>
                    </div>
                    <div class="grid grid-cols-2 gap-6 mb-6">
                        <div>
                            <p class="text-label-sm font-label-sm text-outline mb-1">Check-in</p>
                            <p class="text-body-lg font-body-lg text-on-surface font-semibold">@ViewBag.Reservation.CheckInDate.ToString("MMM dd, yyyy")</p>
                            <p class="text-body-md text-on-surface-variant">15:00</p>
                        </div>
                        <div>
                            <p class="text-label-sm font-label-sm text-outline mb-1">Check-out</p>
                            <p class="text-body-lg font-body-lg text-on-surface font-semibold">@ViewBag.Reservation.CheckOutDate.ToString("MMM dd, yyyy")</p>
                            <p class="text-body-md text-on-surface-variant">11:00</p>
                        </div>
                    </div>
                </div>
                <div class="pt-6 border-t border-outline-variant/30 flex items-center gap-4">
                    <div class="w-16 h-16 rounded-lg bg-surface-container-high overflow-hidden">
                        <img alt="Chalet Image" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAUV7mDyMnXYdAF1IXBzxmaQanRYrzesHBvI2byECLZYAhNPdsmQPBH5LD0iSTjdOQzSEcO7YTZwmu16LxpXZ3UAmmACzg2WQH1dCAZDfJicWR-52o8hcUDlQUMth6WGo9S3VfCiiCBAOuSuKedBJpsHL-VBZ4RghOas2cXq7fU9lHclnbaq8smdRfbv6lSSw-qN1mQ6djqlw4bq8i17YiRsYb6h8iuldAI_k0HwmFikoYyVPqKwFpEYwlw02SO8-Png11It0-P14Ls"/>
                    </div>
                    <div>
                        <p class="text-body-lg font-body-lg text-primary font-semibold">@ViewBag.Reservation.Unit.UnitNumber</p>
                        <p class="text-body-md text-on-surface-variant">@ViewBag.Reservation.Unit.UnitType.Name</p>
                    </div>
                </div>
            </div>

            <!-- Special Requests -->
            <div class="glass-panel rounded-xl p-8 bg-gradient-to-br from-surface-container-lowest to-surface-container-low flex flex-col justify-between">
                <div>
                    <h3 class="text-label-md font-label-md text-primary uppercase tracking-wider mb-6">Concierge Details</h3>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-secondary mt-1">celebration</span>
                            <div>
                                <p class="text-body-md font-body-md text-on-surface font-semibold">Anniversary Stay</p>
                                <p class="text-label-sm font-label-sm text-on-surface-variant">Client requested complimentary champagne on arrival.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-error mt-1">warning</span>
                            <div>
                                <p class="text-body-md font-body-md text-error font-semibold">Severe Dietary Restriction</p>
                                <p class="text-label-sm font-label-sm text-on-surface-variant">Peanut allergy safety flag dispatched to kitchen team.</p>
                            </div>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-outline mt-1">airport_shuttle</span>
                            <div>
                                <p class="text-body-md font-body-md text-on-surface font-semibold">SUV Airport Transfer</p>
                                <p class="text-label-sm font-label-sm text-on-surface-variant">Private shuttle GVA booked at check-in timeline.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </section>
    </div>

    <!-- Right Column: Timeline & Payment -->
    <div class="lg:col-span-4 flex flex-col gap-gutter">
        <!-- Payment Summary -->
        <section class="glass-panel rounded-xl p-6 flex flex-col justify-between">
            <div>
                <h3 class="text-label-md font-label-md text-primary uppercase tracking-wider mb-6">Payment Ledger</h3>
                <div class="space-y-3 mb-6">
                    <div class="flex justify-between text-body-md">
                        <span class="text-on-surface-variant font-medium">Lodging Stay Value</span>
                        <span class="text-on-surface font-semibold">$@String.Format("{0:N2}", ViewBag.Reservation.TotalPrice)</span>
                    </div>
                    <div class="flex justify-between text-body-md">
                        <span class="text-on-surface-variant font-medium">Resort Taxes (10%)</span>
                        <span class="text-on-surface font-semibold">$@String.Format("{0:N2}", ViewBag.Reservation.TotalPrice * 0.1m)</span>
                    </div>
                    <div class="pt-3 border-t border-outline-variant/30 flex justify-between items-center">
                        <span class="text-body-lg font-bold text-primary">Gross Cost</span>
                        <span class="text-headline-md font-headline-md text-primary font-bold">$@String.Format("{0:N2}", ViewBag.Reservation.TotalPrice * 1.1m)</span>
                    </div>
                </div>
            </div>
            <button onclick="window.location.href='/billing'" class="w-full py-3 rounded-lg border border-primary text-primary font-label-md hover:bg-primary/5 transition-colors flex items-center justify-center gap-2 font-semibold">
                <span class="material-symbols-outlined">receipt_long</span>
                Open Billing Ledger
            </button>
        </section>

        <!-- Document Management -->
        <section class="glass-panel rounded-xl p-6">
            <h3 class="text-label-md font-label-md text-primary uppercase tracking-wider mb-6">Documents Registry</h3>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-3 rounded-lg hover:bg-surface-container-high transition-colors cursor-pointer border border-transparent hover:border-outline-variant/30">
                    <div class="flex items-center gap-3">
                        <div class="p-2 bg-primary/10 rounded text-primary">
                            <span class="material-symbols-outlined">badge</span>
                        </div>
                        <div>
                            <p class="text-body-md font-body-md text-on-surface font-semibold">Passport_EVance.pdf</p>
                            <p class="text-label-sm text-outline">Identity Proof verified</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-outline">download</span>
                </div>
                <div class="flex items-center justify-between p-3 rounded-lg hover:bg-surface-container-high transition-colors cursor-pointer border border-transparent hover:border-outline-variant/30">
                    <div class="flex items-center gap-3">
                        <div class="p-2 bg-secondary/10 rounded text-secondary">
                            <span class="material-symbols-outlined">contract</span>
                        </div>
                        <div>
                            <p class="text-body-md font-body-md text-on-surface font-semibold">Rental_Agreement.pdf</p>
                            <p class="text-label-sm text-secondary font-semibold">Signed via Social Consent</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-outline">download</span>
                </div>
            </div>
        </section>
    </div>
</main>
