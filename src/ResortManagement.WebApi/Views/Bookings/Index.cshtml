@using ResortManagement.Domain.Entities.Resorts
@using ResortManagement.Domain.Entities.Reservations
@using ResortManagement.Domain.Entities.CRM
@{
    ViewData["Title"] = "Reservations & Booking Timeline";
    
    var showcaseUnitTypes = (ViewBag.ShowcaseUnitTypes as System.Collections.IEnumerable)?.Cast<dynamic>().ToList() ?? new List<dynamic>();
    var dbUnits = ViewBag.Units as List<ResortManagement.Domain.Entities.Resorts.Unit> ?? new List<ResortManagement.Domain.Entities.Resorts.Unit>();
    var dbReservations = ViewBag.Reservations as List<ResortManagement.Domain.Entities.Reservations.Reservation> ?? new List<ResortManagement.Domain.Entities.Reservations.Reservation>();
    var dbCustomers = ViewBag.Customers as List<ResortManagement.Domain.Entities.CRM.Customer> ?? new List<ResortManagement.Domain.Entities.CRM.Customer>();

    // Calculate dynamic dates starting from today
    var timelineStart = DateTime.Today;
    var timelineDates = Enumerable.Range(0, 7).Select(i => timelineStart.AddDays(i)).ToList();
}

@functions {
    public string GetUnitTypeName(Guid unitTypeId)
    {
        var rawList = ViewBag.ShowcaseUnitTypes;
        if (rawList != null)
        {
            foreach (var item in rawList)
            {
                try
                {
                    if (item.Id == unitTypeId)
                    {
                        return item.Name;
                    }
                }
                catch {}
            }
        }
        return "Luxury Chalet";
    }

    public string GetImageUrl(dynamic item)
    {
        try
        {
            return item.ImageUrl;
        }
        catch
        {
            string name = "";
            try { name = item.Name; } catch {}
            if (name.Contains("Villa"))
                return "https://lh3.googleusercontent.com/aida-public/AB6AXuBXrKcc-gJv5rtJ9oHbwF035pJRS9fNVqz21qWE4zQGRKZhN67sVfeKDzLdASveZTQw7sFobtHggGJp3IGTh3x4GqRbIHUyCgwznaaNs2h7icD8EAOh-SiUm5l607TfKJip94rwBGbqvcO47uhzVgb_ot3KyMueLMG7re-8zZWjy5SNTYY-dSwYJMg0jU77u_VYXb6oHN0oo67fPTf3rUArmdo79nI2bin5lCucu1-jbpg4DKWJCH6xbHvmlo7IqD0o_7WEFcsE7FI9";
            if (name.Contains("Suite"))
                return "https://lh3.googleusercontent.com/aida-public/AB6AXuCAT0d5yECFJhAWXKmNsyG4QgtMJs0b9nHs5yGcrI9zhk5b-9FqJeDcSWwaC0i2qItirczsm11dO3UsMLMoeZWjw9xN6Z768RH6ok1_fPRrmVFgmHY6N0w_RiZ-Zzn27spspseJiJA0qImIzYnjuvogrS4WNknweyWLtlu2JJFxaNnsdf_FWLlhfD89DzgrJd7YPBrbHzI01WxnwkUTgkNGyVKXSgHesfM4E7CWf1MTq4X8GPor02imvHtA0AbJ8jYz1OMnsaTH3YX3";
            return "https://lh3.googleusercontent.com/aida-public/AB6AXuCO67FORUlLm2FiZkGc7NEB-Vx9G1SjTBACxgQyPHit58-XKsV4127b5tpYEcSL6wjf4QKh0W3foY52Wg4FR7oy8AqUQHtlmy3vUChXUeFx1xoZVmGYLj8ydTvnZEjE4wUlUjPMDznafAQCgNE1ZpPn-t42_M4lfUeBtA8s7_-aFsiodRGhneqLWpxfEC0x_hFRbySssIzgfz5o3iKp29ga72eXq-bMWj6jlK44KkWn5zk2v54l1mcfTSMM9FmZFf4z23c8x5-uXDQJ";
        }
    }

    public string GetAmenities(dynamic item)
    {
        try
        {
            return item.Amenities;
        }
        catch
        {
            string name = "";
            try { name = item.Name; } catch {}
            if (name.Contains("Villa"))
                return "Beach Access, Kitchenette, Spacious Terrace, Private Pool";
            if (name.Contains("Suite"))
                return "King Bed, Frosted Jacuzzi, High-speed Wifi, Minibar";
            return "Private Infinity Pool, Sea View, Butler Service, Concierge Assist";
        }
    }
}

<main class="pt-32 pb-24 px-margin-mobile md:px-margin-tablet lg:px-margin-desktop max-w-container-max mx-auto w-full relative z-10">
    <!-- Toast Notification Hub -->
    <div id="bookings-toast-container" class="fixed top-24 right-6 z-[999] flex flex-col gap-3 pointer-events-none">
        @if (TempData["Success"] != null)
        {
            <div class="bg-white/95 backdrop-blur-xl border border-white shadow-xl rounded-2xl p-4 w-80 flex items-start gap-3 pointer-events-auto border-l-4 border-l-secondary translate-x-0 transition-transform duration-300">
                <span class="material-symbols-outlined text-secondary">check_circle</span>
                <div class="flex-grow">
                    <h5 class="font-bold text-primary text-label-md mb-0.5">Success</h5>
                    <p class="text-[12px] text-on-surface-variant">@TempData["Success"]</p>
                </div>
                <button class="text-outline hover:text-primary" onclick="this.parentElement.remove()"><span class="material-symbols-outlined text-[16px]">close</span></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="bg-white/95 backdrop-blur-xl border border-white shadow-xl rounded-2xl p-4 w-80 flex items-start gap-3 pointer-events-auto border-l-4 border-l-error translate-x-0 transition-transform duration-300">
                <span class="material-symbols-outlined text-error">error</span>
                <div class="flex-grow">
                    <h5 class="font-bold text-primary text-label-md mb-0.5">Error</h5>
                    <p class="text-[12px] text-on-surface-variant">@TempData["Error"]</p>
                </div>
                <button class="text-outline hover:text-primary" onclick="this.parentElement.remove()"><span class="material-symbols-outlined text-[16px]">close</span></button>
            </div>
        }
    </div>

    <!-- Header Section -->
    <header class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <h1 class="text-display-lg-mobile md:text-display-lg font-bold text-primary mb-2 font-headline-lg">Reservation Timeline</h1>
            <p class="text-body-lg text-on-surface-variant">Manage guest stays, operations telemetry, and check-in workflows in real-time.</p>
        </div>
        
        <!-- Google Calendar Integration Toggle -->
        <div class="flex gap-3">
            <button onclick="openGoogleSyncModal()" class="text-secondary border border-secondary px-5 py-2.5 rounded-full text-label-sm font-semibold hover:bg-secondary/5 transition-all flex items-center gap-2 shadow-sm">
                <span class="material-symbols-outlined text-[18px]">sync</span>
                Google Calendar Sync
            </button>
        </div>
    </header>
    
    <!-- Gantt Chart Container -->
    <section class="glass-panel rounded-2xl shadow-sm overflow-hidden flex flex-col mb-12 border border-white/60">
        <!-- Timeline Header (Dates) -->
        <div class="flex border-b border-outline-variant/20 bg-white/40 backdrop-blur-md">
            <!-- Resource Column Header -->
            <div class="w-64 min-w-[256px] flex-shrink-0 p-6 border-r border-outline-variant/20 flex items-center justify-between">
                <span class="text-label-md text-primary uppercase tracking-wider font-bold">Property Chalets</span>
                <span class="material-symbols-outlined text-[18px] text-outline">hotel</span>
            </div>
            
            <!-- Dates Row -->
            <div class="flex-grow flex overflow-x-auto hide-scrollbar">
                @for (int i = 0; i < 7; i++)
                {
                    var date = timelineDates[i];
                    var isToday = date == DateTime.Today;
                    var highlightClass = isToday ? "bg-secondary/5 font-bold text-secondary relative" : "text-primary";
                    <div class="min-w-[120px] flex-1 p-4 border-r border-outline-variant/20 text-center flex flex-col items-center justify-center @highlightClass">
                        @if (isToday)
                        {
                            <div class="absolute top-0 left-0 w-full h-1 bg-secondary"></div>
                        }
                        <span class="text-xs uppercase tracking-wider mb-1 @(isToday ? "text-secondary font-bold" : "text-outline")">@date.ToString("ddd")</span>
                        <span class="text-headline-sm font-bold text-xl">@date.Day</span>
                        @if (isToday)
                        {
                            <span class="absolute bottom-1.5 text-[8px] bg-secondary text-white font-bold px-1.5 py-0.5 rounded-full uppercase tracking-wider">Today</span>
                        }
                    </div>
                }
            </div>
        </div>
        
        <!-- Timeline Body (Rows) -->
        <div class="flex flex-col">
            @if (dbUnits.Count == 0)
            {
                <div class="p-12 text-center text-on-surface-variant/70 bg-white/30">
                    <span class="material-symbols-outlined text-[48px] text-outline/30 mb-2">hotel_class</span>
                    <p class="font-semibold text-sm">No property units registered under this resort portfolio</p>
                    <a href="/resorts/units" class="mt-2 text-secondary hover:text-primary font-bold text-xs inline-block">Register units in Properties page</a>
                </div>
            }
            else
            {
                foreach (var unit in dbUnits)
                {
                    var unitReservations = dbReservations
                        .Where(r => r.UnitId == unit.Id && r.Status != "Cancelled")
                        .ToList();
                    
                    <div class="flex border-b border-outline-variant/10 bg-white/10 hover:bg-white/50 transition-colors group relative">
                        <!-- Resource Info -->
                        <div class="w-64 min-w-[256px] flex-shrink-0 p-6 border-r border-outline-variant/20 flex items-center gap-4 bg-white/40 backdrop-blur-md z-10">
                            <div class="w-11 h-11 rounded-xl bg-primary-container text-on-primary-container overflow-hidden border border-outline-variant/20 flex-shrink-0 flex items-center justify-center">
                                <span class="material-symbols-outlined text-[20px] text-secondary">cottage</span>
                            </div>
                            <div class="min-w-0">
                                <h3 class="text-label-md text-primary mb-0.5 font-bold truncate">@unit.UnitNumber</h3>
                                <p class="text-[11px] text-on-surface-variant font-medium truncate">@GetUnitTypeName(unit.UnitTypeId)</p>
                            </div>
                        </div>
                        
                        <!-- Timeline Grid Row -->
                        <div class="flex-grow relative overflow-hidden min-w-[840px] h-24 bg-white/5">
                            <!-- Grid Lines -->
                            <div class="absolute inset-0 flex pointer-events-none">
                                @for (int i = 0; i < 7; i++)
                                {
                                    var date = timelineDates[i];
                                    var highlightCol = date == DateTime.Today ? "bg-secondary/5" : "";
                                    <div class="flex-1 border-r border-outline-variant/10 @highlightCol"></div>
                                }
                            </div>
                            
                            <!-- Reservation Bars -->
                            @foreach (var res in unitReservations)
                            {
                                var customer = dbCustomers.FirstOrDefault(c => c.Id == res.CustomerId);
                                var custName = customer != null ? $"{customer.FirstName} {customer.LastName}" : "Luxury Guest";
                                var custEmail = customer?.Email ?? "guest@luxury.com";
                                var custPhone = customer?.Phone ?? "Concierge Direct";
                                var custNat = customer?.Nationality ?? "International";

                                // Bounds check for weekly timeline window
                                var checkIn = res.CheckInDate.Date;
                                var checkOut = res.CheckOutDate.Date;
                                var timelineEnd = timelineStart.AddDays(7);

                                if (checkOut <= timelineStart || checkIn >= timelineEnd)
                                {
                                    continue; // Out of bounds of this week
                                }

                                var visibleStart = checkIn < timelineStart ? timelineStart : checkIn;
                                var visibleEnd = checkOut > timelineEnd ? timelineEnd : checkOut;

                                double offsetDays = (visibleStart - timelineStart).TotalDays;
                                double durationDays = (visibleEnd - visibleStart).TotalDays;

                                if (durationDays <= 0) durationDays = 0.5; // Minimum visible width

                                double leftPct = (offsetDays / 7.0) * 100.0;
                                double widthPct = (durationDays / 7.0) * 100.0;

                                // Style based on status
                                string barClass = "bg-white border-outline-variant/30 text-primary border-l-4 border-l-secondary shadow-md";
                                string statusLabel = "Confirmed";
                                if (res.Status == "CheckedIn")
                                {
                                    barClass = "bg-primary text-on-primary border-l-4 border-l-secondary-dim shadow-md";
                                    statusLabel = "Checked-in";
                                }
                                else if (res.Status == "CheckedOut")
                                {
                                    barClass = "bg-surface-container-high text-on-surface border-l-4 border-l-outline shadow-sm opacity-70";
                                    statusLabel = "Checked-out";
                                }
                                else if (res.Status == "Pending")
                                {
                                    barClass = "bg-white border-dashed border-outline-variant text-primary border-l-4 border-l-tertiary-fixed shadow-sm";
                                    statusLabel = "Pending";
                                }

                                <div onclick="openReservationModal({
                                    id: '@res.Id',
                                    customer: '@custName',
                                    email: '@custEmail',
                                    phone: '@custPhone',
                                    nationality: '@custNat',
                                    unit: '@unit.UnitNumber',
                                    checkIn: '@res.CheckInDate.ToString("yyyy-MM-dd")',
                                    checkOut: '@res.CheckOutDate.ToString("yyyy-MM-dd")',
                                    price: '@res.TotalPrice.ToString("N2")',
                                    status: '@res.Status'
                                })" style="left: @(leftPct)%; width: @(widthPct)%;" class="absolute top-4 bottom-4 px-1 z-20 cursor-pointer hover:-translate-y-0.5 transition-transform">
                                    <div class="h-full rounded-xl p-3 flex flex-col justify-center overflow-hidden border relative @barClass">
                                        <p class="text-xs font-bold truncate leading-tight">@custName</p>
                                        <p class="text-[9px] uppercase tracking-wider mt-0.5 font-bold truncate opacity-90">@statusLabel • €@res.TotalPrice.ToString("N0")</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
        
        <!-- Legend Footer -->
        <div class="bg-white p-5 border-t border-outline-variant/20 flex justify-between items-center text-xs font-bold text-primary">
            <div class="flex gap-6">
                <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-primary block"></span> Checked-in</div>
                <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-secondary block"></span> Confirmed</div>
                <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-surface-container-high border border-outline-variant block"></span> Checked-out</div>
                <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-white border border-dashed border-outline block"></span> Pending</div>
            </div>
            <div class="text-on-surface-variant flex items-center gap-1.5 font-semibold">
                <span class="material-symbols-outlined text-[16px] text-secondary">info</span>
                Click any reservation bar to manage check-in workflows
            </div>
        </div>
    </section>
    
    <!-- Available Unit Showcase & Calculator Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter mt-12 items-start">
        <!-- Showcase Property Units List -->
        <div class="lg:col-span-2 flex flex-col gap-6">
            <h2 class="text-headline-md font-bold text-primary flex items-center gap-2 font-headline-sm">
                <span class="material-symbols-outlined text-secondary">stars</span>
                Available Unit Showcase
            </h2>
            
            <div class="flex flex-col gap-4">
                @if (showcaseUnitTypes.Count > 0)
                {
                    foreach (var item in showcaseUnitTypes)
                    {
                        <div class="bg-white rounded-2xl overflow-hidden border border-outline-variant/20 shadow-[0_2px_12px_0_rgba(0,39,65,0.02)] flex flex-col md:flex-row min-h-[160px] group hover:shadow-md transition-all">
                            <div class="w-full md:w-48 relative overflow-hidden shrink-0 min-h-[140px]">
                                <img src="@GetImageUrl(item)" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="@item.Name" />
                                <span class="absolute bottom-3 left-3 bg-primary/80 backdrop-blur-md text-white text-[9px] font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wider">Luxury Tier</span>
                            </div>
                            <div class="p-6 flex-1 flex flex-col justify-between">
                                <div>
                                    <div class="flex justify-between items-start mb-2">
                                        <h3 class="text-body-lg font-bold text-primary group-hover:text-secondary transition-colors">@item.Name</h3>
                                        <span class="text-label-md font-bold text-secondary bg-secondary/5 px-2.5 py-0.5 rounded-full">€@item.BasePrice.ToString("N2") / Night</span>
                                    </div>
                                    <p class="text-xs text-on-surface-variant mb-1 font-semibold flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[14px]">group</span> Max Occupancy: @item.MaxOccupancy Guests
                                    </p>
                                    <p class="text-xs text-on-surface-variant/80 font-medium">Amenities: @GetAmenities(item)</p>
                                </div>
                                <button class="mt-4 bg-surface-container hover:bg-secondary hover:text-white text-primary rounded-xl py-2 px-4 text-xs font-bold transition-all self-start flex items-center gap-1.5" onclick="selectUnitForCalculator('@item.Name', @item.BasePrice);">
                                    <span class="material-symbols-outlined text-[14px]">price_check</span>
                                    Select for Calculator
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
        
        <!-- Interactive Pricing Calculator -->
        <div class="lg:col-span-1">
            <form action="/bookings/create" method="POST" class="glass-panel border border-white/60 rounded-2xl p-6 shadow-sm sticky top-28 flex flex-col gap-4">
                <h2 class="text-headline-md font-bold text-primary font-headline-sm flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-secondary">calculate</span>
                    Rate Estimator
                </h2>
                
                <div>
                    <label class="block text-xs font-bold text-primary mb-1.5 uppercase tracking-wider">Selected Unit Template</label>
                    <input name="unitTypeName" class="w-full bg-surface-container-low/70 border border-outline-variant/40 rounded-xl px-4 py-2.5 text-xs font-bold text-primary outline-none cursor-not-allowed" type="text" id="calc-selected-unit-name" value="Royal Pool Chalet" readonly />
                </div>
                
                <div>
                    <label class="block text-xs font-bold text-primary mb-1.5 uppercase tracking-wider">Base Rate (€/Night)</label>
                    <input class="w-full bg-white border border-outline-variant/40 rounded-xl px-4 py-2.5 text-xs font-semibold text-primary outline-none focus:ring-1 focus:ring-secondary/20" type="number" id="calc-base-price" value="450.00" step="0.01" readonly />
                </div>
                
                <div>
                    <label class="block text-xs font-bold text-primary mb-1.5 uppercase tracking-wider">Check-In Date</label>
                    <input name="checkIn" class="w-full bg-white border border-outline-variant/40 rounded-xl px-4 py-2.5 text-xs font-semibold text-primary outline-none focus:border-secondary focus:ring-1 focus:ring-secondary" type="date" id="calc-check-in" required />
                </div>
                
                <div>
                    <label class="block text-xs font-bold text-primary mb-1.5 uppercase tracking-wider">Check-Out Date</label>
                    <input name="checkOut" class="w-full bg-white border border-outline-variant/40 rounded-xl px-4 py-2.5 text-xs font-semibold text-primary outline-none focus:border-secondary focus:ring-1 focus:ring-secondary" type="date" id="calc-check-out" required />
                </div>
                
                <div class="bg-surface p-4 rounded-xl border border-outline-variant/20 min-h-[80px] flex items-center justify-center">
                    <div id="calc-price-result" class="w-full text-center">
                        <span class="text-xs text-on-surface-variant/80 font-medium">Select dates to trigger dynamic rates...</span>
                    </div>
                </div>
                
                <button type="submit" class="w-full py-3.5 bg-primary hover:bg-primary/95 text-on-primary rounded-xl text-xs font-bold transition-all shadow hover:shadow-md flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[16px]">book_online</span>
                    Reserve Estimated Stay
                </button>
            </form>
        </div>
    </div>

    <!-- 1. RESERVATION DETAILS WORKFLOW MODAL -->
    <div id="res-modal-backdrop" class="fixed inset-0 bg-primary/30 backdrop-blur-sm z-[100] hidden items-center justify-center" onclick="closeReservationModal()">
        <div class="bg-white/95 backdrop-blur-xl border border-white/60 rounded-3xl shadow-2xl p-8 w-full max-w-lg mx-margin-mobile flex flex-col gap-6 animate-fade-in relative overflow-hidden" onclick="event.stopPropagation()">
            <!-- Header -->
            <div class="flex justify-between items-start border-b border-outline-variant/20 pb-4">
                <div>
                    <h3 class="font-headline-sm text-lg font-bold text-primary" id="modal-guest-name">Guest Reservation</h3>
                    <p class="text-xs text-on-surface-variant font-medium mt-0.5" id="modal-unit-label">Chalet 101</p>
                </div>
                <button onclick="closeReservationModal()" class="text-on-surface-variant hover:text-primary p-1.5 rounded-full hover:bg-surface-container transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <!-- Details Grid -->
            <div class="grid grid-cols-2 gap-4 text-xs">
                <div>
                    <p class="text-on-surface-variant font-semibold">Email Address</p>
                    <p class="text-primary font-bold mt-0.5" id="modal-email">guest@example.com</p>
                </div>
                <div>
                    <p class="text-on-surface-variant font-semibold">Phone Number</p>
                    <p class="text-primary font-bold mt-0.5" id="modal-phone">+44 7700 900077</p>
                </div>
                <div>
                    <p class="text-on-surface-variant font-semibold">Check-In</p>
                    <p class="text-primary font-bold mt-0.5" id="modal-checkin">2026-06-12</p>
                </div>
                <div>
                    <p class="text-on-surface-variant font-semibold">Check-Out</p>
                    <p class="text-primary font-bold mt-0.5" id="modal-checkout">2026-06-15</p>
                </div>
                <div>
                    <p class="text-on-surface-variant font-semibold">Total Price</p>
                    <p class="text-secondary font-bold text-sm mt-0.5" id="modal-price">€1,350.00</p>
                </div>
                <div>
                    <p class="text-on-surface-variant font-semibold">Nationality</p>
                    <p class="text-primary font-bold mt-0.5" id="modal-nationality">British</p>
                </div>
            </div>

            <!-- Loader indicator inside modal -->
            <div id="modal-loader" class="hidden text-center py-4">
                <div class="animate-spin inline-block w-6 h-6 border-2 border-current border-t-transparent rounded-full text-secondary" role="status"></div>
                <p class="text-xs font-semibold text-primary mt-2">Updating reservation record...</p>
            </div>

            <!-- Dynamic Workflow Actions -->
            <div class="flex flex-col gap-2 mt-2" id="modal-actions-box">
                <!-- Populated dynamically via JS -->
            </div>
        </div>
    </div>

    <!-- 2. GOOGLE CALENDAR SYNC MODAL -->
    <div id="gcal-modal-backdrop" class="fixed inset-0 bg-primary/30 backdrop-blur-sm z-[100] hidden items-center justify-center" onclick="closeGoogleSyncModal()">
        <div class="bg-white/95 backdrop-blur-xl border border-white/60 rounded-3xl shadow-2xl p-8 w-full max-w-md mx-margin-mobile flex flex-col gap-6 relative" onclick="event.stopPropagation()">
            <div class="flex justify-between items-start border-b border-outline-variant/20 pb-4">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-secondary">calendar_month</span>
                    <h3 class="font-headline-sm text-base font-bold text-primary">Google Calendar Sync Hub</h3>
                </div>
                <button onclick="closeGoogleSyncModal()" class="text-on-surface-variant hover:text-primary p-1.5 rounded-full hover:bg-surface-container transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <p class="text-xs text-on-surface-variant leading-relaxed">
                Connect your reservation ledger directly to Google Calendar. Keep your staff, reception desk, and housekeeping schedules instantly synchronized in real-time.
            </p>

            <!-- Subscription Link Copy Widget -->
            <div class="bg-surface-container-low p-4 rounded-2xl border border-outline-variant/20 flex flex-col gap-2">
                <span class="text-[10px] font-bold text-primary uppercase tracking-wider">Option A: Subscribe via iCal URL</span>
                <p class="text-[10px] text-on-surface-variant mb-1">Copy this link and add it via "From URL" in Google Calendar:</p>
                <div class="flex items-center gap-2 bg-white p-2 rounded-xl border border-outline-variant/30">
                    <input type="text" id="gcal-feed-url" readonly class="text-xs text-primary font-mono truncate border-none outline-none flex-grow bg-transparent p-0 select-all" />
                    <button onclick="copyFeedUrl()" class="bg-secondary text-white p-2 rounded-lg hover:bg-secondary/95 flex items-center shrink-0 shadow-sm" title="Copy Subscription Link">
                        <span class="material-symbols-outlined text-[16px]" id="copy-icon">content_copy</span>
                    </button>
                </div>
            </div>

            <!-- OAuth Sync Sync Button -->
            <div class="flex flex-col gap-2 border-t border-outline-variant/10 pt-4">
                <span class="text-[10px] font-bold text-primary uppercase tracking-wider">Option B: Standard Google Authentication</span>
                <button onclick="triggerMockGoogleSync()" id="btn-oauth-sync" class="w-full py-3 bg-secondary text-white text-xs font-bold rounded-xl hover:bg-secondary/90 transition-all flex items-center justify-center gap-2 shadow-sm">
                    <span class="material-symbols-outlined text-[16px]">key</span>
                    Authorize &amp; Link Google Account
                </button>
                <div id="oauth-status" class="hidden text-center py-2 bg-emerald-500/10 text-emerald-800 border border-emerald-500/20 rounded-xl text-xs font-semibold flex items-center justify-center gap-1.5 animate-pulse">
                    <span class="material-symbols-outlined text-[16px]">verified</span>
                    Google Calendar Synced Successfully!
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .animate-fade-in {
        animation: fadeIn 0.25s ease-out forwards;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

@section Scripts {
    <script>
        let currentSelectedReservationId = null;

        // Sound Synthesis helper (synthesizes audio chime locally)
        function playStatusChime() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                
                osc.type = 'sine';
                osc.frequency.setValueAtTime(660, audioCtx.currentTime); // E5
                gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.4);
                
                osc.start(audioCtx.currentTime);
                osc.stop(audioCtx.currentTime + 0.4);
            } catch(e){}
        }

        // Set default date range helper
        const today = new Date();
        const tomorrow = new Date(today);
        tomorrow.setDate(today.getDate() + 1);
        const dayAfter = new Date(today);
        dayAfter.setDate(today.getDate() + 4);
        
        const formatDate = (date) => {
            const yyyy = date.getFullYear();
            let mm = date.getMonth() + 1;
            let dd = date.getDate();
            if (dd < 10) dd = '0' + dd;
            if (mm < 10) mm = '0' + mm;
            return yyyy + '-' + mm + '-' + dd;
        };
        
        document.getElementById("calc-check-in").value = formatDate(tomorrow);
        document.getElementById("calc-check-out").value = formatDate(dayAfter);
        
        setTimeout(() => {
            calculateEstimation();
        }, 200);
        
        document.getElementById("calc-check-in").addEventListener("change", calculateEstimation);
        document.getElementById("calc-check-out").addEventListener("change", calculateEstimation);
        document.getElementById("calc-base-price").addEventListener("input", calculateEstimation);
        
        function selectUnitForCalculator(name, price) {
            document.getElementById("calc-selected-unit-name").value = name;
            document.getElementById("calc-base-price").value = price;
            calculateEstimation();
        }
        
        function calculateEstimation() {
            const basePrice = parseFloat(document.getElementById("calc-base-price").value) || 0;
            const inVal = document.getElementById("calc-check-in").value;
            const outVal = document.getElementById("calc-check-out").value;
            
            if (!inVal || !outVal) return;
            
            const checkIn = new Date(inVal);
            const checkOut = new Date(outVal);
            
            if (checkOut <= checkIn) {
                document.getElementById("calc-price-result").innerHTML = '<span class="text-error text-xs font-bold">Check-out must be after check-in.</span>';
                return;
            }
            
            const diffTime = Math.abs(checkOut - checkIn);
            const nights = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            
            let totalPrice = 0;
            let weekendNightsCount = 0;
            let currentDay = new Date(checkIn);
            
            for (let i = 0; i < nights; i++) {
                const dayOfWeek = currentDay.getDay(); 
                let nightRate = basePrice;
                if (dayOfWeek === 5 || dayOfWeek === 6) { // Friday, Saturday
                    nightRate = basePrice * 1.15;
                    weekendNightsCount++;
                }
                totalPrice += nightRate;
                currentDay.setDate(currentDay.getDate() + 1);
            }
            
            const avgRate = totalPrice / nights;
            
            document.getElementById("calc-price-result").innerHTML = `
                <div class="text-left space-y-1.5 text-xs">
                    <div class="flex justify-between font-bold text-primary">
                        <span>Total (${nights} Nights)</span>
                        <span>€${totalPrice.toFixed(2)}</span>
                    </div>
                    <div class="flex justify-between text-on-surface-variant font-semibold">
                        <span>Average Nightly Rate</span>
                        <span>€${avgRate.toFixed(2)}</span>
                    </div>
                    <div class="text-[10px] text-secondary font-medium">
                        * Includes ${weekendNightsCount} weekend nights calculated with 15% dynamic surcharge.
                    </div>
                </div>
            `;
        }

        // --- 1. RESERVATION DETAILS WORKFLOW OVERLAYS ---
        function openReservationModal(res) {
            currentSelectedReservationId = res.id;
            
            document.getElementById('modal-guest-name').innerText = res.customer;
            document.getElementById('modal-unit-label').innerText = 'Room Unit: ' + res.unit;
            document.getElementById('modal-email').innerText = res.email;
            document.getElementById('modal-phone').innerText = res.phone;
            document.getElementById('modal-checkin').innerText = res.checkIn;
            document.getElementById('modal-checkout').innerText = res.checkOut;
            document.getElementById('modal-price').innerText = '€' + res.price;
            document.getElementById('modal-nationality').innerText = res.nationality;

            // Render Dynamic Workflow Action Buttons based on status
            const actionsBox = document.getElementById('modal-actions-box');
            actionsBox.innerHTML = '';
            
            if (res.status === 'Confirmed') {
                actionsBox.innerHTML = `
                    <button onclick="triggerReservationStatus('check-in')" class="w-full py-3 bg-secondary text-white text-xs font-bold rounded-xl hover:bg-secondary-container hover:text-on-secondary-container transition-all flex items-center justify-center gap-1.5 shadow-sm">
                        <span class="material-symbols-outlined text-[16px]">check_circle</span>
                        Register Check-In &amp; Hand Keys
                    </button>
                    <button onclick="triggerReservationStatus('cancel')" class="w-full py-3 border border-error text-error text-xs font-bold rounded-xl hover:bg-error/5 transition-all flex items-center justify-center gap-1.5">
                        <span class="material-symbols-outlined text-[16px]">cancel</span>
                        Cancel Guest Reservation
                    </button>
                `;
            } else if (res.status === 'CheckedIn') {
                actionsBox.innerHTML = `
                    <button onclick="triggerReservationStatus('check-out')" class="w-full py-3 bg-primary text-on-primary text-xs font-bold rounded-xl hover:bg-primary-container transition-all flex items-center justify-center gap-1.5 shadow-sm">
                        <span class="material-symbols-outlined text-[16px]">assignment_turned_in</span>
                        Log Check-Out &amp; Invoice Settlement
                    </button>
                `;
            } else {
                actionsBox.innerHTML = `
                    <button onclick="closeReservationModal()" class="w-full py-3 bg-surface-container hover:bg-surface-container-high text-primary text-xs font-bold rounded-xl transition-all">
                        Close Guest Record File
                    </button>
                `;
            }

            const backdrop = document.getElementById('res-modal-backdrop');
            backdrop.classList.remove('hidden');
            backdrop.classList.add('flex');
        }

        function closeReservationModal() {
            const backdrop = document.getElementById('res-modal-backdrop');
            backdrop.classList.remove('flex');
            backdrop.classList.add('hidden');
        }

        async function triggerReservationStatus(action) {
            if (!currentSelectedReservationId) return;

            const actionsBox = document.getElementById('modal-actions-box');
            const loader = document.getElementById('modal-loader');
            
            actionsBox.classList.add('hidden');
            loader.classList.remove('hidden');

            try {
                const response = await fetch(`/bookings/${currentSelectedReservationId}/${action}`, {
                    method: 'POST'
                });

                if (response.ok) {
                    playStatusChime();
                    loader.innerHTML = `
                        <div class="text-emerald-600 font-bold text-xs flex flex-col items-center gap-1 animate-pulse">
                            <span class="material-symbols-outlined text-[32px]">verified</span>
                            Operation successfully saved to ledger!
                        </div>
                    `;
                    
                    setTimeout(() => {
                        window.location.reload();
                    }, 1200);
                } else {
                    alert("Operation failed. Parity checks rejected the workflow transition.");
                    actionsBox.classList.remove('hidden');
                    loader.classList.add('hidden');
                }
            } catch (e) {
                alert("Network connectivity issue. Failed to connect to SQL database.");
                actionsBox.classList.remove('hidden');
                loader.classList.add('hidden');
            }
        }

        // --- 2. GOOGLE CALENDAR SYNC MODALS ---
        function openGoogleSyncModal() {
            // Set dynamic feed url
            const feedUrlInput = document.getElementById('gcal-feed-url');
            const protocol = window.location.protocol;
            const host = window.location.host;
            feedUrlInput.value = `${protocol}//${host}/bookings/feed.ics`;

            const modal = document.getElementById('gcal-modal-backdrop');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeGoogleSyncModal() {
            const modal = document.getElementById('gcal-modal-backdrop');
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }

        function copyFeedUrl() {
            const feedUrlInput = document.getElementById('gcal-feed-url');
            feedUrlInput.select();
            feedUrlInput.setSelectionRange(0, 99999); 
            navigator.clipboard.writeText(feedUrlInput.value);

            const copyIcon = document.getElementById('copy-icon');
            copyIcon.innerText = 'check';
            setTimeout(() => {
                copyIcon.innerText = 'content_copy';
            }, 2000);
        }

        function triggerMockGoogleSync() {
            const syncBtn = document.getElementById('btn-oauth-sync');
            const statusDiv = document.getElementById('oauth-status');
            
            syncBtn.classList.add('hidden');
            statusDiv.classList.remove('hidden');
            playStatusChime();
        }

        // Auto slide-out toast message if present
        const toast = document.querySelector('#bookings-toast-container > div');
        if (toast) {
            setTimeout(() => {
                toast.classList.remove('translate-x-full');
                toast.classList.add('translate-x-0');
            }, 10);
            setTimeout(() => {
                toast.classList.remove('translate-x-0');
                toast.classList.add('translate-x-full');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }
    </script>
}
