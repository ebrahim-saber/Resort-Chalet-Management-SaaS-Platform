            © 2026 ChaletElite Luxury Management. All rights reserved.
        </div>
    </footer>
    
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- Dynamic Active Tab Highlight script -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const currentPath = window.location.pathname.toLowerCase();
            
            // Standard direct links
            const directLinks = [
                { id: "nav-dashboard", paths: ["/dashboard"] },
                { id: "nav-guests", paths: ["/guests"] },
                { id: "nav-storefront", paths: ["/storefront"] }
            ];

            directLinks.forEach(item => {
                const element = document.getElementById(item.id);
                if (element) {
                    const isActive = item.paths.some(p => currentPath === p || currentPath.startsWith(p + "/"));
                    if (isActive) {
                        element.className = "text-secondary bg-secondary/10 font-bold rounded-full px-4 py-2 transition-all duration-200 text-label-md font-label-md";
                    } else {
                        element.className = "text-on-surface-variant hover:text-primary hover:bg-black/5 dark:hover:bg-white/5 rounded-full px-4 py-2 transition-all duration-200 text-label-md font-label-md";
                    }
                }
            });

            // Dropdown items configuration
            const dropdowns = [
                {
                    triggerId: "nav-properties-trigger",
                    items: [
                        { id: "nav-resorts", paths: ["/resorts"] },
                        { id: "nav-units", paths: ["/resorts/units"] }
                    ]
                },
                {
                    triggerId: "nav-operations-trigger",
                    items: [
                        { id: "nav-bookings", paths: ["/bookings"] },
                        { id: "nav-calendar", paths: ["/calendar"] },
                        { id: "nav-housekeeping", paths: ["/operations/housekeeping"] },
                        { id: "nav-maintenance", paths: ["/operations/maintenance"] }
                    ]
                },
                {
                    triggerId: "nav-financials-trigger",
                    items: [
                        { id: "nav-billing", paths: ["/billing"] },
                        { id: "nav-analytics", paths: ["/analytics"] },
                        { id: "nav-owner", paths: ["/owner"] }
                    ]
                }
            ];

            dropdowns.forEach(group => {
                const triggerEl = document.getElementById(group.triggerId);
                let isAnyChildActive = false;

                group.items.forEach(item => {
                    const itemEl = document.getElementById(item.id);
                    const isActive = item.paths.some(p => {
                        if (p === "/resorts") {
                            return currentPath === "/resorts"; // resorts index exactly
                        }
                        return currentPath === p || currentPath.startsWith(p + "/");
                    });

                    if (isActive) {
                        isAnyChildActive = true;
                        if (itemEl) {
                            itemEl.className = "block px-4 py-2.5 rounded-xl text-label-md text-secondary font-bold bg-secondary/10 transition-all duration-200";
                        }
                    } else {
                        if (itemEl) {
                            itemEl.className = "block px-4 py-2.5 rounded-xl text-label-md text-on-surface-variant hover:bg-secondary/5 hover:text-secondary transition-all duration-200";
                        }
                    }
                });

                if (triggerEl) {
                    if (isAnyChildActive) {
                        triggerEl.className = "text-secondary bg-secondary/10 font-bold rounded-full px-4 py-2 transition-all duration-200 text-label-md font-label-md flex items-center gap-1";
                    } else {
                        triggerEl.className = "text-on-surface-variant hover:text-primary hover:bg-black/5 dark:hover:bg-white/5 rounded-full px-4 py-2 transition-all duration-200 text-label-md font-label-md flex items-center gap-1";
                    }
                }
            });
        });
    </script>

    <!-- Toast Notification Container (Floating Bottom-Right) -->
    <div id="toast-container" class="fixed bottom-6 right-6 z-50 flex flex-col gap-4 max-w-sm w-full"></div>

    <!-- Notification Center Drawer Overlay -->
    <div id="notifications-backdrop" class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-40 hidden" onclick="toggleNotificationsDrawer()"></div>
    <aside id="notifications-drawer" class="fixed right-0 top-0 h-full w-full md:w-[480px] bg-white/90 backdrop-blur-xl border-l border-white/40 shadow-[-4px_0_24px_0_rgba(0,39,65,0.08)] z-50 flex flex-col overflow-hidden transform transition-transform duration-300 translate-x-full">
        
        <!-- MAIN PANEL: Feed & Filters & Simulator -->
        <div id="notifications-main-panel" class="h-full w-full flex flex-col transition-transform duration-300">
            <!-- Header -->
            <header class="px-8 py-6 border-b border-outline-variant/30 flex justify-between items-center bg-white/40">
                <div>
                    <h2 class="font-headline-md text-headline-md text-primary">Notifications</h2>
                    <p class="font-body-md text-body-md text-on-surface-variant mt-1">Activity Feed &amp; Alerts</p>
                </div>
                <div class="flex gap-3 items-center">
                    <button onclick="markAllNotificationsAsRead()" class="text-secondary hover:text-primary transition-colors font-label-md text-label-md flex items-center gap-1">
                        <span class="material-symbols-outlined" style="font-size: 18px;">done_all</span>
                        Mark all read
                    </button>
                    <button onclick="toggleNotificationsDrawer()" class="text-on-surface-variant hover:text-primary transition-colors p-2 rounded-full hover:bg-surface-container">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
            </header>

            <!-- Collapsible Developer Simulation Console -->
            <div class="border-b border-outline-variant/20 bg-surface-container-low/50">
                <button onclick="toggleSimulator()" class="w-full px-8 py-3 flex justify-between items-center text-label-md text-primary hover:bg-surface-container/40 transition-colors">
                    <span class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px] text-secondary">terminal</span>
                        Developer Console: Simulate Alerts
                    </span>
                    <span id="simulator-arrow" class="material-symbols-outlined transition-transform duration-200">keyboard_arrow_down</span>
                </button>
                <div id="simulator-form" class="hidden px-8 pb-4 flex flex-col gap-3">
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-[11px] font-semibold text-on-surface-variant uppercase mb-1">Preset Alert Type</label>
                            <select id="sim-preset" onchange="applyPresetTemplate(this.value)" class="w-full text-xs rounded-lg border-outline-variant/50 bg-white/80 py-1.5 focus:border-secondary focus:ring-secondary">
                                <option value="custom">Custom Alert...</option>
                                <option value="booking">VIP Reservation (System)</option>
                                <option value="maintenance">AC Compressor Failure (Alert)</option>
                                <option value="guest">WhatsApp Guest Inquiry</option>
                                <option value="email">Email Catering Request</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-[11px] font-semibold text-on-surface-variant uppercase mb-1">Alert Channel</label>
                            <select id="sim-channel" class="w-full text-xs rounded-lg border-outline-variant/50 bg-white/80 py-1.5 focus:border-secondary focus:ring-secondary">
                                <option value="System">System</option>
                                <option value="Alerts">Alerts (Warning)</option>
                                <option value="WhatsApp">WhatsApp</option>
                                <option value="Email">Email</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-[11px] font-semibold text-on-surface-variant uppercase mb-1">Alert Title</label>
                        <input id="sim-title" type="text" placeholder="e.g. Heating Malfunction" class="w-full text-xs rounded-lg border-outline-variant/50 bg-white/80 py-1.5 focus:border-secondary focus:ring-secondary" />
                    </div>
                    <div>
                        <label class="block text-[11px] font-semibold text-on-surface-variant uppercase mb-1">Alert Description Body</label>
                        <textarea id="sim-body" rows="2" placeholder="Describe the notification event context..." class="w-full text-xs rounded-lg border-outline-variant/50 bg-white/80 py-1.5 focus:border-secondary focus:ring-secondary"></textarea>
                    </div>
                    <button onclick="submitSimulatedNotification()" class="bg-secondary text-white text-xs font-semibold py-2 px-4 rounded-lg hover:bg-secondary-container hover:text-on-secondary-container transition-colors shadow-sm flex items-center justify-center gap-1">
                        <span class="material-symbols-outlined text-[14px]">send</span>
                        Trigger Live Database Alert
                    </button>
                </div>
            </div>

            <!-- Filters -->
            <div class="px-8 py-4 flex gap-2 overflow-x-auto custom-scroll border-b border-outline-variant/20">
                <button onclick="filterNotifications('All', this)" class="filter-btn px-4 py-1.5 rounded-full bg-primary text-on-primary font-label-sm text-label-sm shadow-sm whitespace-nowrap">All</button>
                <button onclick="filterNotifications('WhatsApp', this)" class="filter-btn px-4 py-1.5 rounded-full border border-outline-variant/50 text-on-surface-variant hover:border-primary hover:text-primary transition-colors font-label-sm text-label-sm whitespace-nowrap flex items-center gap-1">
                    <span class="material-symbols-outlined" style="font-size: 14px;">forum</span> WhatsApp
                </button>
                <button onclick="filterNotifications('Email', this)" class="filter-btn px-4 py-1.5 rounded-full border border-outline-variant/50 text-on-surface-variant hover:border-primary hover:text-primary transition-colors font-label-sm text-label-sm whitespace-nowrap flex items-center gap-1">
                    <span class="material-symbols-outlined" style="font-size: 14px;">mail</span> Email
                </button>
                <button onclick="filterNotifications('Alerts', this)" class="filter-btn px-4 py-1.5 rounded-full border border-outline-variant/50 text-on-surface-variant hover:border-primary hover:text-primary transition-colors font-label-sm text-label-sm whitespace-nowrap flex items-center gap-1">
                    <span class="material-symbols-outlined" style="font-size: 14px;">warning</span> Alerts
                </button>
                <button onclick="filterNotifications('System', this)" class="filter-btn px-4 py-1.5 rounded-full border border-outline-variant/50 text-on-surface-variant hover:border-primary hover:text-primary transition-colors font-label-sm text-label-sm whitespace-nowrap flex items-center gap-1">
                    <span class="material-symbols-outlined" style="font-size: 14px;">build</span> System
                </button>
            </div>

            <!-- Activity Feed List -->
            <div id="notifications-feed" class="flex-grow overflow-y-auto custom-scroll p-8 flex flex-col gap-6">
                <div class="text-center py-12 text-on-surface-variant">
                    <div class="animate-spin inline-block w-8 h-8 border-4 border-current border-t-transparent rounded-full text-secondary" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                    <p class="mt-4 font-medium">Retrieving luxury feed...</p>
                </div>
            </div>
        </div>

        <!-- DETAILS PANEL: Sliding Sub-Panel for Interactive Action Hub -->
        <div id="notifications-details-panel" class="absolute inset-0 bg-white flex flex-col transform transition-transform duration-300 translate-x-full z-10">
            <!-- Details Header -->
            <header class="px-8 py-6 border-b border-outline-variant/30 flex items-center gap-4 bg-surface-container-low/40">
                <button onclick="closeNotificationDetails()" class="text-on-surface-variant hover:text-primary p-1.5 rounded-full hover:bg-surface-container transition-colors flex items-center">
                    <span class="material-symbols-outlined">arrow_back</span>
                </button>
                <div>
                    <h2 class="font-label-md text-label-md text-primary" id="detail-category-label">Alert Detail</h2>
                    <p class="text-xs text-on-surface-variant mt-0.5" id="detail-time-label">Just now</p>
                </div>
            </header>

            <!-- Details Content Area -->
            <div class="flex-grow overflow-y-auto custom-scroll p-8 flex flex-col gap-6" id="detail-content-area">
                <!-- Will be dynamically populated via showNotificationDetails -->
            </div>
        </div>
    </aside>

    <script>
        let activeFilter = 'All';
        let notificationsList = [];
        let isInitialized = false;

        // 1. Play Premium Notification Chime (Synthesized via Web Audio API)
        function playNotificationSound() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                
                // Chime 1
                const osc1 = audioCtx.createOscillator();
                const gain1 = audioCtx.createGain();
                osc1.connect(gain1);
                gain1.connect(audioCtx.destination);
                
                osc1.type = 'sine';
                osc1.frequency.setValueAtTime(880, audioCtx.currentTime); // A5 note
                gain1.gain.setValueAtTime(0.12, audioCtx.currentTime);
                gain1.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.5);
                
                osc1.start(audioCtx.currentTime);
                osc1.stop(audioCtx.currentTime + 0.5);
                
                // Chime 2 (Delayed higher pitch)
                setTimeout(() => {
                    const osc2 = audioCtx.createOscillator();
                    const gain2 = audioCtx.createGain();
                    osc2.connect(gain2);
                    gain2.connect(audioCtx.destination);
                    
                    osc2.type = 'sine';
                    osc2.frequency.setValueAtTime(1320, audioCtx.currentTime); // E6 note
                    gain2.gain.setValueAtTime(0.12, audioCtx.currentTime);
                    gain2.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.7);
                    
                    osc2.start(audioCtx.currentTime);
                    osc2.stop(audioCtx.currentTime + 0.7);
                }, 120);
            } catch (e) {
                console.warn("Audio Context blocked or unsupported:", e);
            }
        }

        // 2. Play Sending "Swoosh" Sound (Synthesized via Web Audio API)
        function playSwooshSound() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(160, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(900, audioCtx.currentTime + 0.4);
                
                gain.gain.setValueAtTime(0.08, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.4);
                
                osc.start(audioCtx.currentTime);
                osc.stop(audioCtx.currentTime + 0.4);
            } catch (e) {}
        }

        // 3. Toggle Drawer Panel
        function toggleNotificationsDrawer() {
            const drawer = document.getElementById('notifications-drawer');
            const backdrop = document.getElementById('notifications-backdrop');
            
            if (drawer.classList.contains('translate-x-full')) {
                drawer.classList.remove('translate-x-full');
                drawer.classList.add('translate-x-0');
                backdrop.classList.remove('hidden');
                fetchNotifications();
            } else {
                drawer.classList.remove('translate-x-0');
                drawer.classList.add('translate-x-full');
                backdrop.classList.add('hidden');
                closeNotificationDetails();
            }
        }

        // 4. Fetch and Sync Notifications with Toast Detection
        async function fetchNotifications() {
            try {
                const response = await fetch('/operations/notifications');
                if (response.ok) {
                    const newNotifications = await response.json();
                    
                    // Identify newly created notifications to trigger Toasts
                    if (isInitialized) {
                        newNotifications.forEach(notif => {
                            const exists = notificationsList.some(n => n.id === notif.id);
                            if (!exists) {
                                triggerToast(notif);
                                playNotificationSound();
                            }
                        });
                    }
                    
                    notificationsList = newNotifications;
                    isInitialized = true;
                    
                    renderNotifications();
                    updateBadge();
                }
            } catch (error) {
                console.error("Failed to fetch notifications:", error);
            }
        }

        // 5. Render Drawer Feed List
        function renderNotifications() {
            const feed = document.getElementById('notifications-feed');
            feed.innerHTML = '';

            const filtered = activeFilter === 'All' 
                ? notificationsList 
                : notificationsList.filter(n => n.channel.toLowerCase() === activeFilter.toLowerCase());

            if (filtered.length === 0) {
                feed.innerHTML = `
                    <div class="text-center py-16 text-on-surface-variant/70">
                        <span class="material-symbols-outlined text-[48px] text-outline-variant">notifications_off</span>
                        <p class="mt-3 font-semibold text-sm">No alerts in this category</p>
                    </div>
                `;
                return;
            }

            filtered.forEach(n => {
                const isUnread = n.status === 'Queued';
                const unreadIndicator = isUnread 
                    ? `relative pl-6 before:content-[''] before:absolute before:left-0 before:top-4 before:w-2.5 before:h-2.5 before:bg-secondary before:rounded-full` 
                    : `relative pl-6`;

                let channelIcon = 'chat';
                let channelColor = 'bg-primary-container text-on-primary-container';
                let typeLabel = n.channel;

                if (n.channel.toLowerCase() === 'whatsapp') {
                    channelIcon = 'forum';
                    channelColor = 'bg-secondary-container text-on-secondary-container';
                    typeLabel = 'WhatsApp Message';
                } else if (n.channel.toLowerCase() === 'email') {
                    channelIcon = 'mail';
                    channelColor = 'bg-surface-container-highest text-primary';
                    typeLabel = 'Email Alert';
                } else if (n.channel.toLowerCase() === 'alerts' || n.channel.toLowerCase() === 'warning') {
                    channelIcon = 'warning';
                    channelColor = 'bg-error-container text-on-error-container';
                    typeLabel = 'Urgent Alert';
                } else if (n.channel.toLowerCase() === 'system') {
                    channelIcon = 'build';
                    channelColor = 'bg-surface-container-highest text-primary';
                    typeLabel = 'System Notify';
                }

                feed.innerHTML += `
                    <div class="${unreadIndicator}">
                        <div onclick="showNotificationDetails('${n.id}', this)" class="bg-surface-container-lowest border border-white/60 p-4 rounded-xl shadow-[0_2px_12px_0_rgba(0,39,65,0.03)] hover:shadow-[0_4px_20px_0_rgba(0,39,65,0.07)] hover:border-secondary/30 transition-all cursor-pointer group ${isUnread ? 'border-secondary/20 bg-secondary/5' : ''}">
                            <div class="flex justify-between items-start mb-2">
                                <div class="flex items-center gap-2">
                                    <div class="w-7 h-7 rounded-full ${channelColor} flex items-center justify-center">
                                        <span class="material-symbols-outlined" style="font-size: 14px;">${channelIcon}</span>
                                    </div>
                                    <span class="font-label-sm text-label-sm font-semibold ${n.channel.toLowerCase() === 'alerts' ? 'text-error' : 'text-primary'}">${typeLabel}</span>
                                </div>
                                <span class="font-label-sm text-label-sm text-on-surface-variant">${n.timeAgo}</span>
                            </div>
                            <h3 class="font-label-md text-label-md text-primary font-bold mb-1">${n.title}</h3>
                            <p class="font-body-md text-xs text-on-surface-variant line-clamp-2">${n.body}</p>
                        </div>
                    </div>
                `;
            });
        }

        // 6. Filter Drawer Feed
        function filterNotifications(filter, btn) {
            activeFilter = filter;
            
            const buttons = document.querySelectorAll('.filter-btn');
            buttons.forEach(b => {
                b.className = "filter-btn px-4 py-1.5 rounded-full border border-outline-variant/50 text-on-surface-variant hover:border-primary hover:text-primary transition-colors font-label-sm text-label-sm whitespace-nowrap flex items-center gap-1";
            });

            btn.className = "filter-btn px-4 py-1.5 rounded-full bg-primary text-on-primary font-label-sm text-label-sm shadow-sm whitespace-nowrap";
            renderNotifications();
        }

        // 7. Toggle Developer Console
        function toggleSimulator() {
            const form = document.getElementById('simulator-form');
            const arrow = document.getElementById('simulator-arrow');
            if (form.classList.contains('hidden')) {
                form.classList.remove('hidden');
                arrow.style.transform = 'rotate(180deg)';
            } else {
                form.classList.add('hidden');
                arrow.style.transform = 'rotate(0deg)';
            }
        }

        // 8. Preset Templates for Simulator Console
        function applyPresetTemplate(val) {
            const titleInput = document.getElementById('sim-title');
            const bodyInput = document.getElementById('sim-body');
            const channelSelect = document.getElementById('sim-channel');

            if (val === 'booking') {
                titleInput.value = 'New VIP Reservation Confirmed';
                bodyInput.value = 'Chalet Mont Blanc has been booked by Al-Maktoum family for June 12 - 20. Premium yacht tour service requested.';
                channelSelect.value = 'System';
            } else if (val === 'maintenance') {
                titleInput.value = 'Urgent AC compressor leak - Villa 102';
                bodyInput.value = 'Sensor reported ambient temperature spike of 29°C in bedroom suite. Guest requested technical dispatch.';
                channelSelect.value = 'Alerts';
            } else if (val === 'guest') {
                titleInput.value = 'Ibrahim Saber - WhatsApp Inquiry';
                bodyInput.value = 'Can we arrange check-in at 10 AM instead of 2 PM tomorrow morning? We are arriving on early flight.';
                channelSelect.value = 'WhatsApp';
            } else if (val === 'email') {
                titleInput.value = 'Private Chef Catering Proposal';
                bodyInput.value = 'Inquiry regarding organic, dairy-free private catering options for evening terrace dining next Saturday.';
                channelSelect.value = 'Email';
            } else {
                titleInput.value = '';
                bodyInput.value = '';
            }
        }

        // 9. Submit simulated notification to backend database
        async function submitSimulatedNotification() {
            const channel = document.getElementById('sim-channel').value;
            const title = document.getElementById('sim-title').value;
            const body = document.getElementById('sim-body').value;

            if (!title || !body) {
                alert("Please fill in Title and Description.");
                return;
            }

            try {
                const response = await fetch('/operations/notifications/create-simulated', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ channel, title, body })
                });

                if (response.ok) {
                    // Instantly trigger sync
                    await fetchNotifications();
                    
                    // Reset simulator inputs
                    document.getElementById('sim-title').value = '';
                    document.getElementById('sim-body').value = '';
                    document.getElementById('sim-preset').value = 'custom';
                    toggleSimulator();
                } else {
                    console.error("Failed to inject simulation");
                }
            } catch (e) {
                console.error(e);
            }
        }

        // 10. Sliding Sub-Panel Details Hub
        async function showNotificationDetails(id, cardElement) {
            const notif = notificationsList.find(n => n.id === id);
            if (!notif) return;

            // Slide in the panel
            const panel = document.getElementById('notifications-details-panel');
            panel.classList.remove('translate-x-full');
            panel.classList.add('translate-x-0');

            // Set labels
            let channelText = notif.channel;
            if (notif.channel.toLowerCase() === 'whatsapp') channelText = 'WhatsApp Message';
            if (notif.channel.toLowerCase() === 'email') channelText = 'Email Alert';
            if (notif.channel.toLowerCase() === 'alerts') channelText = 'Urgent Operations Warning';
            if (notif.channel.toLowerCase() === 'system') channelText = 'System Automation Notify';

            document.getElementById('detail-category-label').innerText = channelText;
            document.getElementById('detail-time-label').innerText = notif.timeAgo + ' • Status: ' + notif.status;

            // Mark read on backend immediately if unread
            if (notif.status === 'Queued') {
                try {
                    const response = await fetch(`/operations/notifications/${id}/read`, { method: 'POST' });
                    if (response.ok) {
                        notif.status = 'Sent';
                        if (cardElement) {
                            const parent = cardElement.closest('.relative');
                            if (parent) parent.className = 'relative pl-6';
                            cardElement.classList.remove('border-secondary/20', 'bg-secondary/5');
                        }
                        updateBadge();
                    }
                } catch (e) {}
            }

            // Render customized interactive actions based on alert category/channel
            const container = document.getElementById('detail-content-area');
            let actionsHtml = '';

            if (notif.channel.toLowerCase() === 'whatsapp') {
                actionsHtml = `
                    <div class="bg-surface-container-lowest border border-white/60 p-5 rounded-2xl shadow-sm flex flex-col gap-4">
                        <h4 class="font-label-md text-label-sm font-bold text-secondary uppercase tracking-wider flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[16px]">forum</span>
                            Live Guest Conversation
                        </h4>
                        
                        <!-- Chat message bubbles -->
                        <div class="flex flex-col gap-3 p-3 bg-surface-container-low/40 rounded-xl max-h-[220px] overflow-y-auto custom-scroll" id="chat-history">
                            <div class="bg-surface-variant/40 text-on-surface p-3 rounded-2xl rounded-tl-none max-w-[85%] text-xs">
                                <p class="font-semibold text-primary mb-1">Incoming Request</p>
                                ${notif.body}
                            </div>
                        </div>

                        <!-- Chat reply input -->
                        <div class="flex flex-col gap-2 mt-2" id="chat-composer-box">
                            <textarea id="whatsapp-reply-text" rows="2" placeholder="Type luxury response to send via WhatsApp..." class="w-full text-xs rounded-xl border-outline-variant/40 bg-white py-2 focus:border-secondary focus:ring-secondary"></textarea>
                            <button onclick="sendWhatsAppReply('${notif.id}')" class="bg-secondary text-white text-xs font-semibold py-2 px-4 rounded-xl hover:bg-secondary-container hover:text-on-secondary-container transition-all flex items-center justify-center gap-1 shadow-sm">
                                <span class="material-symbols-outlined text-[14px]">send</span>
                                Send Response to Guest
                            </button>
                        </div>
                    </div>
                `;
            } else if (notif.channel.toLowerCase() === 'email') {
                actionsHtml = `
                    <div class="bg-surface-container-lowest border border-white/60 p-5 rounded-2xl shadow-sm flex flex-col gap-4">
                        <h4 class="font-label-md text-label-sm font-bold text-primary uppercase tracking-wider flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[16px]">mail</span>
                            Concierge Email Desk
                        </h4>
                        <div class="text-xs flex flex-col gap-2 bg-surface-container-low/30 p-3 rounded-xl">
                            <p class="text-on-surface-variant"><strong class="text-primary">To:</strong> ${notif.recipient || 'guest@luxuryresorts.com'}</p>
                            <p class="text-on-surface-variant"><strong class="text-primary">Subject:</strong> Re: ${notif.title}</p>
                        </div>
                        <div class="flex flex-col gap-2" id="email-composer-box">
                            <textarea id="email-reply-text" rows="3" placeholder="Compose email response..." class="w-full text-xs rounded-xl border-outline-variant/40 bg-white py-2 focus:border-secondary focus:ring-secondary"></textarea>
                            <button onclick="sendEmailReply()" class="bg-primary text-white text-xs font-semibold py-2 px-4 rounded-xl hover:bg-primary-container transition-all flex items-center justify-center gap-1 shadow-sm">
                                <span class="material-symbols-outlined text-[14px]">send</span>
                                Dispatch Concierge Email
                            </button>
                        </div>
                    </div>
                `;
            } else if (notif.channel.toLowerCase() === 'alerts' || notif.channel.toLowerCase() === 'warning') {
                actionsHtml = `
                    <div class="bg-surface-container-lowest border border-white/60 p-5 rounded-2xl shadow-sm flex flex-col gap-4">
                        <h4 class="font-label-md text-label-sm font-bold text-error uppercase tracking-wider flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[16px]">engineering</span>
                            Emergency Dispatch Protocol
                        </h4>
                        <p class="text-xs text-on-surface-variant">Acknowledge critical maintenance telemetry to notify staff immediately:</p>
                        
                        <div class="flex flex-col gap-2 text-xs" id="dispatch-checklist-box">
                            <label class="flex items-center gap-2 p-2 hover:bg-surface-container/30 rounded-lg cursor-pointer">
                                <input type="checkbox" id="chk-crew" class="rounded text-secondary focus:ring-secondary" />
                                <span>Assign nearest maintenance engineer to site</span>
                            </label>
                            <label class="flex items-center gap-2 p-2 hover:bg-surface-container/30 rounded-lg cursor-pointer">
                                <input type="checkbox" id="chk-status" class="rounded text-secondary focus:ring-secondary" />
                                <span>Mark unit status as "Maintenance Pending"</span>
                            </label>
                            <label class="flex items-center gap-2 p-2 hover:bg-surface-container/30 rounded-lg cursor-pointer">
                                <input type="checkbox" id="chk-notify" class="rounded text-secondary focus:ring-secondary" />
                                <span>Log emergency alert in operations portal</span>
                            </label>
                            
                            <button onclick="acknowledgeAlert()" class="bg-error text-white text-xs font-semibold py-2 px-4 rounded-xl hover:bg-error/90 transition-all flex items-center justify-center gap-1 mt-2 shadow-sm">
                                <span class="material-symbols-outlined text-[14px]">done</span>
                                Acknowledge &amp; Dispatch Crew
                            </button>
                        </div>
                    </div>
                `;
            } else { // System / Automation
                let directLink = '/bookings';
                let btnText = 'View Bookings Ledger';
                if (notif.title.toLowerCase().includes('resort')) {
                    directLink = '/resorts';
                    btnText = 'Manage Resorts';
                } else if (notif.title.toLowerCase().includes('room') || notif.title.toLowerCase().includes('unit')) {
                    directLink = '/resorts/units';
                    btnText = 'Open Units Configuration';
                }

                actionsHtml = `
                    <div class="bg-surface-container-lowest border border-white/60 p-5 rounded-2xl shadow-sm flex flex-col gap-4">
                        <h4 class="font-label-md text-label-sm font-bold text-primary uppercase tracking-wider flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[16px]">settings_system_daydream</span>
                            System Automation Link
                        </h4>
                        <p class="text-xs text-on-surface-variant">This system record is logged into the ledger. Navigate directly to view or audit:</p>
                        <a href="${directLink}" class="bg-primary text-on-primary text-center text-xs font-semibold py-2.5 px-4 rounded-xl hover:bg-primary-container hover:text-on-primary-container transition-all flex items-center justify-center gap-1 shadow-sm">
                            <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                            ${btnText}
                        </a>
                    </div>
                `;
            }

            container.innerHTML = `
                <!-- Notification Core Card -->
                <div class="bg-surface-container-low/40 p-6 rounded-2xl border border-outline-variant/20">
                    <h3 class="font-headline-md text-lg font-bold text-primary mb-3">${notif.title}</h3>
                    <p class="font-body-md text-sm text-on-surface-variant leading-relaxed whitespace-pre-line">${notif.body}</p>
                </div>
                
                <!-- Action Hub Form -->
                ${actionsHtml}
            `;
        }

        function closeNotificationDetails() {
            const panel = document.getElementById('notifications-details-panel');
            panel.classList.remove('translate-x-0');
            panel.classList.add('translate-x-full');
        }

        // Interactive WhatsApp send reply function
        function sendWhatsAppReply(id) {
            const text = document.getElementById('whatsapp-reply-text').value;
            if (!text) return;

            playSwooshSound();
            const composer = document.getElementById('chat-composer-box');
            composer.innerHTML = `
                <div class="text-center py-4 text-on-surface-variant">
                    <div class="animate-spin inline-block w-5 h-5 border-2 border-current border-t-transparent rounded-full text-secondary" role="status"></div>
                    <span class="text-xs ml-2 font-medium">Sending WhatsApp Dispatch...</span>
                </div>
            `;

            setTimeout(() => {
                const history = document.getElementById('chat-history');
                history.innerHTML += `
                    <div class="bg-secondary/15 text-primary p-3 rounded-2xl rounded-tr-none max-w-[85%] text-xs align-self-end ml-auto">
                        <p class="font-semibold text-secondary mb-1">Outgoing Response</p>
                        ${text}
                    </div>
                `;
                
                composer.innerHTML = `
                    <div class="text-center py-2 bg-secondary/10 text-secondary border border-secondary/20 rounded-xl text-xs font-semibold flex items-center justify-center gap-1.5 animate-pulse">
                        <span class="material-symbols-outlined text-[16px]">done_all</span>
                        Message Delivered to Guest!
                    </div>
                `;
                
                // Scroll down
                history.scrollTop = history.scrollHeight;
            }, 1200);
        }

        // Interactive Email send response
        function sendEmailReply() {
            const text = document.getElementById('email-reply-text').value;
            if (!text) return;

            playSwooshSound();
            const composer = document.getElementById('email-composer-box');
            composer.innerHTML = `
                <div class="text-center py-4 text-on-surface-variant">
                    <div class="animate-spin inline-block w-5 h-5 border-2 border-current border-t-transparent rounded-full text-primary" role="status"></div>
                    <span class="text-xs ml-2 font-medium">Dispatching Luxury Mail...</span>
                </div>
            `;

            setTimeout(() => {
                composer.innerHTML = `
                    <div class="text-center py-2 bg-primary/10 text-primary border border-primary/20 rounded-xl text-xs font-semibold flex items-center justify-center gap-1.5">
                        <span class="material-symbols-outlined text-[16px]">done</span>
                        Email successfully dispatched and logged!
                    </div>
                `;
            }, 1200);
        }

        // Interactive acknowledge alert status
        function acknowledgeAlert() {
            playSwooshSound();
            const box = document.getElementById('dispatch-checklist-box');
            box.innerHTML = `
                <div class="text-center py-4 text-on-surface-variant">
                    <div class="animate-spin inline-block w-5 h-5 border-2 border-current border-t-transparent rounded-full text-error" role="status"></div>
                    <span class="text-xs ml-2 font-medium">Deploying Emergency Team...</span>
                </div>
            `;

            setTimeout(() => {
                box.innerHTML = `
                    <div class="flex flex-col items-center justify-center py-4 border border-emerald-500/30 bg-emerald-500/10 rounded-2xl gap-2 animate-fade-in">
                        <span class="material-symbols-outlined text-emerald-600 text-[36px]">verified</span>
                        <div class="text-center">
                            <p class="text-xs font-bold text-emerald-800">ALERT RESOLVED &amp; DISPATCHED</p>
                            <p class="text-[10px] text-emerald-600">Logged on ledger by concierge staff</p>
                        </div>
                    </div>
                `;
            }, 1000);
        }

        // 11. Floating Toast System
        function triggerToast(notif) {
            const container = document.getElementById('toast-container');
            const toastId = 'toast-' + notif.id;

            let icon = 'notifications';
            let iconColor = 'text-primary bg-primary-container';
            if (notif.channel.toLowerCase() === 'whatsapp') {
                icon = 'forum';
                iconColor = 'text-on-secondary-container bg-secondary-container';
            } else if (notif.channel.toLowerCase() === 'email') {
                icon = 'mail';
                iconColor = 'text-primary bg-surface-container-highest';
            } else if (notif.channel.toLowerCase() === 'alerts' || notif.channel.toLowerCase() === 'warning') {
                icon = 'warning';
                iconColor = 'text-on-error-container bg-error-container';
            }

            const toast = document.createElement('div');
            toast.id = toastId;
            toast.className = "glass-panel p-4 rounded-2xl shadow-xl border border-white/40 flex flex-col gap-3 transform translate-x-12 opacity-0 transition-all duration-500 overflow-hidden relative";
            toast.innerHTML = `
                <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full ${iconColor} flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined" style="font-size: 16px;">${icon}</span>
                    </div>
                    <div class="flex-grow">
                        <h4 class="font-bold text-xs text-primary leading-tight line-clamp-1">${notif.title}</h4>
                        <p class="text-[11px] text-on-surface-variant mt-1 leading-normal line-clamp-2">${notif.body}</p>
                    </div>
                    <button onclick="dismissToast('${toastId}')" class="text-on-surface-variant hover:text-primary transition-colors shrink-0">
                        <span class="material-symbols-outlined" style="font-size: 16px;">close</span>
                    </button>
                </div>
                <div class="flex justify-end gap-2 border-t border-outline-variant/20 pt-2 shrink-0">
                    <button onclick="viewToast('${notif.id}', '${toastId}')" class="text-secondary hover:text-primary font-bold text-[11px] transition-colors">
                        View Details
                    </button>
                </div>
                <!-- Linear auto-dismiss progress bar -->
                <div class="absolute bottom-0 left-0 h-[3px] bg-secondary" style="width: 100%; transition: width 8000ms linear;" id="${toastId}-progress"></div>
            `;

            container.appendChild(toast);

            // Animate In
            setTimeout(() => {
                toast.classList.remove('translate-x-12', 'opacity-0');
                // Trigger transition on progress bar width
                const bar = document.getElementById(`${toastId}-progress`);
                if (bar) {
                    bar.style.width = '0%';
                }
            }, 100);

            // Auto dismiss after 8 seconds
            const timeout = setTimeout(() => {
                dismissToast(toastId);
            }, 8000);

            toast.dataset.timeoutId = timeout;
        }

        function dismissToast(toastId) {
            const toast = document.getElementById(toastId);
            if (!toast) return;

            // Clear auto dismiss timer
            if (toast.dataset.timeoutId) {
                clearTimeout(toast.dataset.timeoutId);
            }

            // Animate Out
            toast.classList.add('translate-x-12', 'opacity-0');
            setTimeout(() => {
                toast.remove();
            }, 500);
        }

        function viewToast(id, toastId) {
            dismissToast(toastId);
            
            // Open drawer and trigger details view
            const drawer = document.getElementById('notifications-drawer');
            if (drawer.classList.contains('translate-x-full')) {
                toggleNotificationsDrawer();
            }
            
            // Wait slightly for drawer to load, then trigger slide details
            setTimeout(() => {
                showNotificationDetails(id);
            }, 300);
        }

        // 12. Mark All Read
        async function markAllNotificationsAsRead() {
            try {
                const response = await fetch('/operations/notifications/read-all', {
                    method: 'POST'
                });
                if (response.ok) {
                    await fetchNotifications();
                }
            } catch (error) {
                console.error("Failed to mark all read:", error);
            }
        }

        // 13. Update badge count icon
        function updateBadge() {
            const badge = document.getElementById('notifications-badge');
            const unreadCount = notificationsList.filter(n => n.status === 'Queued').length;
            
            if (unreadCount > 0) {
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        }

        // Check for new notifications every 5 seconds for snappy real-time experience
        setInterval(fetchNotifications, 5000);
        
        // Initial load
        document.addEventListener("DOMContentLoaded", fetchNotifications);
    </script>
</body>
</html>

