@{
    // Resolve user avatar dynamically in real-time
    var layoutEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
    var layoutAvatarUrl = "";
    if (!string.IsNullOrEmpty(layoutEmail))
    {
        try
        {
            var path = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "uploads", "profiles", "avatars.json");
            if (System.IO.File.Exists(path))
            {
                var text = System.IO.File.ReadAllText(path);
                var dict = System.Text.Json.JsonSerializer.Deserialize<System.Collections.Generic.Dictionary<string, string>>(text);
                if (dict != null && dict.TryGetValue(layoutEmail.ToLowerInvariant(), out var url))
                {
                    layoutAvatarUrl = url;
                }
            }
        }
        catch {}
    }
    if (string.IsNullOrEmpty(layoutAvatarUrl))
    {
        layoutAvatarUrl = User.FindFirst("AvatarUrl")?.Value ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuD5tzsdzyh_iuKmPmtlvydMcmgZuBsA2NHfDjopajkiIBzjTOsu-NapK-CnPTBAJhDiykSrzgWbwuv9bHTEkE85RL6KewvTioW0lm3Bqe-5LtX6uXQmYWuYIJc5OueC9bjv3KFzltacJwjHFQJudqygvgh7lgAiD43irizFKnvg7ZAmsP6qYABFjAra6bGvJwHE_Ay_gV_pdmavebEQp-E9PYI3uLT-dTPX52QzHgFMNfEDZoGlGqxRiF10nncKu8Zetp3tF-0ZPVAG";
    }
}
