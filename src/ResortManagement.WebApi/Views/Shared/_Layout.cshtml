<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LuxeStay SaaS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <!-- Floating Navigation Bar -->
        <aside class="side-navigation">
            <div class="brand-section">
                <div class="brand-logo">
                    <!-- Premium Crown / Hotel SVG Icon -->
                    <svg viewBox="0 0 24 24">
                        <path d="M12 2L4.5 9h15L12 2zm-7.5 9h15v10h-15V11zm7.5 3c-1.38 0-2.5 1.12-2.5 2.5s1.12 2.5 2.5 2.5 2.5-1.12 2.5-2.5-1.12-2.5-2.5-2.5z" />
                    </svg>
                </div>
                <span class="brand-name">LuxeStay</span>
            </div>

            <nav style="flex-grow: 1;">
                <ul class="nav-links">
                    <li class="nav-item">
                        <a href="/dashboard">
                            <!-- Dashboard Icon -->
                            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/bookings">
                            <!-- Booking Calendar Icon -->
                            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            <span>Bookings</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/operations/housekeeping">
                            <!-- Clean/Broom Icon -->
                            <svg viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                            <span>Housekeeping</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/operations/maintenance">
                            <!-- Tool Icon -->
                            <svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                            <span>Maintenance</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/">
                            <!-- Platform Settings Icon -->
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                            <span>Platform Home</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="user-profile-section">
                <div class="user-avatar">
                    LS
                </div>
                <div class="user-details">
                    <span class="user-name">Ibrahim Saber</span>
                    <span class="tenant-badge">Premium Plan</span>
                </div>
            </div>
        </aside>

        <!-- Main Content Workspace -->
        <main class="main-workspace">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        // Set Active Nav Link dynamically
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll(".nav-item");
        navLinks.forEach(item => {
            const link = item.querySelector("a");
            if (link && link.getAttribute("href") === currentPath) {
                item.classList.add("active");
            } else {
                item.classList.remove("active");
            }
        });
    </script>
</body>
</html>
