@{
    ViewData["Title"] = "Executive Analytics";
}

<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 4px 20px 0 rgba(0, 39, 65, 0.05);
    }
    .card-hover {
        transition: all 0.3s ease;
    }
    .card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px 0 rgba(0, 39, 65, 0.08);
        background: rgba(255, 255, 255, 0.85);
    }
    .chart-bar-primary { background-color: #0f3d5e; }
    .chart-bar-secondary { background-color: #006a66; }
    .chart-bar-tertiary { background-color: #a3caf2; }
</style>

<main class="flex-1 w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-tablet lg:px-margin-desktop pt-24 md:pt-32 pb-section-gap flex flex-col gap-8">
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 mb-8">
        <div>
            <h1 class="text-display-lg-mobile md:text-display-lg font-display-lg-mobile md:font-display-lg text-primary mb-2">Executive Analytics</h1>
            <p class="text-body-md font-body-md text-on-surface-variant">Real-time performance metrics and forecasting for your active resorts portfolio.</p>
        </div>
        <div class="flex gap-4">
            <select class="bg-surface-container-lowest border border-outline-variant/50 rounded-lg px-4 py-2 text-label-md font-label-md text-primary focus:border-secondary focus:ring-1 focus:ring-secondary/20 outline-none">
                <option>Last 30 Days</option>
                <option>This Quarter</option>
                <option>Year to Date</option>
                <option>Last Year</option>
            </select>
            <button onclick="window.print()" class="border border-secondary text-secondary px-4 py-2 rounded-lg text-label-md font-label-md hover:bg-secondary/5 transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">download</span> Export Report
            </button>
        </div>
    </div>

    <!-- Key Metrics Bento Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter mb-6">
        <!-- Metric 1 -->
        <div class="glass-panel rounded-xl p-6 flex flex-col gap-4 card-hover">
            <div class="flex justify-between items-center text-on-surface-variant">
                <span class="text-label-md font-label-md">Total Revenue</span>
                <span class="material-symbols-outlined text-primary">payments</span>
            </div>
            <div class="text-headline-lg font-headline-lg text-primary">$@String.Format("{0:N0}", ViewBag.Stats.TotalRevenue)</div>
            <div class="flex items-center gap-2 text-label-sm font-label-sm">
                <span class="text-secondary flex items-center"><span class="material-symbols-outlined text-[14px]">arrow_upward</span> 12.5%</span>
                <span class="text-outline">vs last month</span>
            </div>
        </div>

        <!-- Metric 2 -->
        <div class="glass-panel rounded-xl p-6 flex flex-col gap-4 card-hover">
            <div class="flex justify-between items-center text-on-surface-variant">
                <span class="text-label-md font-label-md">Avg. Occupancy</span>
                <span class="material-symbols-outlined text-primary">holiday_village</span>
            </div>
            <div class="text-headline-lg font-headline-lg text-primary">@ViewBag.Stats.OccupancyRate%</div>
            <div class="flex items-center gap-2 text-label-sm font-label-sm">
                <span class="text-secondary flex items-center"><span class="material-symbols-outlined text-[14px]">arrow_upward</span> 5.2%</span>
                <span class="text-outline">vs last month</span>
            </div>
        </div>

        <!-- Metric 3 -->
        <div class="glass-panel rounded-xl p-6 flex flex-col gap-4 card-hover">
            <div class="flex justify-between items-center text-on-surface-variant">
                <span class="text-label-md font-label-md">Pending Revenue</span>
                <span class="material-symbols-outlined text-primary">trending_up</span>
            </div>
            <div class="text-headline-lg font-headline-lg text-primary">$@String.Format("{0:N0}", ViewBag.Stats.PendingRevenue)</div>
            <div class="flex items-center gap-2 text-label-sm font-label-sm">
                <span class="text-secondary flex items-center"><span class="material-symbols-outlined text-[14px]">arrow_upward</span> 2.1%</span>
                <span class="text-outline">due this cycle</span>
            </div>
        </div>

        <!-- Metric 4 -->
        <div class="glass-panel rounded-xl p-6 flex flex-col gap-4 card-hover">
            <div class="flex justify-between items-center text-on-surface-variant">
                <span class="text-label-md font-label-md">New Bookings</span>
                <span class="material-symbols-outlined text-primary">calendar_month</span>
            </div>
            <div class="text-headline-lg font-headline-lg text-primary">@ViewBag.Stats.TotalReservations</div>
            <div class="flex items-center gap-2 text-label-sm font-label-sm">
                <span class="text-secondary flex items-center"><span class="material-symbols-outlined text-[14px]">arrow_upward</span> 18.4%</span>
                <span class="text-outline">vs last month</span>
            </div>
        </div>
    </section>

    <!-- Complex Charts Area -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
        <!-- Main Chart: Revenue Trends -->
        <div class="lg:col-span-2 glass-panel rounded-xl p-6 flex flex-col gap-6">
            <div class="flex justify-between items-center">
                <h2 class="text-headline-md font-headline-md text-primary">Revenue &amp; Forecasting</h2>
                <div class="flex gap-2">
                    <span class="flex items-center gap-1 text-label-sm font-label-sm text-on-surface-variant"><span class="w-3 h-3 rounded-full bg-primary-container"></span> Actual</span>
                    <span class="flex items-center gap-1 text-label-sm font-label-sm text-on-surface-variant"><span class="w-3 h-3 rounded-full border border-dashed border-secondary"></span> Forecast</span>
                </div>
            </div>

            <!-- Mock Chart Area -->
            <div class="relative h-[300px] w-full flex items-end gap-2 pb-8 px-4 border-b border-outline-variant/30">
                <!-- Y Axis Labels -->
                <div class="absolute left-0 top-0 h-full flex flex-col justify-between text-label-sm font-label-sm text-outline pb-8">
                    <span>$2M</span>
                    <span>$1.5M</span>
                    <span>$1M</span>
                    <span>$500k</span>
                    <span>$0</span>
                </div>
                <!-- Bars (Mock Data) -->
                <div class="flex-1 flex items-end justify-between ml-8 h-full">
                    <div class="w-1/12 chart-bar-primary rounded-t-sm h-[40%] group relative cursor-pointer hover:opacity-80 transition-opacity"></div>
                    <div class="w-1/12 chart-bar-primary rounded-t-sm h-[45%] group relative cursor-pointer hover:opacity-80 transition-opacity"></div>
                    <div class="w-1/12 chart-bar-primary rounded-t-sm h-[60%] group relative cursor-pointer hover:opacity-80 transition-opacity"></div>
                    <div class="w-1/12 chart-bar-primary rounded-t-sm h-[75%] group relative cursor-pointer hover:opacity-80 transition-opacity"></div>
                    <div class="w-1/12 chart-bar-primary rounded-t-sm h-[85%] group relative cursor-pointer hover:opacity-80 transition-opacity"></div>
                    <div class="w-1/12 chart-bar-primary rounded-t-sm h-[70%] group relative cursor-pointer hover:opacity-80 transition-opacity"></div>
                    <!-- Forecast Bars -->
                    <div class="w-1/12 bg-transparent border-2 border-dashed border-secondary rounded-t-sm h-[65%]"></div>
                    <div class="w-1/12 bg-transparent border-2 border-dashed border-secondary rounded-t-sm h-[80%]"></div>
                </div>
                <!-- X Axis Labels -->
                <div class="absolute bottom-0 left-8 right-4 flex justify-between text-label-sm font-label-sm text-outline">
                    <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span><span>May</span><span>Jun</span><span>Jul</span><span>Aug</span>
                </div>
            </div>
        </div>

        <!-- Side Widget: Occupancy Deep Dive -->
        <div class="glass-panel rounded-xl p-6 flex flex-col gap-6">
            <h2 class="text-headline-md font-headline-md text-primary">Occupancy by Type</h2>
            <div class="flex-grow flex flex-col justify-center gap-6">
                <!-- Progress Item -->
                <div class="flex flex-col gap-2">
                    <div class="flex justify-between text-label-md font-label-md">
                        <span class="text-on-surface">Luxury Chalets</span>
                        <span class="text-primary font-bold">92%</span>
                    </div>
                    <div class="w-full bg-surface-container-highest rounded-full h-2">
                        <div class="bg-primary h-2 rounded-full" style="width: 92%"></div>
                    </div>
                </div>
                <!-- Progress Item -->
                <div class="flex flex-col gap-2">
                    <div class="flex justify-between text-label-md font-label-md">
                        <span class="text-on-surface">Premium Suites</span>
                        <span class="text-primary font-bold">78%</span>
                    </div>
                    <div class="w-full bg-surface-container-highest rounded-full h-2">
                        <div class="bg-secondary h-2 rounded-full" style="width: 78%"></div>
                    </div>
                </div>
                <!-- Progress Item -->
                <div class="flex flex-col gap-2">
                    <div class="flex justify-between text-label-md font-label-md">
                        <span class="text-on-surface">Standard Rooms</span>
                        <span class="text-primary font-bold">64%</span>
                    </div>
                    <div class="w-full bg-surface-container-highest rounded-full h-2">
                        <div class="bg-inverse-primary h-2 rounded-full" style="width: 64%"></div>
                    </div>
                </div>
            </div>
            <div class="mt-auto pt-4 border-t border-outline-variant/30 flex justify-between items-center">
                <span class="text-label-sm font-label-sm text-outline">Updated 2h ago</span>
                <span class="text-secondary text-label-md font-label-md hover:underline cursor-pointer">View Details</span>
            </div>
        </div>
    </section>
</main>
