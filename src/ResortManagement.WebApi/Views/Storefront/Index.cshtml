                        <div class="row g-2 mb-3">
                            <div class="col">
                                <label class="form-label" data-translate-key="first_name">First Name</label>
                                <input type="text" name="firstName" class="form-control" required />
                            </div>
                            <div class="col">
                                <label class="form-label" data-translate-key="last_name">Last Name</label>
                                <input type="text" name="lastName" class="form-control" required />
