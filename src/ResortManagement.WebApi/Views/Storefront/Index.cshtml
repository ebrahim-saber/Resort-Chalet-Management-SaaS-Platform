@using ResortManagement.Domain.Entities.Resorts
@using ResortManagement.Domain.Entities.SaaS
@using static ResortManagement.WebApi.Controllers.Mvc.StorefrontController
@{
    Layout = null; // Independent clean branding storefront layout!
    var tenant = ViewBag.Tenant as Tenant;
    var availableUnits = ViewBag.AvailableUnits as List<StorefrontChaletDto> ?? new List<StorefrontChaletDto>();
    var pricingPreviews = ViewBag.PricingPreviews as Dictionary<Guid, decimal> ?? new Dictionary<Guid, decimal>();
    var checkIn = (DateTime)ViewBag.CheckIn;
    var checkOut = (DateTime)ViewBag.CheckOut;
    var guests = (int)ViewBag.Guests;
    var error = TempData["Error"] as string;
    var success = TempData["Success"] as string;
    var resortsList = ViewBag.Resorts as List<Resort> ?? new List<Resort>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(tenant?.Name ?? "LuxeStay") - Luxury Stays & Chalets</title>
    
    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <!-- Google Fonts: Outfit (English) & Cairo (Arabic) -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Cairo:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- FontAwesome & Material Symbols -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script src="/js/translation.js"></script>

    <style>
        :root {
            --bg-color: @(tenant?.DarkBgColor ?? "#030712");
            --surface-color: @(tenant?.SurfaceColor ?? "#0b0f19");
            --accent-primary: @(tenant?.PrimaryColor ?? "#cd9a5f");      /* Luxury Bronze Gold */
            --accent-secondary: @(tenant?.SecondaryColor ?? "#0ea5e9");    /* Sky Blue */
            --accent-emerald: #10b981;      /* Emerald Green */
            --text-main: #f3f4f6;
            --text-muted: #cbd5e1;
            --border-glow: color-mix(in srgb, var(--accent-primary) 15%, transparent);
            --transition-speed: 0.35s;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            overflow-x: hidden;
            background-image: 
                radial-gradient(circle at 10% 20%, color-mix(in srgb, var(--accent-primary) 5%, transparent) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(99, 102, 241, 0.04) 0%, transparent 40%);
        }

        /* Sticky Glass Header */
        .premium-nav {
            background: rgba(3, 7, 18, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
            transition: all var(--transition-speed) ease;
        }

        /* Luxury Hero Banner */
        .luxury-hero {
            position: relative;
            background: linear-gradient(rgba(3, 7, 18, 0.3), rgba(3, 7, 18, 0.85)), 
                        url('https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?q=80&w=2013&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            height: 60vh;
            min-height: 480px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            margin-bottom: -60px;
        }

        .hero-title {
            font-weight: 800;
            letter-spacing: -0.03em;
            background: linear-gradient(135deg, #ffffff 30%, #e2e8f0 70%, var(--accent-primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }

        /* Floating Modern Search Widget */
        .search-panel {
            background: rgba(11, 15, 25, 0.75);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--border-glow);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            border-radius: 24px;
            padding: 24px;
            position: relative;
            z-index: 100;
        }

        /* Input Controls Override */
        .form-label, label {
            color: var(--accent-primary) !important;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .form-control, .form-select {
            background-color: rgba(255, 255, 255, 0.04) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: #ffffff !important;
            border-radius: 12px !important;
            padding: 12px 16px;
            transition: all var(--transition-speed) ease;
        }

        .form-control:focus, .form-select:focus {
            background-color: rgba(255, 255, 255, 0.08) !important;
            border-color: var(--accent-primary) !important;
            box-shadow: 0 0 0 4px rgba(205, 154, 95, 0.15) !important;
            color: #ffffff !important;
        }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.3) !important;
        }

        /* Amenity Filters Row */
        .amenity-pill {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 100px;
            padding: 6px 16px;
            color: var(--text-muted);
            cursor: pointer;
            transition: all 0.3s ease;
            user-select: none;
        }

        .amenity-checkbox:checked + .amenity-pill {
            background: rgba(205, 154, 95, 0.12);
            border-color: var(--accent-primary);
            color: var(--text-main);
        }

        /* High-End Room Card */
        .premium-card {
            background: rgba(11, 15, 25, 0.6);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            overflow: hidden;
            height: 100%;
            transition: all var(--transition-speed) cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .premium-card:hover {
            transform: translateY(-8px);
            border-color: var(--accent-primary);
            box-shadow: 0 20px 40px rgba(205, 154, 95, 0.15);
        }

        .card-img-container {
            position: relative;
            height: 240px;
            overflow: hidden;
        }

        .card-img-premium {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
        }

        .premium-card:hover .card-img-premium {
            transform: scale(1.06);
        }

        .price-badge {
            position: absolute;
            bottom: 16px;
            right: 16px;
            background: rgba(3, 7, 18, 0.8);
            backdrop-filter: blur(8px);
            border: 1px solid var(--accent-primary);
            padding: 8px 16px;
            border-radius: 12px;
            font-weight: 700;
            color: var(--text-main);
        }

        /* Gold/Bronze luxury button */
        .btn-luxury {
            background: linear-gradient(135deg, #cd9a5f 0%, #b48146 100%);
            border: none;
            color: #030712;
            font-weight: 700;
            border-radius: 12px;
            padding: 12px 24px;
            transition: all 0.3s ease;
        }

        .btn-luxury:hover {
            background: linear-gradient(135deg, #ddaa6f 0%, #c49156 100%);
            box-shadow: 0 8px 24px rgba(205, 154, 95, 0.35);
            color: #030712;
        }

        .btn-outline-luxury {
            background: transparent;
            border: 1px solid var(--accent-primary);
            color: var(--accent-primary);
            font-weight: 600;
            border-radius: 12px;
            padding: 10px 20px;
            transition: all 0.3s ease;
        }

        .btn-outline-luxury:hover {
            background: rgba(205, 154, 95, 0.08);
            border-color: var(--accent-primary);
            color: var(--accent-primary);
        }

        /* Services Grid Section */
        .service-box {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.04);
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s ease;
        }

        .service-box:hover {
            background: rgba(205, 154, 95, 0.04);
            border-color: rgba(205, 154, 95, 0.2);
        }

        .service-icon {
            font-size: 2.2rem;
            color: var(--accent-primary);
            margin-bottom: 16px;
        }

        /* Testimonials glass container */
        .review-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            padding: 32px;
            height: 100%;
        }

        /* Fully Overhauled Checkout Modal */
        .modal-content.glass-card {
            background: rgba(8, 12, 21, 0.96) !important;
            border: 1px solid var(--accent-primary) !important;
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.8) !important;
            border-radius: 28px !important;
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
        }

        .modal-header {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding: 24px 32px;
        }

        .modal-body {
            padding: 32px;
        }

        .modal-footer {
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding: 20px 32px;
        }

        /* Interactive Credit Card Widget Styles */
        .credit-card {
            background: linear-gradient(135deg, #1e1b4b 0%, #311042 100%);
            border: 1px solid rgba(255, 255, 255, 0.15);
            position: relative;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
            border-radius: 20px;
            height: 180px;
            width: 100%;
            max-width: 320px;
            padding: 24px;
            margin: 20px auto;
            color: #ffffff;
            transition: all 0.5s ease;
        }

        .card-glow-effect {
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(205, 154, 95, 0.1) 0%, transparent 60%);
            pointer-events: none;
        }

        /* Text Overrides for visibility */
        .text-muted, .text-muted-light, .text-white-50, .text-slate-400, .form-text {
            color: #cbd5e1 !important;
        }
        /* Desktop Sticky Sidebar styling */
        @@media (min-width: 992px) {
            #sidebarFilters {
                position: sticky;
                top: 100px;
                height: fit-content;
                background: rgba(11, 15, 25, 0.65) !important;
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid rgba(255, 255, 255, 0.08) !important;
                border-radius: 20px;
                padding: 24px;
            }
        }

        /* Custom check styling for luxury theme */
        .custom-check {
            display: flex;
            align-items: center;
            gap: 8px;
            padding-left: 0 !important;
        }
        .custom-check .form-check-input {
            margin-left: 0 !important;
            margin-right: 0 !important;
            float: none !important;
            background-color: rgba(255, 255, 255, 0.05);
            border-color: rgba(255, 255, 255, 0.15);
            cursor: pointer;
            width: 1.1em;
            height: 1.1em;
        }
        .custom-check .form-check-input:checked {
            background-color: var(--accent-primary);
            border-color: var(--accent-primary);
        }
        .custom-check .form-check-input:focus {
            box-shadow: 0 0 0 4px rgba(205, 154, 95, 0.15);
            border-color: var(--accent-primary);
        }
        .custom-check .form-check-label {
            cursor: pointer;
            user-select: none;
        }

        /* RTL specific adjustments for custom checks */
        html[dir="rtl"] .custom-check {
            gap: 8px;
        }

        /* Price slider luxury style */
        .form-range::-webkit-slider-thumb {
            background: var(--accent-primary) !important;
        }
        .form-range::-moz-range-thumb {
            background: var(--accent-primary) !important;
        }
        .form-range::-ms-thumb {
            background: var(--accent-primary) !important;
        }

        /* Mobile Filters Drawer & Backdrop */
        @@media (max-width: 991px) {
            #sidebarFilters {
                position: fixed;
                top: 0;
                left: -320px;
                width: 300px;
                height: 100vh;
                z-index: 2000;
                overflow-y: auto;
                background: rgba(8, 12, 21, 0.98) !important;
                backdrop-filter: blur(30px);
                transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
                margin-top: 0 !important;
                border-right: 1px solid var(--accent-primary) !important;
                box-shadow: 20px 0 50px rgba(0, 0, 0, 0.8) !important;
                padding: 24px;
            }
            html[dir="rtl"] #sidebarFilters {
                left: auto;
                right: -320px;
                border-right: none !important;
                border-left: 1px solid var(--accent-primary) !important;
                transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            }
            html[dir="rtl"] #sidebarFilters.show {
                right: 0;
                left: auto;
            }
            #sidebarFilters.show {
                left: 0;
            }
            .filters-backdrop {
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background: rgba(0, 0, 0, 0.6);
                backdrop-filter: blur(4px);
                z-index: 1999;
                display: none;
            }
            .filters-backdrop.show {
                display: block;
            }
        }
    </style>
</head>
<body>

    <!-- Sticky Luxury Header -->
    <nav class="premium-nav py-3">
        <div class="container px-4 d-flex justify-content-between align-items-center">
            <a class="navbar-brand d-flex align-items-center gap-2" href="#">
                <img src="@(tenant?.LogoPath ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuTh4NCDpF7-t1YlTnFy2TF8frWnxjGPZ4tUgfbvb7ejk0YhJ86NeRYFDVX5vr7vQ-p7p6qL26OqZ2cofZQOAUr8XfkBiO3b9urRZYy-IwqcWTM4hxtw6XGDDcvYWTFabk3a9vpBpRG7c_MKkH1NM6fVRYIeTDsZ6A8Y6m40unqoXTtAMW0XlwhOYyl-Xq8nDNVMh_8i_V9SaB8ncgbp2Vw3Hdv1lHdoHg7vl26C8NREzdXke29miyRmTb1RuLrP9tPeB0MiDNne9K7")" 
                     alt="Logo" style="height: 34px; border-radius: 6px;" />
                <span class="font-weight-bold text-white tracking-wide fs-4">@(tenant?.Name ?? "LuxeStay")</span>
            </a>
            
            <div class="d-flex align-items-center gap-3">
                <!-- Language Toggle Selector -->
                <button onclick="toggleLanguage()" class="btn btn-outline-luxury btn-sm d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">translate</span>
                    <span id="lang-indicator">العربية</span>
                </button>
                <a href="/" data-translate-key="staff_login" class="btn btn-luxury btn-sm px-4">Staff Login</a>
            </div>
        </div>
    </nav>

    <!-- Immersive Hero Section -->
    <header class="luxury-hero">
        <div class="container px-4 text-center">
            <span class="badge rounded-pill bg-dark border border-warning text-warning px-3 py-2 mb-3 tracking-wider uppercase small" data-translate-key="luxury_chalet_stays">Luxury Chalet Stays</span>
            <h1 class="display-3 hero-title" id="storefront-welcome-title" 
                data-welcome-en="@(tenant?.WelcomeMessageEn ?? "Find Your Ultimate Mountain Hideaway")" 
                data-welcome-ar="@(tenant?.WelcomeMessageAr ?? "ابحث عن ملاذك الجبلي المثالي")"
                data-translate-key="find_mountain_hideaway">Find Your Ultimate Mountain Hideaway</h1>
            <p class="max-w-xl mx-auto mt-3 fs-5" data-translate-key="browse_luxury_spaces" style="color: #cbd5e1;">Browse luxury spaces, review pricing, and book your stay instantly.</p>
        </div>
    </header>

    <!-- Main Container -->
    <main class="container py-5 px-4" style="margin-top: -60px;">
        
        <!-- Booking Alert status messages -->
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger glass-card text-white border-danger rounded-3 mb-4 p-3" role="alert">
                <i class="fas fa-exclamation-circle me-2 text-danger"></i>@error
            </div>
        }
        @if (!string.IsNullOrEmpty(success))
        {
            <div class="alert alert-success glass-card text-white border-success rounded-3 mb-4 p-3" role="alert">
                <i class="fas fa-check-circle me-2 text-success"></i>@success
            </div>
        }

        <!-- Backdrop for Mobile Filters -->
        <div class="filters-backdrop" id="filtersBackdrop"></div>

        <div class="row g-4 position-relative">
            <!-- Mobile Toggle Button -->
            <div class="col-12 d-lg-none mb-2">
                <button class="btn btn-luxury w-100 py-3 d-flex align-items-center justify-content-center gap-2" onclick="toggleMobileFilters()">
                    <span class="material-symbols-outlined">filter_list</span>
                    <span data-translate-key="show_filters">Show Filters</span>
                </button>
            </div>

            <!-- Left Column: Filters Sidebar -->
            <aside class="col-lg-3 mb-4" id="sidebarFilters">
                <!-- Sidebar Header with Close Button for Mobile -->
                <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
                    <h5 class="font-weight-bold text-white mb-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-warning">filter_list</span>
                        <span data-translate-key="filters">Filters</span>
                    </h5>
                    <div class="d-flex align-items-center gap-2">
                        <button onclick="resetAllFilters()" class="btn btn-link text-warning text-decoration-none p-0 small" data-translate-key="reset_all" style="font-size: 0.85rem;">Reset All</button>
                        <button class="btn-close btn-close-white d-lg-none" onclick="toggleMobileFilters()" aria-label="Close"></button>
                    </div>
                </div>

                <!-- Server Side Form for Dates & Guests -->
                <form method="get" action="/storefront" class="d-flex flex-column gap-3 mb-4">
                    <div>
                        <label class="form-label" data-translate-key="arrival_date">Arrival Date</label>
                        <input type="date" name="checkIn" value="@checkIn.ToString("yyyy-MM-dd")" class="form-control" required />
                    </div>
                    <div>
                        <label class="form-label" data-translate-key="departure_date">Departure Date</label>
                        <input type="date" name="checkOut" value="@checkOut.ToString("yyyy-MM-dd")" class="form-control" required />
                    </div>
                    <div>
                        <label class="form-label" data-translate-key="guests">Guests</label>
                        <select name="guestsCount" class="form-select">
                            <!option value="1" @(guests == 1 ? "selected" : "")>1 Guest</!option>
                            <!option value="2" @(guests == 2 ? "selected" : "")>2 Guests</!option>
                            <!option value="4" @(guests == 4 ? "selected" : "")>4 Guests</!option>
                            <!option value="6" @(guests == 6 ? "selected" : "")>6 Guests</!option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-luxury w-100 py-2.5 mt-2" data-translate-key="update_search">Update Search</button>
                </form>

                <!-- Location Filter (Client Side) -->
                @if (resortsList.Any())
                {
                    <div class="mb-4 pt-3 border-top border-secondary border-opacity-25">
                        <label class="form-label" data-translate-key="resorts">Resorts</label>
                        <div class="d-flex flex-column gap-2 mt-2">
                            @foreach (var resort in resortsList)
                            {
                                <div class="form-check custom-check">
                                    <input class="form-check-input resort-checkbox" type="checkbox" id="resort-@resort.Id" value="@resort.Name" checked onchange="filterRooms()">
                                    <label class="form-check-label text-white small" for="resort-@resort.Id">
                                        @resort.Name
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Price Range Filter (Client Side) -->
                <div class="mb-4 pt-3 border-top border-secondary border-opacity-25">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label mb-0" data-translate-key="max_nightly_price">Max Nightly Price</label>
                        <span class="badge bg-dark border border-warning text-warning px-2 py-1 font-monospace" id="priceDisplay">$3,000</span>
                    </div>
                    <input type="range" class="form-range" id="priceRange" min="100" max="3000" step="50" value="3000" oninput="updatePriceFilter(this.value)">
                    <div class="d-flex justify-content-between text-white-50 font-monospace" style="font-size: 0.75rem;">
                        <span>$100</span>
                        <span>$3,000</span>
                    </div>
                </div>

                <!-- Amenities Filter (Client Side) -->
                <div class="pt-3 border-top border-secondary border-opacity-25">
                    <label class="form-label" data-translate-key="included_amenities">Included Amenities</label>
                    <div class="d-flex flex-column gap-2 mt-2">
                        <div class="form-check custom-check">
                            <input class="form-check-input amenity-checkbox" type="checkbox" id="filter-wifi" value="wifi" onchange="filterRooms()">
                            <label class="form-check-label text-white small" for="filter-wifi">
                                WiFi
                            </label>
                        </div>
                        <div class="form-check custom-check">
                            <input class="form-check-input amenity-checkbox" type="checkbox" id="filter-hottub" value="hot-tub" onchange="filterRooms()">
                            <label class="form-check-label text-white small" for="filter-hottub">
                                Hot Tub
                            </label>
                        </div>
                        <div class="form-check custom-check">
                            <input class="form-check-input amenity-checkbox" type="checkbox" id="filter-fireplace" value="fireplace" onchange="filterRooms()">
                            <label class="form-check-label text-white small" for="filter-fireplace">
                                Fireplace
                            </label>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Right Column: Room Catalog Grid -->
            <div class="col-lg-9">
                <h3 class="font-weight-bold text-white mb-4"><span data-translate-key="available_premium_properties">Available Premium Properties</span> (@availableUnits.Count)</h3>

                <!-- Client-side filter Empty State (Hidden by default) -->
                <div id="empty-state" style="display: none;" class="bg-dark bg-opacity-40 border border-secondary border-opacity-25 rounded-4 p-5 text-center text-muted flex-column align-items-center justify-content-center w-100 my-4">
                    <span class="material-symbols-outlined text-[48px] text-warning mb-3">filter_list_off</span>
                    <h4 class="text-white font-weight-bold" data-translate-key="no_chalets_available">No chalets available</h4>
                    <p class="text-muted-light mb-0" data-translate-key="try_expanding_dates">Try expanding your check-in dates or choosing a smaller group configuration.</p>
                </div>

                <div class="row g-4 mb-5" id="roomsGrid">
                    @if (!availableUnits.Any())
                    {
                        <div class="col-12 text-center py-5">
                            <div class="glass-card rounded-4 p-5 max-w-lg mx-auto">
                                <span class="material-symbols-outlined text-[48px] text-muted mb-3">hotel</span>
                                <h5 class="text-white font-weight-bold" data-translate-key="no_chalets_available">No chalets available</h5>
                                <p class="text-muted-light mb-0" data-translate-key="try_expanding_dates">Try expanding your check-in dates or choosing a smaller group configuration.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var unit in availableUnits)
                        {
                            var totalPrice = pricingPreviews[unit.Id];
                            var imgPath = "/images/luxury_mountain_chalet.png";
                            var amenitiesList = "wifi,hot-tub,fireplace";
                            var isWifi = true;
                            var isHottub = true;
                            var isFireplace = true;
                            var desc = "Expansive pool chalet complete with custom architectural trims, private terrace, and premium finishes.";

                            if (unit.Name.Contains("Suite", StringComparison.OrdinalIgnoreCase))
                            {
                                imgPath = "/images/boutique_suite.png";
                                amenitiesList = "wifi,fireplace";
                                isHottub = false;
                                desc = "Cozy luxury boutique suite featuring a modern fireplace, elegant workspace, and premium linens.";
                            }
                            else if (unit.Name.Contains("Villa", StringComparison.OrdinalIgnoreCase) || unit.Name.Contains("104"))
                            {
                                imgPath = "/images/sea_villa.png";
                                amenitiesList = "wifi,hot-tub";
                                isFireplace = false;
                                desc = "Stunning sea villa overlooking the coast, equipped with an infinity pool and private balcony.";
                            }
                            else
                            {
                                imgPath = "/images/chalet_pool.png";
                            }

                            <div class="col-12 col-md-6 room-card-container" data-resort="@unit.ResortName" data-amenities="@amenitiesList" data-price-per-night="@((totalPrice / (checkOut - checkIn).Days).ToString("F0"))">
                                <div class="premium-card d-flex flex-column h-100">
                                    <!-- Image wrapper with status dot & guest capacity -->
                                    <div class="card-img-container">
                                        <img src="@imgPath" class="card-img-premium" alt="Chalet Photo" />
                                        
                                        <!-- Top Right Available Status Badge -->
                                        <div class="position-absolute top-0 end-0 m-3 badge text-white py-2 px-3 rounded-pill d-flex align-items-center gap-1 shadow-sm font-semibold" style="background-color: var(--accent-emerald) !important;">
                                            <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
                                            <span data-translate-key="available">Available</span>
                                        </div>

                                        <!-- Top Left Capacity Badge -->
                                        <div class="position-absolute top-0 start-0 m-3 badge bg-dark bg-opacity-75 text-white py-2 px-3 border border-secondary border-opacity-25 rounded-pill">
                                            <i class="fas fa-users me-1 text-warning"></i>
                                            <span data-translate-key="max_capacity_guests" data-param-count="@unit.MaxCapacity">Max @unit.MaxCapacity Guests</span>
                                        </div>
                                    </div>

                                    <!-- Content details -->
                                    <div class="p-4 d-flex flex-column flex-grow-1 justify-content-between">
                                        <div>
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <span class="text-warning font-weight-semibold small uppercase tracking-wider">@unit.ResortName</span>
                                                    <h4 class="font-weight-bold mt-1 text-white">@unit.Name</h4>
                                                </div>
                                                <div class="text-end">
                                                    <div class="fs-4 font-weight-bold text-white">@((totalPrice / (checkOut - checkIn).Days).ToString("C"))</div>
                                                    <div class="small text-white-50">/ Night</div>
                                                </div>
                                            </div>
                                            
                                            <p class="small my-3 text-muted" style="min-height: 48px; line-height: 1.5;">@desc</p>
                                            
                                            <div class="d-flex flex-wrap gap-2 mb-4">
                                                @if (isWifi)
                                                {
                                                    <span class="badge bg-dark bg-opacity-50 text-muted border border-secondary border-opacity-25 rounded-pill py-1.5 px-3 small"><i class="fas fa-wifi text-warning me-1"></i><span data-translate-key="free_wifi">Free WiFi</span></span>
                                                }
                                                @if (isHottub)
                                                {
                                                    <span class="badge bg-dark bg-opacity-50 text-muted border border-secondary border-opacity-25 rounded-pill py-1.5 px-3 small"><i class="fas fa-snowflake text-warning me-1"></i><span data-translate-key="hot_tub">Hot Tub</span></span>
                                                }
                                                @if (isFireplace)
                                                {
                                                    <span class="badge bg-dark bg-opacity-50 text-muted border border-secondary border-opacity-25 rounded-pill py-1.5 px-3 small"><i class="fas fa-fireplace text-warning me-1"></i><span data-translate-key="fireplace">Fireplace</span></span>
                                                }
                                            </div>
                                        </div>

                                        <!-- Card footer stay total with details trigger -->
                                        <div class="pt-3 border-top border-secondary border-opacity-25 mt-auto">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <div>
                                                    <div class="small text-muted" data-translate-key="stay_value">Stay Value</div>
                                                    <div class="fs-4 font-weight-bold text-warning">@totalPrice.ToString("C")</div>
                                                </div>
                                                <div class="text-end text-white-50" style="font-size: 0.75rem;" data-translate-key="for_nights_stay" data-param-count="@((checkOut - checkIn).Days)">For @((checkOut - checkIn).Days) nights stay</div>
                                            </div>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-outline-luxury flex-fill py-2.5 text-sm" data-translate-key="view_details" 
                                                        onclick="triggerDetails('@unit.Id', '@unit.Name', @unit.BasePrice, @unit.MaxCapacity, '@unit.ResortName', '@unit.BuildingName', `@desc`, '@amenitiesList', '@imgPath')">Details</button>
                                                <button class="btn btn-luxury flex-fill py-2.5 text-sm" data-translate-key="book_now" 
                                                        onclick="triggerCheckout('@unit.Id', '@unit.Name', '@totalPrice.ToString("C")')">Book Now</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Premium Why Stay With Us section -->
        <section class="py-5 border-top border-secondary border-opacity-25">
            <div class="text-center mb-5">
                <span class="text-warning small uppercase tracking-wider fw-bold">Unparalleled Luxury</span>
                <h2 class="display-6 font-weight-bold text-white mt-1">Exclusive Signature Services</h2>
            </div>
            
            <div class="row g-4">
