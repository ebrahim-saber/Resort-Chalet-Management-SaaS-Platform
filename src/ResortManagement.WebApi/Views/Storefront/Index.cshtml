    <!-- Bootstrap Script -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Seasons & Rules Data dynamically serialized from database for real-time client-side calculation
        const seasons = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SeasonsList));
        const pricingRules = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PricingRulesList));

        let activeUnitId = "";
        let activeBasePrice = 0;
        let activeUnitName = "";

        function triggerCheckout(unitId, unitName, price) {
            document.getElementById('modalUnitId').value = unitId;
            document.getElementById('modalRoomName').innerText = unitName;
            document.getElementById('modalTotalPrice').innerText = price;
            
            var checkoutModal = new bootstrap.Modal(document.getElementById('checkoutModal'));
            checkoutModal.show();
        }

        function triggerDetails(unitId, unitName, basePrice, capacity, resortName, buildingName, desc, amenitiesList, imgPath) {
            activeUnitId = unitId;
            activeBasePrice = basePrice;
            activeUnitName = unitName;

            document.getElementById('detailChaletName').innerText = unitName;
            document.getElementById('detailRoomTitle').innerText = unitName;
            document.getElementById('detailResortName').innerText = resortName;
            document.getElementById('detailBuildingName').innerText = buildingName;
            document.getElementById('detailCapacity').innerText = "Max " + capacity + " Guests";
            document.getElementById('detailDescription').innerText = desc;
            document.getElementById('detailChaletImg').src = imgPath;

            // Pre-populate calculator with current search dates
            const checkInVal = document.querySelector('input[name="checkIn"]').value;
            const checkOutVal = document.querySelector('input[name="checkOut"]').value;
            document.getElementById('calcCheckIn').value = checkInVal;
            document.getElementById('calcCheckOut').value = checkOutVal;

            // Generate amenities badges
            const container = document.getElementById('detailAmenitiesContainer');
            container.innerHTML = '';
            amenitiesList.split(',').forEach(am => {
                const badge = document.createElement('span');
                badge.className = 'badge bg-dark bg-opacity-50 text-white border border-secondary border-opacity-25 rounded-pill py-2 px-3 small';
                
                let iconClass = 'fa-wifi';
                let label = am;
                if (am === 'wifi') { iconClass = 'fa-wifi'; label = 'Free WiFi'; badge.setAttribute('data-translate-key', 'free_wifi'); }
                else if (am === 'hot-tub') { iconClass = 'fa-snowflake'; label = 'Hot Tub'; badge.setAttribute('data-translate-key', 'hot_tub'); }
                else if (am === 'fireplace') { iconClass = 'fa-fireplace'; label = 'Fireplace'; badge.setAttribute('data-translate-key', 'fireplace'); }
                
                badge.innerHTML = `<i class="fas ${iconClass} text-warning me-2"></i>${label}`;
                container.appendChild(badge);
            });

            recalculateModalCost();

            // Hook checkout transition
            document.getElementById('btnProceedToCheckout').onclick = function() {
                const finalCheckIn = document.getElementById('calcCheckIn').value;
                const finalCheckOut = document.getElementById('calcCheckOut').value;
                
                document.querySelector('#checkoutForm input[name="checkIn"]').value = finalCheckIn;
                document.querySelector('#checkoutForm input[name="checkOut"]').value = finalCheckOut;
                
                // Hide details modal and launch checkout
                const dModal = bootstrap.Modal.getInstance(document.getElementById('detailsModal'));
                dModal.hide();
                
                const finalPrice = document.getElementById('calcTotalPrice').innerText;
                triggerCheckout(activeUnitId, activeUnitName, finalPrice);
            };

            // Call client-side translation engine to translate modal
            if (window.applyTranslation) window.applyTranslation();

            var detailsModal = new bootstrap.Modal(document.getElementById('detailsModal'));
            detailsModal.show();
        }

        function recalculateModalCost() {
            const checkInStr = document.getElementById('calcCheckIn').value;
            const checkOutStr = document.getElementById('calcCheckOut').value;
            
            if (!checkInStr || !checkOutStr) return;
            
            const start = new Date(checkInStr);
            const end = new Date(checkOutStr);
            
            if (end <= start) {
                document.getElementById('calcTotalPrice').innerText = "$0.00";
                return;
            }

            let totalPrice = 0;
            
            for (let d = new Date(start); d < end; d.setDate(d.getDate() + 1)) {
                let nightPrice = activeBasePrice;
                
                // 1. Season multiplier check
                const activeSeason = seasons.find(s => {
                    const sStart = new Date(s.StartDate || s.startDate);
                    const sEnd = new Date(s.EndDate || s.endDate);
                    return d >= sStart && d <= sEnd;
                });
                
                if (activeSeason) {
                    nightPrice *= (activeSeason.PriceMultiplier || activeSeason.priceMultiplier || 1);
                }
                
                // 2. Weekend rules check
                const isWeekend = d.getDay() === 5 || d.getDay() === 6; // Friday, Saturday
                if (isWeekend) {
                    const weekendRule = pricingRules.find(r => (r.RuleType || r.ruleType) === 'Weekend');
                    if (weekendRule) {
                        const mult = weekendRule.Multiplier !== undefined ? weekendRule.Multiplier : weekendRule.multiplier;
                        const flat = weekendRule.FlatAmount !== undefined ? weekendRule.FlatAmount : weekendRule.flatAmount;
                        if (mult) {
                            nightPrice *= mult;
                        } else if (flat) {
                            nightPrice += flat;
                        }
                    }
                }
                
                totalPrice += nightPrice;
            }

            document.getElementById('calcTotalPrice').innerText = totalPrice.toLocaleString('en-US', { style: 'currency', currency: 'USD' });
        }

        function updatePriceFilter(val) {
            document.getElementById('priceDisplay').innerText = '$' + parseInt(val).toLocaleString();
            filterRooms();
        }

        // Real-time Credit Card synchronization
        document.addEventListener("DOMContentLoaded", function() {
            const numberInput = document.getElementById('input-card-number');
            if (numberInput) {
                numberInput.addEventListener('input', function(e) {
                    let val = e.target.value.replace(/\D/g, '');
                    let formatted = val.match(/.{1,4}/g)?.join(' ') || '';
                    e.target.value = formatted;
                    
                    document.getElementById('display-card-number').innerText = formatted || '•••• •••• •••• ••••';
                    
                    const icon = document.getElementById('card-type-icon');
                    if (val.startsWith('4')) {
                        icon.className = 'fab fa-cc-visa fa-2x text-white';
                    } else if (val.startsWith('5')) {
                        icon.className = 'fab fa-cc-mastercard fa-2x text-white';
                    } else {
                        icon.className = 'fas fa-credit-card fa-2x text-white';
                    }
                });
            }

            const firstNameInput = document.querySelector('input[name="firstName"]');
            const lastNameInput = document.querySelector('input[name="lastName"]');
            function updateCardName() {
                const first = firstNameInput?.value || '';
                const last = lastNameInput?.value || '';
                const fullName = (first + ' ' + last).trim().toUpperCase();
                document.getElementById('display-card-name').innerText = fullName || 'GUEST CUSTOMER';
            }
            if (firstNameInput) firstNameInput.addEventListener('input', updateCardName);
            if (lastNameInput) lastNameInput.addEventListener('input', updateCardName);

            const expiryInput = document.getElementById('input-card-expiry');
            if (expiryInput) {
                expiryInput.addEventListener('input', function(e) {
                    let val = e.target.value.replace(/\D/g, '');
                    if (val.length > 2) {
                        val = val.substring(0, 2) + '/' + val.substring(2, 4);
                    }
                    e.target.value = val;
                    document.getElementById('display-card-expiry').innerText = val || 'MM/YY';
                });
            }
        });

        // Client-side mobile filters toggler
        function toggleMobileFilters() {
            const sidebar = document.getElementById('sidebarFilters');
            const backdrop = document.getElementById('filtersBackdrop');
            if (sidebar && backdrop) {
                sidebar.classList.toggle('show');
                backdrop.classList.toggle('show');
            }
        }

        // Close mobile filters when clicking outside on the backdrop
        document.addEventListener("DOMContentLoaded", function() {
            const backdrop = document.getElementById('filtersBackdrop');
            if (backdrop) {
                backdrop.addEventListener('click', toggleMobileFilters);
            }
        });

        // Reset all client-side filters
        function resetAllFilters() {
            // Reset amenities
            document.getElementById('filter-wifi').checked = false;
            document.getElementById('filter-hottub').checked = false;
            document.getElementById('filter-fireplace').checked = false;

            // Reset price
            const priceSlider = document.getElementById('priceRange');
            if (priceSlider) {
                priceSlider.value = 3000;
                updatePriceFilter(3000);
            }

            // Reset resorts checkboxes
            document.querySelectorAll('.resort-checkbox').forEach(cb => {
                cb.checked = true;
            });

            filterRooms();
        }

        // Client-side filter logic for amenities, resort & price slider
        function filterRooms() {
            const hasWifi = document.getElementById('filter-wifi').checked;
            const hasHottub = document.getElementById('filter-hottub').checked;
            const hasFireplace = document.getElementById('filter-fireplace').checked;
            const maxPrice = parseFloat(document.getElementById('priceRange').value);

            // Selected resorts list
            const checkedResorts = [];
            document.querySelectorAll('.resort-checkbox:checked').forEach(cb => {
                checkedResorts.push(cb.value);
            });

            let visibleCount = 0;

            document.querySelectorAll('.room-card-container').forEach(card => {
                const cardAmenities = card.getAttribute('data-amenities').split(',');
                const cardPrice = parseFloat(card.getAttribute('data-price-per-night'));
                const cardResort = card.getAttribute('data-resort');
                
                let visible = true;
                if (hasWifi && !cardAmenities.includes('wifi')) visible = false;
                if (hasHottub && !cardAmenities.includes('hot-tub')) visible = false;
                if (hasFireplace && !cardAmenities.includes('fireplace')) visible = false;
                if (cardPrice > maxPrice) visible = false;
                if (checkedResorts.length > 0 && !checkedResorts.includes(cardResort)) visible = false;

                if (visible) {
                    card.style.setProperty('display', 'block', 'important');
                    visibleCount++;
                } else {
                    card.style.setProperty('display', 'none', 'important');
                }
            });

            // Show or hide the empty state
            const emptyState = document.getElementById('empty-state');
            if (emptyState) {
                emptyState.style.display = (visibleCount === 0) ? 'flex' : 'none';
            }
        }
    </script>
</body>
</html>



