    <!-- Checkout Modal Dialog -->
    <div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-card text-white border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title font-weight-bold text-white d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-warning">shopping_bag</span>
                        <span data-translate-key="guest_self_checkout">Guest Self Checkout</span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="checkoutForm" method="post" action="/storefront/book">
                        <input type="hidden" id="modalUnitId" name="unitId" />
                        <input type="hidden" name="checkIn" value="@checkIn.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="checkOut" value="@checkOut.ToString("yyyy-MM-dd")" />

                        <div class="bg-dark bg-opacity-50 border border-secondary border-opacity-25 rounded-3 p-3 mb-4">
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-white-50" data-translate-key="selected_chalet">Selected Chalet:</span>
                                <span class="text-white font-weight-bold" id="modalRoomName">Suite 101</span>
                            </div>
                            <div class="d-flex justify-content-between small">
                                <span class="text-white-50" data-translate-key="est_gross_total">Est. Gross Total:</span>
                                <span class="text-warning font-weight-bold" id="modalTotalPrice">$0.00</span>
                            </div>
                        </div>

                        <!-- Guest Info -->
