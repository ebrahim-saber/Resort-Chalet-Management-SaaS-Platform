                                <div class="card-glow-effect"></div>
                                <div class="d-flex justify-content-between align-items-start mb-4">
                                    <div class="chip rounded-2" style="width: 45px; height: 32px; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);"></div>
                                    <i class="fab fa-cc-visa fa-2x text-white" id="card-type-icon" style="opacity: 0.85;"></i>
                                </div>
                                <div class="card-number font-monospace fs-5 tracking-widest mb-3" id="display-card-number">•••• •••• •••• ••••</div>
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <div class="text-white-50" style="font-size: 0.65rem; text-transform: uppercase;">Card Holder</div>
                                        <div class="small font-monospace text-white" id="display-card-name">GUEST CUSTOMER</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="text-white-50" style="font-size: 0.65rem; text-transform: uppercase;">Expires</div>
                                        <div class="small font-monospace text-white" id="display-card-expiry">MM/YY</div>
