@using ResortManagement.Domain.Entities.Resorts
@using ResortManagement.Domain.Entities.SaaS
@using static ResortManagement.WebApi.Controllers.Mvc.StorefrontController
@{
    Layout = null; // Independent clean branding storefront layout!
    var tenant = ViewBag.Tenant as Tenant;
    var availableUnits = ViewBag.AvailableUnits as List<StorefrontChaletDto> ?? new List<StorefrontChaletDto>();
    var pricingPreviews = ViewBag.PricingPreviews as Dictionary<Guid, decimal> ?? new Dictionary<Guid, decimal>();
    var checkIn = (DateTime)ViewBag.CheckIn;
    var checkOut = (DateTime)ViewBag.CheckOut;
    var guests = (int)ViewBag.Guests;
    var error = TempData["Error"] as string;
    var success = TempData["Success"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LuxeStay - Public Booking Catalog</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #090d16 0%, #111827 100%);
            color: #f3f4f6;
            min-height: 100vh;
        }
        .text-primary-accent {
            color: #6366f1 !important;
        }
        .bg-primary-accent {
            background-color: #6366f1 !important;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }
        .hero-section {
            background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.75)), url('https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?q=80&w=2013&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            padding: 80px 0;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }
        .room-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .room-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 40px rgba(99, 102, 241, 0.25) !important;
        }
        .room-img-wrapper {
            position: relative;
            height: 220px;
            overflow: hidden;
        }
        .room-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .room-card:hover .room-img {
            transform: scale(1.05);
        }
    </style>
</head>
<body>

    <!-- Storefront Header Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-transparent border-bottom border-secondary border-opacity-25 py-3">
        <div class="container px-4">
            <a class="navbar-brand d-flex align-items-center gap-2" href="#">
                <img src="@(tenant?.LogoPath ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuATh4NCDpF7-t1YlTnFy2TF8frWnxjGPZ4tUgfbvb7ejk0YhJ86NeRYFDVX5vr7vQ-p7p6qL26OqZ2cofZQOAUr8XfkBiO3b9urRZYy-IwqcWTM4hxtw6XGDDcvYWTFabk3a9vpBpRG7c_MKkH1NM6fVRYIeTDsZ6A8Y6m40unqoXTtAMW0XlwhOYyl-Xq8nDNVMh_8i_V9SaB8ncgbp2Vw3Hdv1lHdoHg7vl26C8NREzdXke29miyRmTb1RuLrP9tPeB0MiDNne9K7")" 
                     alt="Logo" style="height: 32px; border-radius: 4px;" />
                <span class="font-weight-bold text-white tracking-wide">@(tenant?.Name ?? "LuxeStay")</span>
            </a>
            <div class="ms-auto">
                <a href="/" class="btn btn-outline-light rounded-pill px-4 btn-sm">Staff Login</a>
            </div>
        </div>
    </nav>

    <!-- Hero Header -->
    <header class="hero-section">
        <div class="container px-4">
            <span class="badge bg-primary-accent rounded-pill px-3 py-2 mb-3 tracking-wider uppercase small">Luxury Chalet Stays</span>
            <h1 class="display-5 font-weight-bold text-white">Find Your Ultimate Mountain Hideaway</h1>
            <p class="text-muted-light max-w-xl mx-auto mt-2 mb-0">Browse luxury spaces, review pricing, and book your stay instantly.</p>
        </div>
    </header>

    <!-- Content Catalog Grid -->
    <main class="container py-5 px-4">
        
        <!-- Booking Alert status messages -->
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger glass-card text-white border-danger rounded-3 mb-4 p-3" role="alert">
                <i class="fas fa-exclamation-circle me-2 text-danger"></i>@error
            </div>
        }
        @if (!string.IsNullOrEmpty(success))
        {
            <div class="alert alert-success glass-card text-white border-success rounded-3 mb-4 p-3" role="alert">
                <i class="fas fa-check-circle me-2 text-success"></i>@success
            </div>
        }

        <!-- Live Search Widget -->
        <section class="glass-card rounded-4 p-4 mb-5">
            <h5 class="font-weight-bold text-white mb-3"><i class="fas fa-search me-2 text-primary-accent"></i>Check Room Availability</h5>
            <form method="get" action="/storefront" class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label small text-muted">Arrival Date</label>
                    <input type="date" name="checkIn" value="@checkIn.ToString("yyyy-MM-dd")" class="form-control bg-dark border-secondary text-white rounded-pill px-3" required />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label small text-muted">Departure Date</label>
                    <input type="date" name="checkOut" value="@checkOut.ToString("yyyy-MM-dd")" class="form-control bg-dark border-secondary text-white rounded-pill px-3" required />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label small text-muted">Guests</label>
                    <select name="guestsCount" class="form-select bg-dark border-secondary text-white rounded-pill px-3">
                        <!option value="1" @(guests == 1 ? "selected" : "")>1 Guest</!option>
                        <!option value="2" @(guests == 2 ? "selected" : "")>2 Guests</!option>
                        <!option value="4" @(guests == 4 ? "selected" : "")>4 Guests</!option>
                        <!option value="6" @(guests == 6 ? "selected" : "")>6 Guests</!option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <button type="submit" class="btn btn-primary-accent rounded-pill w-100 py-2 font-weight-semibold">Update Search</button>
                </div>
            </form>
        </section>

        <!-- Rooms Catalog Grid -->
        <h4 class="font-weight-bold text-white mb-4">Available Premium Properties (@availableUnits.Count)</h4>
        <div class="row g-4">
            @if (!availableUnits.Any())
            {
                <div class="col-12 text-center py-5">
                    <div class="glass-card rounded-4 p-5 max-w-lg mx-auto">
                        <i class="fas fa-bed fa-3x text-muted mb-3"></i>
                        <h5 class="text-white font-weight-bold">No chalets available</h5>
                        <p class="text-muted-light mb-0">Try expanding your check-in dates or choosing a smaller group configuration.</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var unit in availableUnits)
                {
                    var totalPrice = pricingPreviews[unit.Id];
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card bg-transparent glass-card border-secondary border-opacity-25 h-100 overflow-hidden room-card d-flex flex-column justify-content-between">
                            <div>
                                <!-- Room Image Wrapper -->
                                <div class="room-img-wrapper">
                                    <img src="https://images.unsplash.com/photo-1518780664697-55e3ad937233?q=80&w=1000&auto=format&fit=crop" 
                                         class="room-img" alt="Chalet Photo" />
                                    <div class="position-absolute top-0 end-0 m-3 badge bg-dark bg-opacity-75 text-white py-2 px-3 border border-secondary border-opacity-25 rounded-pill">
                                        <i class="fas fa-users me-1 text-primary-accent"></i>Max @unit.MaxCapacity Guests
                                    </div>
                                </div>

                                <!-- Room Content Details -->
                                <div class="card-body p-4 text-white">
                                    <span class="text-primary-accent font-weight-semibold small uppercase tracking-wider">@unit.ResortName</span>
                                    <h4 class="card-title font-weight-bold mt-1 text-white">@unit.Name</h4>
                                    <p class="text-muted-light small mb-3">Expansive suite located in the @unit.BuildingName Wing, complete with custom architectural trims, mountain view terrace, and custom linens.</p>
                                    
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        <span class="badge bg-dark bg-opacity-50 text-muted-light border border-secondary border-opacity-25 rounded-pill small"><i class="fas fa-wifi text-primary-accent me-1"></i>Free WiFi</span>
                                        <span class="badge bg-dark bg-opacity-50 text-muted-light border border-secondary border-opacity-25 rounded-pill small"><i class="fas fa-snowflake text-primary-accent me-1"></i>Hot Tub</span>
                                        <span class="badge bg-dark bg-opacity-50 text-muted-light border border-secondary border-opacity-25 rounded-pill small"><i class="fas fa-fireplace text-primary-accent me-1"></i>Fireplace</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Footer Section with checkout trigger -->
                            <div class="card-footer bg-transparent border-top border-secondary border-opacity-25 p-4 d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="small text-muted">Stay Value</div>
                                    <div class="fs-4 font-weight-bold text-emerald text-white">@totalPrice.ToString("C")</div>
                                    <div class="text-muted-light" style="font-size: 0.7rem;">For @((checkOut - checkIn).Days) nights stay</div>
                                </div>
                                <button class="btn btn-primary-accent rounded-pill px-4 font-weight-semibold" 
                                        onclick="triggerCheckout('@unit.Id', '@unit.Name', '@totalPrice.ToString("C")')">Book Now</button>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </main>

    <!-- Checkout Modal Dialog -->
    <div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-card text-white border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title font-weight-bold"><i class="fas fa-credit-card me-2 text-primary-accent"></i>Guest Self Checkout</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="checkoutForm" method="post" action="/storefront/book">
                        <input type="hidden" id="modalUnitId" name="unitId" />
                        <input type="hidden" name="checkIn" value="@checkIn.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="checkOut" value="@checkOut.ToString("yyyy-MM-dd")" />

                        <div class="bg-dark bg-opacity-50 border border-secondary border-opacity-25 rounded-3 p-3 mb-4">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Selected Chalet:</span>
                                <span class="text-white font-weight-bold" id="modalRoomName">Suite 101</span>
                            </div>
                            <div class="d-flex justify-content-between small text-muted">
                                <span>Est. Gross Total:</span>
                                <span class="text-white font-weight-bold text-primary-accent" id="modalTotalPrice">$0.00</span>
                            </div>
                        </div>

                        <!-- Guest Info -->
                        <h6 class="font-weight-bold text-white mb-3">Guest Contact Details</h6>
                        <div class="row g-2 mb-3">
                            <div class="col">
                                <label class="form-label small text-muted">First Name</label>
                                <input type="text" name="firstName" class="form-control bg-dark border-secondary text-white rounded-pill px-3" required />
                            </div>
                            <div class="col">
                                <label class="form-label small text-muted">Last Name</label>
                                <input type="text" name="lastName" class="form-control bg-dark border-secondary text-white rounded-pill px-3" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-muted">Email Address</label>
                            <input type="email" name="email" class="form-control bg-dark border-secondary text-white rounded-pill px-3" required />
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col">
                                <label class="form-label small text-muted">Phone Number</label>
                                <input type="text" name="phone" class="form-control bg-dark border-secondary text-white rounded-pill px-3" required />
                            </div>
                            <div class="col">
                                <label class="form-label small text-muted">Passport / ID Number</label>
                                <input type="text" name="documentNumber" class="form-control bg-dark border-secondary text-white rounded-pill px-3" required />
                            </div>
                        </div>

                        <!-- Payment Mock Detail -->
                        <h6 class="font-weight-bold text-white mb-2 mt-4"><i class="fas fa-lock me-2 text-success"></i>Secure Mock Payments</h6>
                        <p class="text-muted-light small mb-3">Resort reservation is automatically guaranteed by credit card. Card details will be verified at check-in.</p>
                        
                        <div class="mb-3">
                            <label class="form-label small text-muted">Credit Card Number</label>
                            <input type="text" class="form-control bg-dark border-secondary text-white rounded-pill px-3" placeholder="4111 2222 3333 4444" required />
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary-accent rounded-pill px-4" onclick="document.getElementById('checkoutForm').submit()">Complete Reservation</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap Script -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function triggerCheckout(unitId, unitName, price) {
            document.getElementById('modalUnitId').value = unitId;
            document.getElementById('modalRoomName').innerText = unitName;
            document.getElementById('modalTotalPrice').innerText = price;
            
            var checkoutModal = new bootstrap.Modal(document.getElementById('checkoutModal'));
            checkoutModal.show();
        }
    </script>
</body>
</html>
