@model ResortManagement.Application.Features.Analytics.Queries.GetDashboardStats.DashboardStatsDto
@using System.Security.Claims
@{
    ViewData["Title"] = "Operations Dashboard";
    var recentReservations = ViewBag.RecentReservations as List<ResortManagement.Domain.Entities.Reservations.Reservation> ?? new List<ResortManagement.Domain.Entities.Reservations.Reservation>();
    var userName = User.FindFirst(ClaimTypes.Name)?.Value ?? "Ibrahim";
}

<main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop lg:px-margin-desktop w-full pt-28 pb-20">
    <!-- Hero Section -->
    <section class="mb-12">
        <div class="relative rounded-2xl overflow-hidden h-[240px] flex items-end p-8 bg-cover bg-center shadow-lg" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCoslKV3WmWqnvTNvYhwDJuVmL8_1l14ggpidJikf3EEQtLNRYOLEHva3N6NbSP7SnWoOEy1sjiWco5GL81ArfEUt4nkNCBFKTSi6-REHH9L0Y380242giLTRTQ9LFZft0_Oy4jUQmzjQbP5_huSGeSi7_h8d02YtMrmXAMQk81HmMGNSGBt0KbVb3EGT8Wf1Ghp58sRWElFRomfOnXyrKs8LQuPlzJc67oN8cSIA7z_TcZuQ3U64PSev4oe8M0krUq8uCZYX63U0iv');">
            <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
            <div class="relative z-10 w-full flex flex-col md:flex-row justify-between items-end gap-6">
                <div>
                    <h1 class="text-display-lg-mobile md:text-headline-lg font-bold text-white mb-2" data-translate-key="lbl_welcome_back" data-param-name="@userName">Welcome Back, @userName</h1>
                    <p class="text-body-lg text-white/90" data-translate-key="lbl_dashboard_sub">Here is what's happening across @(ViewBag.ResortName ?? "your properties") today.</p>
                </div>
                <!-- Weather Widget (Glassmorphic) -->
                <div class="glass-panel rounded-xl p-4 flex items-center gap-4 text-white" id="weather-widget">
                    <span id="weather-icon" class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">cloud_queue</span>
                    <div>
                        <div id="weather-temp" class="text-headline-md font-bold">-2°C</div>
                        <div id="weather-location" class="text-label-sm text-white/80">Courchevel, FR</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Bento Grid: Key Metrics & Charts -->
    <section class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-gutter mb-12">
        <!-- Revenue Overview -->
        <div class="metric-card rounded-2xl p-6 lg:col-span-2 flex flex-col justify-between">
            <div>
                <h3 class="text-label-md text-on-surface-variant mb-1 font-semibold uppercase tracking-wider" data-translate-key="lbl_total_revenue">Total Revenue</h3>
                <div class="text-headline-lg text-primary font-bold">@Model.TotalRevenue.ToString("C") <span class="text-label-md text-secondary ml-2 font-normal">+12.5%</span></div>
            </div>
            <div class="h-32 mt-6 relative flex items-end gap-2">
                <!-- Sparkline Chart Bars -->
                <div class="w-1/6 bg-secondary/20 h-[40%] rounded-t-sm hover:bg-secondary transition-colors cursor-pointer relative group"></div>
                <div class="w-1/6 bg-secondary/20 h-[60%] rounded-t-sm hover:bg-secondary transition-colors cursor-pointer relative group"></div>
                <div class="w-1/6 bg-secondary/20 h-[50%] rounded-t-sm hover:bg-secondary transition-colors cursor-pointer relative group"></div>
                <div class="w-1/6 bg-secondary/20 h-[80%] rounded-t-sm hover:bg-secondary transition-colors cursor-pointer relative group"></div>
                <div class="w-1/6 bg-secondary/20 h-[70%] rounded-t-sm hover:bg-secondary transition-colors cursor-pointer relative group"></div>
                <div class="w-1/6 bg-primary h-[100%] rounded-t-sm hover:bg-primary/90 transition-colors cursor-pointer relative group"></div>
            </div>
        </div>
        
        <!-- Occupancy Rate -->
        <div class="metric-card rounded-2xl p-6 flex flex-col justify-between items-center text-center">
            <div class="w-full text-left">
                <h3 class="text-label-md text-on-surface-variant mb-1 font-semibold uppercase tracking-wider" data-translate-key="lbl_current_occupancy">Current Occupancy</h3>
                <div class="text-headline-lg text-primary font-bold">@Model.OccupancyRate%</div>
            </div>
            <div class="relative w-24 h-24 mt-2">
                <svg class="w-full h-full transform -rotate-90" viewbox="0 0 36 36">
                    <path class="text-surface-variant" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3"></path>
                    <path class="text-secondary" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-dasharray="@Model.OccupancyRate, 100" stroke-width="3"></path>
                </svg>
                <div class="absolute inset-0 flex items-center justify-center font-bold text-primary">@Model.OccupancyRate%</div>
            </div>
        </div>
        
        <!-- Reservations Count / Pending Invoices -->
        <div class="metric-card rounded-2xl p-6 flex flex-col justify-between bg-primary text-on-primary shadow-lg">
            <div>
                <h3 class="text-label-md text-on-primary/80 mb-1 font-semibold uppercase tracking-wider" data-translate-key="lbl_active_bookings">Active Bookings</h3>
                <div class="text-headline-lg font-bold">@Model.TotalReservations</div>
            </div>
            <div class="mt-4 text-label-sm text-on-primary/80 border-t border-white/10 pt-4">
                <p class="mb-2" data-translate-key="lbl_pending_invoices" data-param-amount="@Model.PendingRevenue.ToString("C")">Pending Invoices: <span class="font-bold text-white">@Model.PendingRevenue.ToString("C")</span></p>
                <div class="w-full bg-white/20 rounded-full h-1.5 mb-1">
                    <div class="bg-secondary-container h-1.5 rounded-full" style="width: 75%"></div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Main Content Area: Properties & Stays -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
        <!-- Recent Stays & Bookings Table (Takes up 2 columns) -->
        <div class="lg:col-span-2 flex flex-col">
            <div class="flex justify-between items-end mb-6">
                <h2 class="text-headline-md font-bold text-primary" data-translate-key="lbl_recent_stays_bookings">Recent Stays & Bookings</h2>
                <a class="text-label-md text-secondary hover:text-primary transition-colors font-semibold" data-translate-key="lbl_view_all_stays" href="/bookings">View All Stays</a>
            </div>
            
            <div class="bg-white rounded-2xl border border-outline-variant/30 shadow-sm overflow-hidden flex-1">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-surface border-b border-outline-variant/30">
                                <th class="p-4 text-label-sm font-bold text-primary uppercase" data-translate-key="lbl_table_res_id">Reservation ID</th>
                                <th class="p-4 text-label-sm font-bold text-primary uppercase" data-translate-key="lbl_table_stay_period">Stay Period</th>
                                <th class="p-4 text-label-sm font-bold text-primary uppercase" data-translate-key="lbl_table_amount">Amount</th>
                                <th class="p-4 text-label-sm font-bold text-primary uppercase" data-translate-key="lbl_table_status">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/20">
                            @if (recentReservations.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="p-8 text-center text-on-surface-variant font-medium" data-translate-key="lbl_no_recent_stays">No recent stays or bookings found in database.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var reservation in recentReservations)
                                {
                                    <tr>
                                        <td class="p-4 text-body-md text-on-surface font-semibold">#RS-@reservation.Id.ToString()[..8].ToUpper()</td>
                                        <td class="p-4 text-label-sm text-on-surface-variant">@reservation.CheckInDate.ToString("MMM dd") - @reservation.CheckOutDate.ToString("MMM dd")</td>
                                        <td class="p-4 text-body-md text-primary font-bold">@reservation.TotalPrice.ToString("C")</td>
                                        <td class="p-4">
                                            @{
                                                var badgeClass = "bg-tertiary-container/20 text-on-tertiary-container";
                                                if (reservation.Status == "Confirmed" || reservation.Status == "CheckedIn") badgeClass = "bg-secondary/10 text-secondary";
                                                if (reservation.Status == "Cancelled") badgeClass = "bg-error/10 text-error";
                                            }
                                            <span class="@badgeClass px-2.5 py-1 rounded-full text-label-sm font-semibold">@reservation.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Featured Resorts Sidebar -->
        <div class="lg:col-span-1">
            <h2 class="text-headline-md font-bold text-primary mb-6" data-translate-key="lbl_top_properties">Top Properties</h2>
            <div class="space-y-6">
                @{
                    var topResorts = ViewBag.TopResorts as List<ResortManagement.Domain.Entities.Resorts.Resort> ?? new List<ResortManagement.Domain.Entities.Resorts.Resort>();
                }
                @if (topResorts.Count == 0)
                {
                    <div class="metric-card rounded-2xl p-6 text-center text-on-surface-variant font-medium">
                        <span class="material-symbols-outlined text-[32px] text-outline/40 mb-2">holiday_village</span>
                        <p class="text-label-md" data-translate-key="lbl_no_properties_registered">No properties registered yet.</p>
                        <a href="/resorts" class="text-secondary hover:underline text-label-sm mt-2 block font-semibold" data-translate-key="lbl_add_first_property">Add First Property</a>
                    </div>
                }
                else
                {
                    @foreach (var resort in topResorts)
                    {
                        <div class="metric-card rounded-2xl overflow-hidden flex flex-col group cursor-pointer" onclick="window.location.href='/resorts'">
                            <div class="h-32 relative overflow-hidden">
                                <img alt="@resort.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?q=80&w=2013&auto=format&fit=crop"/>
                                <div class="absolute top-3 right-3 glass-panel px-3 py-1 rounded-full text-label-sm text-primary font-bold" data-translate-key="lbl_active">
                                    Active
                                </div>
                            </div>
                            <div class="p-4">
                                <h4 class="text-body-lg font-bold text-primary mb-1">@resort.Name</h4>
                                <p class="text-label-sm text-on-surface-variant flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[16px]">location_on</span> @resort.Address
                                </p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", async function() {
            try {
                const response = await fetch('/api/weather/current');
                if (response.ok) {
                    const data = await response.json();
                    const iconEl = document.getElementById('weather-icon');
                    const tempEl = document.getElementById('weather-temp');
                    const locationEl = document.getElementById('weather-location');
                    
                    if (iconEl && data.icon) {
                        iconEl.textContent = data.icon;
                    }
                    if (tempEl && data.temp !== undefined) {
                        tempEl.textContent = `${data.temp}°C`;
                    }
                    if (locationEl && data.city && data.country) {
                        locationEl.textContent = `${data.city}, ${data.country}`;
                    }
                }
            } catch (error) {
                console.error("Failed to load live weather:", error);
            }
        });
    </script>
}
