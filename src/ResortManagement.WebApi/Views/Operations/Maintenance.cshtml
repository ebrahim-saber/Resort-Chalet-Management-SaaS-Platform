        // AJAX dynamic ticket logging
        function submitTicket() {
            const unit = document.getElementById("new-ticket-unit").value.trim();
            const title = document.getElementById("new-ticket-title").value.trim();
            const priority = document.getElementById("new-ticket-priority").value;
            const desc = document.getElementById("new-ticket-desc").value.trim();

            if (!unit || !title) {
                showNotification("خطأ في الإدخال", "يرجى كتابة اسم الغرفة/الوحدة وعنوان المشكلة.", "warning");
                return;
            }

            fetch("/operations/maintenance/create", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    unitNumber: unit,
                    title: title,
                    priority: priority,
                    description: desc
                })
            })
            .then(async res => {
                const data = await res.json();
                if (res.ok) {
                    const id = data.id;
                    const image = assetImages[Math.floor(Math.random() * assetImages.length)];
                    const avatar = techAvatars[Math.floor(Math.random() * techAvatars.length)];

                    // Styling variables based on priority
                    let priorityBg = "bg-secondary-container text-on-secondary-container";
                    let priorityIcon = "schedule";
                    let priorityText = "Standard";
                    if (priority === "Critical") {
                        priorityBg = "bg-error text-on-error";
                        priorityIcon = "priority_high";
                        priorityText = "Urgent";
                    } else if (priority === "High") {
                        priorityBg = "bg-tertiary-fixed-dim/90 text-on-tertiary-fixed";
                        priorityIcon = "warning";
                        priorityText = "Elevated";
                    }

                    // Create new DOM card structure
                    const card = document.createElement("article");
                    card.id = `ticket-card-${id}`;
                    card.className = "bg-white border border-outline-variant/20 rounded-2xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col h-full transform scale-95 opacity-0";
                    
                    card.innerHTML = `
                        <div class="h-48 relative overflow-hidden shrink-0">
                            <img alt="${title} image" class="w-full h-full object-cover" src="${image}" />
                            <div class="absolute inset-0 bg-gradient-to-t from-primary/60 to-transparent"></div>
                            <div class="absolute top-4 right-4 ${priorityBg} font-label-sm text-label-sm px-3 py-1 rounded-full shadow-sm flex items-center gap-1 font-semibold">
                                <span class="material-symbols-outlined text-[14px]">${priorityIcon}</span> ${priorityText}
                            </div>
                            <div class="absolute bottom-4 left-4 text-white">
                                <p class="font-label-sm text-label-sm uppercase tracking-widest opacity-80 mb-0.5">Asset ID: AS-${unit.replace(/\s+/g, '-').toUpperCase()}</p>
                                <h3 class="text-headline-md font-bold">${unit}</h3>
                            </div>
                        </div>
                        
                        <div class="p-6 flex-grow flex flex-col justify-between">
                            <div class="mb-5">
                                <h4 class="font-label-md text-label-md text-on-surface text-lg font-bold mb-2">${title}</h4>
                                <p class="text-body-md text-on-surface-variant line-clamp-3">${desc || 'No description provided.'}</p>
                            </div>
                            
                            <div class="pt-4 border-t border-outline-variant/10 flex justify-between items-center">
                                <div class="flex items-center gap-3">
                                    <img alt="Tech Avatar" class="w-8 h-8 rounded-full border border-surface-variant object-cover" src="${avatar}" />
                                    <span class="font-label-md text-label-md text-on-surface font-semibold">Tech: Dispatching...</span>
                                </div>
                                
                                <div class="flex items-center gap-2">
                                    <span id="ticket-status-${id}" class="font-label-sm text-label-sm text-primary bg-primary-container/20 px-2.5 py-1 rounded-md font-semibold">Open</span>
                                    
                                    <button id="ticket-btn-${id}" class="bg-secondary text-on-secondary hover:bg-secondary/95 text-label-sm px-4 py-2 rounded-lg transition-colors font-semibold shadow-sm flex items-center gap-1" onclick="resolveTicket('${id}', '${title}');">
                                        <span class="material-symbols-outlined text-[16px]">check</span> Resolve
                                    </button>
                                    
                                    <span id="ticket-solved-${id}" class="text-secondary font-bold text-label-sm flex items-center gap-1" style="display: none;">
                                        <span class="material-symbols-outlined text-[18px]">check_circle</span> Solved
                                    </span>
                                </div>
                            </div>
                        </div>
                    `;

                    // Prepend card inside tickets grid
                    const grid = document.getElementById("tickets-grid");
                    if (grid) {
                        if (grid.querySelector(".col-span-2.text-center")) {
                            grid.innerHTML = "";
                        }
                        grid.insertBefore(card, grid.firstChild);
                        
                        // Animate entrance
                        setTimeout(() => {
                            card.classList.remove("scale-95", "opacity-0");
                            card.classList.add("scale-100", "opacity-100");
                        }, 50);
                    }

                    // Update stats counter
                    const activeStat = document.getElementById("stat-active");
                    if (activeStat) activeStat.textContent = (parseInt(activeStat.textContent) || 0) + 1;
                    if (priority === "Critical") {
                        const critStat = document.getElementById("stat-critical");
                        if (critStat) critStat.textContent = (parseInt(critStat.textContent) || 0) + 1;
                    }

                    showNotification("تم تسجيل الطلب", `تم تسجيل بلاغ صيانة للوحدة ${unit} بنجاح وجاري إرسال الفنيين.`, "success");

                    // Reset inputs & close modal
                    document.getElementById("new-ticket-unit").value = "";
                    document.getElementById("new-ticket-title").value = "";
                    document.getElementById("new-ticket-desc").value = "";
                    document.getElementById("new-ticket-priority").value = "Medium";
                    closeModal();
                } else {
                    showNotification("فشل تسجيل الطلب", data.message || "حدث خطأ أثناء حفظ بلاغ الصيانة.", "error");
                }
            })
            .catch(() => {
                showNotification("خطأ في الشبكة", "فشل الاتصال بالخادم لتسجيل بلاغ الصيانة.", "error");
            });
        }
    </script>
