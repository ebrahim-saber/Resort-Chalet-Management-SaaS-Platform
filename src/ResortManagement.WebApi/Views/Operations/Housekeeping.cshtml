@{
    ViewData["Title"] = "Housekeeping Operations Board";
    var showcaseTasks = (ViewBag.ShowcaseTasks as System.Collections.IEnumerable)?.Cast<dynamic>().ToList() ?? new List<dynamic>();
    var pendingTasks = showcaseTasks.Where(t => (string)t.Status == "Pending" || (string)t.Status == "Dirty").ToList();
    var progressTasks = showcaseTasks.Where(t => (string)t.Status == "InProgress" || (string)t.Status == "Cleaning").ToList();
    var readyTasks = showcaseTasks.Where(t => (string)t.Status == "Completed" || (string)t.Status == "Clean").ToList();
}

<!-- Ambient Background Image with Glass Overlay -->
<div class="fixed inset-0 z-[-1]" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCZBoNmFaAMQIYiSCJOsaCJBY09-BESB25kVDitRxeqs48etPGvt0BTJKVULhkciYJUJqqnL2wmIhVU4hVHco-aqCqbvtqvGLHToV6GURWn3cmOsCdZjZJJ-Yfcszy5wfUMXCbJEmSJBu4qmQI3uFJIx9dbHtfduKW66LWIOgSMJDl4bhR9aAdf1KYXLNFVaXgMwPU83YpwbXQh3BDscNHLlN7zyJyzwNBmt3nREeLaYgS2wZO1x6gzznJA1chR9UUr5Vy57oGQPPVg'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-gradient-to-br from-surface-container-lowest/95 via-surface/90 to-surface-container-low/95 backdrop-blur-[2px]"></div>
</div>

<main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pt-28 pb-20 flex flex-col min-h-screen w-full relative">
    
    <!-- Toast Notification Hub -->
    <div id="toast-container" class="fixed top-24 right-6 z-[999] flex flex-col gap-3 pointer-events-none"></div>

    <!-- Page Header & Global Progress -->
    <section class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-6 mb-12">
        <div>
            <h1 class="text-display-lg-mobile md:text-display-lg font-bold text-primary mb-2">Housekeeping Operations</h1>
            <p class="text-body-lg text-on-surface-variant flex items-center gap-2">
                <span class="material-symbols-outlined text-secondary" style="font-size: 20px;">calendar_today</span>
                Morning Shift Concierge Operations
            </p>
        </div>
        
        <!-- Daily Progress Widget (Glassmorphic Card) -->
        <div class="bg-white/60 backdrop-blur-xl border border-white/60 shadow-sm rounded-2xl p-6 w-full lg:w-[400px]">
            <div class="flex justify-between items-center mb-4">
                <span class="text-label-md text-primary font-bold">Daily Progress</span>
                <span class="text-headline-md text-secondary font-bold">68%</span>
            </div>
            <div class="w-full bg-surface-container-highest rounded-full h-2.5 overflow-hidden mb-2">
                <div class="bg-secondary h-2.5 rounded-full" style="width: 68%"></div>
            </div>
            <div class="flex justify-between text-label-sm text-on-surface-variant font-medium">
                <span>32 Completed</span>
                <span>15 Remaining</span>
            </div>
        </div>
    </section>
    
    <!-- Kanban Board (Grid Layout) -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter flex-grow">
        <!-- Column 1: To Clean (Dirty) -->
        <div class="flex flex-col h-full bg-white/40 backdrop-blur-md rounded-2xl border border-white/50 shadow-sm p-4">
            <div class="flex justify-between items-center mb-6 px-2">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-error"></span>
                    <h2 class="text-headline-md text-primary font-bold">To Clean</h2>
                </div>
                <span id="pending-count" class="text-label-md bg-white/80 px-3 py-1 rounded-full border border-outline-variant/30 text-on-surface-variant font-semibold">@pendingTasks.Count</span>
            </div>
            <div id="pending-tasks-container" class="custom-scroll flex flex-col gap-4 overflow-y-auto max-h-[716px] pb-4 px-1">
                @if (pendingTasks.Count == 0)
                {
                    <!-- Fallback static high fidelity task card if empty -->
                    <article id="task-card-static-1" class="bg-white rounded-xl p-5 border border-white/80 shadow-sm hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group cursor-pointer" onclick="startCleaningTask('static-1');">
                        <div class="absolute top-0 left-0 w-1 h-full bg-error"></div>
                        <div class="flex justify-between items-start mb-3">
                            <div>
                                <h3 class="text-body-lg font-semibold text-primary">Chalet 4 - Mont Blanc</h3>
                                <p class="text-label-sm text-on-surface-variant flex items-center gap-1 mt-1 font-medium">
                                    <span class="material-symbols-outlined text-[14px]">bed</span> 3 Beds • Checkout
                                </p>
                            </div>
                            <span class="text-[10px] uppercase font-bold text-error bg-error-container/30 px-2 py-1 rounded tracking-wider">Urgent</span>
                        </div>
                        <div class="flex items-center gap-3 mt-4 mb-5">
                            <img alt="Staff Avatar" class="w-8 h-8 rounded-full object-cover border border-outline-variant/20" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD5tzsdzyh_iuKmPmtlvydMcmgZuBsA2NHfDjopajkiIBzjTOsu-NapK-CnPTBAJhDiykSrzgWbwuv9bHTEkE85RL6KewvTioW0lm3Bqe-5LtX6uXQmYWuYIJc5OueC9bjv3KFzltacJwjHFQJudqygvgh7lgAiD43irizFKnvg7ZAmsP6qYABFjAra6bGvJwHE_Ay_gV_pdmavebEQp-E9PYI3uLT-dTPX52QzHgFMNfEDZoGlGqxRiF10nncKu8Zetp3tF-0ZPVAG"/>
                            <div class="flex flex-col">
                                <span class="text-label-sm text-primary font-bold">Sarah Jenkins</span>
                                <span class="text-[11px] text-on-surface-variant">Assigned 10m ago</span>
                            </div>
                        </div>
                        <div class="pt-4 border-t border-surface-container-high flex justify-between items-center">
                            <span class="text-label-sm text-tertiary font-medium flex items-center gap-1">
                                <span class="material-symbols-outlined text-[16px]">schedule</span> 14:00 Deadline
                            </span>
                            <button class="bg-primary text-on-primary text-label-sm px-4 py-2 rounded-lg hover:bg-primary/95 transition-colors flex items-center gap-1 font-semibold shadow">
                                <span class="material-symbols-outlined text-[16px]">play_arrow</span> Start
                            </button>
                        </div>
                    </article>
                }
                else
                {
                    foreach (var task in pendingTasks)
                    {
                        <article id="task-card-@task.Id" class="bg-white rounded-xl p-5 border border-white/80 shadow-sm hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group cursor-pointer" onclick="startCleaningTask('@task.Id');">
                            <div class="absolute top-0 left-0 w-1 h-full bg-error"></div>
                            <div class="flex justify-between items-start mb-3">
                                <div class="task-header-title">
                                    <h3 class="text-body-lg font-semibold text-primary">Unit @task.UnitNumber</h3>
                                    <p class="text-label-sm text-on-surface-variant flex items-center gap-1 mt-1 font-medium">
                                        <span class="material-symbols-outlined text-[14px]">cleaning_services</span> Special Clean
                                    </p>
                                </div>
                                <span class="task-status-badge text-[10px] uppercase font-bold text-error bg-error-container/30 px-2 py-1 rounded tracking-wider">Checkout</span>
                            </div>
                            <p class="text-label-sm text-outline-variant my-2">@task.Notes</p>
                            <div class="pt-4 border-t border-surface-container-high flex justify-between items-center action-row">
                                <span class="text-label-sm text-tertiary font-medium flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[16px]">schedule</span> AM Shift
                                </span>
                                <button class="bg-primary text-on-primary text-label-sm px-4 py-2 rounded-lg hover:bg-primary/95 transition-colors flex items-center gap-1 font-semibold shadow">
                                    <span class="material-symbols-outlined text-[16px]">play_arrow</span> Start
                                </button>
                            </div>
                        </article>
                    }
                }
            </div>
        </div>
        
        <!-- Column 2: In Progress -->
        <div class="flex flex-col h-full bg-white/40 backdrop-blur-md rounded-2xl border border-white/50 shadow-sm p-4">
            <div class="flex justify-between items-center mb-6 px-2">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-tertiary-container"></span>
                    <h2 class="text-headline-md text-primary font-bold">In Progress</h2>
                </div>
                <span id="progress-count" class="text-label-md bg-white/80 px-3 py-1 rounded-full border border-outline-variant/30 text-on-surface-variant font-semibold">@progressTasks.Count</span>
            </div>
            <div id="progress-tasks-container" class="custom-scroll flex flex-col gap-4 overflow-y-auto max-h-[716px] pb-4 px-1">
                @if (progressTasks.Count == 0)
                {
                    <article id="task-card-static-2" class="bg-white rounded-xl p-5 border border-white/80 shadow-sm hover:-translate-y-1 transition-all duration-300 relative overflow-hidden cursor-pointer" onclick="finishCleaningTask('static-2');">
                        <div class="absolute top-0 left-0 w-1 h-full bg-tertiary-container"></div>
                        <div class="flex justify-between items-start mb-3">
                            <div>
                                <h3 class="text-body-lg font-semibold text-primary">Villa Belvedere</h3>
                                <p class="text-label-sm text-on-surface-variant flex items-center gap-1 mt-1 font-medium">
                                    <span class="material-symbols-outlined text-[14px]">cleaning_services</span> Deep Clean
                                </p>
                            </div>
                            <span class="material-symbols-outlined text-tertiary-container animate-spin">sync</span>
                        </div>
                        <div class="flex items-center justify-between mt-4 mb-2">
                            <div class="flex items-center gap-2">
                                <span class="text-label-sm text-primary font-bold">Maria G.</span>
                            </div>
                            <span class="text-label-sm text-tertiary font-medium">45m elapsed</span>
                        </div>
                        <div class="w-full bg-surface-container-high rounded-full h-1.5 mb-5">
                            <div class="bg-tertiary-container h-1.5 rounded-full w-3/4"></div>
                        </div>
                        <div class="pt-4 border-t border-surface-container-high flex justify-between items-center gap-2 action-row">
                            <button class="flex-1 bg-white border border-outline-variant text-primary text-label-sm py-2 rounded-lg hover:bg-surface-container-low transition-colors font-semibold" onclick="event.stopPropagation(); showNotification('الإمدادات', 'جاري طلب إمدادات تنظيف إضافية للغرفة...', 'info');">
                                Supplies
                            </button>
                            <button class="flex-1 bg-secondary text-on-secondary text-label-sm py-2 rounded-lg hover:bg-secondary/90 transition-colors flex justify-center items-center gap-1 font-semibold">
                                <span class="material-symbols-outlined text-[16px]">check</span> Finish
                            </button>
                        </div>
                    </article>
                }
                else
                {
                    foreach (var task in progressTasks)
                    {
                        <article id="task-card-@task.Id" class="bg-white rounded-xl p-5 border border-white/80 shadow-sm hover:-translate-y-1 transition-all duration-300 relative overflow-hidden cursor-pointer" onclick="finishCleaningTask('@task.Id');">
                            <div class="absolute top-0 left-0 w-1 h-full bg-tertiary-container"></div>
                            <div class="flex justify-between items-start mb-3">
                                <div class="task-header-title">
                                    <h3 class="text-body-lg font-semibold text-primary">Unit @task.UnitNumber</h3>
                                    <p class="text-label-sm text-on-surface-variant flex items-center gap-1 mt-1 font-medium">
                                        <span class="material-symbols-outlined text-[14px]">cleaning_services</span> Cleaning
                                    </p>
                                </div>
                                <span class="material-symbols-outlined text-tertiary-container animate-spin">sync</span>
                            </div>
                            <p class="text-label-sm text-outline-variant my-2">@task.Notes</p>
                            <div class="pt-4 border-t border-surface-container-high flex justify-between items-center gap-2 action-row">
                                <button class="flex-1 bg-secondary text-on-secondary text-label-sm py-2 rounded-lg hover:bg-secondary/90 transition-colors flex justify-center items-center gap-1 font-semibold">
                                    <span class="material-symbols-outlined text-[16px]">check</span> Finish Clean
                                </button>
                            </div>
                        </article>
                    }
                }
            </div>
        </div>
        
        <!-- Column 3: Ready (Clean) -->
        <div class="flex flex-col h-full bg-white/40 backdrop-blur-md rounded-2xl border border-white/50 shadow-sm p-4">
            <div class="flex justify-between items-center mb-6 px-2">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-secondary"></span>
                    <h2 class="text-headline-md text-primary font-bold">Ready</h2>
                </div>
                <span id="ready-count" class="text-label-md bg-white/80 px-3 py-1 rounded-full border border-outline-variant/30 text-on-surface-variant font-semibold">@readyTasks.Count</span>
            </div>
            <div id="ready-tasks-container" class="custom-scroll flex flex-col gap-4 overflow-y-auto max-h-[716px] pb-4 px-1 opacity-90 hover:opacity-100 transition-opacity">
                @if (readyTasks.Count == 0)
                {
                    <article id="task-card-static-3" class="bg-white/80 rounded-xl p-5 border border-outline-variant/30 shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-1 h-full bg-secondary"></div>
                        <div class="flex justify-between items-center mb-2">
                            <h3 class="text-body-lg font-medium text-primary line-through decoration-outline-variant">Suite 105</h3>
                            <span class="material-symbols-outlined text-secondary font-bold">check_circle</span>
                        </div>
                        <div class="flex items-center gap-2 mt-2">
                            <span class="text-[11px] text-on-surface-variant flex items-center gap-1 font-medium">
                                <span class="material-symbols-outlined text-[14px]">done_all</span> Inspected by Head Housekeeper
                            </span>
                        </div>
                    </article>
                }
                else
                {
                    foreach (var task in readyTasks)
                    {
                        <article id="task-card-@task.Id" class="bg-white/80 rounded-xl p-5 border border-outline-variant/30 shadow-sm relative overflow-hidden">
                            <div class="absolute top-0 left-0 w-1 h-full bg-secondary"></div>
                            <div class="flex justify-between items-center mb-2">
                                <h3 class="text-body-lg font-medium text-primary line-through decoration-outline-variant">Unit @task.UnitNumber</h3>
                                <span class="material-symbols-outlined text-secondary font-bold">check_circle</span>
                            </div>
                            <div class="flex items-center gap-2 mt-2">
                                <span class="text-[11px] text-on-surface-variant flex items-center gap-1 font-medium">
                                    <span class="material-symbols-outlined text-[14px]">done_all</span> Sanitized & Inspected
                                </span>
                            </div>
                        </article>
                    }
                }
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <script>
        // Custom Premium Toast Notification System
        function showNotification(title, message, type = "success") {
            const container = document.getElementById("toast-container");
            const toast = document.createElement("div");
            toast.className = "bg-white/95 backdrop-blur-xl border border-white shadow-xl rounded-2xl p-4 w-80 transform translate-x-full transition-all duration-300 flex items-start gap-3 pointer-events-auto border-l-4 " + 
                (type === "success" ? "border-l-secondary" : type === "warning" ? "border-l-tertiary-fixed-dim" : "border-l-error");
            
            const icon = type === "success" ? "check_circle" : type === "warning" ? "warning" : "error";
            const iconColor = type === "success" ? "text-secondary" : type === "warning" ? "text-on-tertiary-fixed-variant" : "text-error";

            toast.innerHTML = `
                <span class="material-symbols-outlined ${iconColor}">${icon}</span>
                <div class="flex-grow">
                    <h5 class="font-bold text-primary text-label-md mb-0.5">${title}</h5>
                    <p class="text-[12px] text-on-surface-variant">${message}</p>
                </div>
                <button class="text-outline hover:text-primary" onclick="this.parentElement.remove()"><span class="material-symbols-outlined text-[16px]">close</span></button>
            `;

            container.appendChild(toast);
            
            // Trigger animation slide-in
            setTimeout(() => {
                toast.classList.remove("translate-x-full");
                toast.classList.add("translate-x-0");
            }, 10);

            // Auto dismiss
            setTimeout(() => {
                toast.classList.remove("translate-x-0");
                toast.classList.add("translate-x-full");
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 5000);
        }

        // Live Dynamic State Transition APIs
        function startCleaningTask(id) {
            event.stopPropagation();
            
            if (id.startsWith("static-")) {
                // Simulate static card movements gracefully
                moveCardToProgress(id);
                showNotification("تم بدء المهمة", "بدأ تنظيف Chalet 4 وتم إرسال الطاقم للمعاينة الديناميكية.", "success");
                return;
            }

            fetch(`/operations/housekeeping/${id}/start`, {
                method: "POST",
                headers: { "Content-Type": "application/json" }
            })
            .then(res => {
                if (res.ok) {
                    moveCardToProgress(id);
                    showNotification("بدء التنظيف", "تم تحديث حالة الغرفة إلى قيد التنظيف بنجاح في قاعدة البيانات.", "success");
                } else {
                    showNotification("خطأ في العملية", "فشل بدء المهمة. يرجى التحقق من اتصال قاعدة البيانات.", "error");
                }
            })
            .catch(() => {
                showNotification("خطأ في الشبكة", "حدث خطأ غير متوقع أثناء الاتصال بالخادم.", "error");
            });
        }

        function finishCleaningTask(id) {
            event.stopPropagation();
            
            if (id.startsWith("static-")) {
                // Simulate static card movements gracefully
                moveCardToReady(id);
                showNotification("تم إتمام المهمة", "تم تمييز Villa Belvedere كغرفة نظيفة وجاهزة لاستقبال الضيوف.", "success");
                return;
            }

            fetch(`/operations/housekeeping/${id}/complete`, {
                method: "POST",
                headers: { "Content-Type": "application/json" }
            })
            .then(res => {
                if (res.ok) {
                    moveCardToReady(id);
                    showNotification("اكتمل التنظيف", "تم تمييز الوحدة كغرفة جاهزة ونظيفة وتم التحقق من الجودة.", "success");
                } else {
                    showNotification("خطأ في العملية", "فشل إتمام عملية التنظيف. يرجى المحاولة لاحقاً.", "error");
                }
            })
            .catch(() => {
                showNotification("خطأ في الشبكة", "فشل الاتصال بالخادم لإتمام تحديث الحالة.", "error");
            });
        }

        // Client-Side Dynamic DOM Kanban Flow Engine
        function moveCardToProgress(id) {
            const card = document.getElementById("task-card-" + id);
            if (!card) return;

            // 1. Update left decorative border color
            const borderEl = card.querySelector(".absolute.top-0.left-0");
            if (borderEl) {
                borderEl.classList.remove("bg-error");
                borderEl.classList.add("bg-tertiary-container");
            }

            // 2. Change status indicator icon & badges
            const headerRight = card.querySelector(".flex.justify-between.items-start > span");
            if (headerRight) {
                // Replace "Checkout" badge or text with animated sync icon
                const syncIcon = document.createElement("span");
                syncIcon.className = "material-symbols-outlined text-tertiary-container animate-spin";
                syncIcon.textContent = "sync";
                headerRight.replaceWith(syncIcon);
            }

            const cleanSub = card.querySelector(".task-header-title p");
            if (cleanSub) {
                cleanSub.innerHTML = `<span class="material-symbols-outlined text-[14px]">cleaning_services</span> Cleaning`;
            }

            // 3. Switch Action Buttons Row
            const actionRow = card.querySelector(".action-row");
            if (actionRow) {
                actionRow.innerHTML = `
                    <button class="flex-1 bg-secondary text-on-secondary text-label-sm py-2 rounded-lg hover:bg-secondary/90 transition-colors flex justify-center items-center gap-1 font-semibold">
                        <span class="material-symbols-outlined text-[16px]">check</span> Finish Clean
                    </button>
                `;
            }

            // 4. Update click bind attributes
            card.setAttribute("onclick", `finishCleaningTask('${id}');`);

            // 5. Prepend into progress column container
            const progressContainer = document.getElementById("progress-tasks-container");
            const pendingContainer = document.getElementById("pending-tasks-container");

            if (progressContainer && pendingContainer) {
                // Remove fallback static message if any
                const fallback = progressContainer.querySelector("p");
                if (fallback && fallback.textContent.includes("No")) {
                    progressContainer.innerHTML = "";
                }

                // Add nice scaling entry transition
                card.classList.add("scale-95", "opacity-0");
                progressContainer.insertBefore(card, progressContainer.firstChild);

                setTimeout(() => {
                    card.classList.remove("scale-95", "opacity-0");
                    card.classList.add("scale-100", "opacity-100");
                }, 50);

                // 6. Update counts
                const pendingCountEl = document.getElementById("pending-count");
                const progressCountEl = document.getElementById("progress-count");

                if (pendingCountEl) pendingCountEl.textContent = Math.max(0, parseInt(pendingCountEl.textContent) - 1);
                if (progressCountEl) progressCountEl.textContent = (parseInt(progressCountEl.textContent) || 0) + 1;
            }
        }

        function moveCardToReady(id) {
            const card = document.getElementById("task-card-" + id);
            if (!card) return;

            // 1. Update left decorative border color
            const borderEl = card.querySelector(".absolute.top-0.left-0");
            if (borderEl) {
                borderEl.classList.remove("bg-tertiary-container");
                borderEl.classList.add("bg-secondary");
            }

            // 2. Strike-through title & add big check circle
            const titleEl = card.querySelector("h3");
            if (titleEl) {
                titleEl.classList.add("line-through", "decoration-outline-variant");
                titleEl.classList.remove("font-semibold");
                titleEl.classList.add("font-medium");
            }

            const headerEl = card.querySelector(".flex.justify-between.items-start");
            if (headerEl) {
                headerEl.innerHTML = `
                    <h3 class="text-body-lg font-medium text-primary line-through decoration-outline-variant">${titleEl.textContent}</h3>
                    <span class="material-symbols-outlined text-secondary font-bold">check_circle</span>
                `;
            }

            // 3. Remove description notes and actions
            const notesEl = card.querySelector("p.text-outline-variant");
            if (notesEl) notesEl.remove();

            const actionRow = card.querySelector(".action-row");
            if (actionRow) {
                actionRow.innerHTML = `
                    <span class="text-[11px] text-on-surface-variant flex items-center gap-1 font-medium">
                        <span class="material-symbols-outlined text-[14px]">done_all</span> Sanitized & Inspected
                    </span>
                `;
                actionRow.className = "flex items-center gap-2 mt-2";
            }

            // 4. Disable click triggers entirely
            card.removeAttribute("onclick");
            card.className = "bg-white/80 rounded-xl p-5 border border-outline-variant/30 shadow-sm relative overflow-hidden transition-all duration-300";

            // 5. Prepend into ready column container
            const readyContainer = document.getElementById("ready-tasks-container");
            const progressContainer = document.getElementById("progress-tasks-container");

            if (readyContainer && progressContainer) {
                card.classList.add("scale-95", "opacity-0");
                readyContainer.insertBefore(card, readyContainer.firstChild);

                setTimeout(() => {
                    card.classList.remove("scale-95", "opacity-0");
                    card.classList.add("scale-100", "opacity-100");
                }, 50);

                // 6. Update counts
                const progressCountEl = document.getElementById("progress-count");
                const readyCountEl = document.getElementById("ready-count");

                if (progressCountEl) progressCountEl.textContent = Math.max(0, parseInt(progressCountEl.textContent) - 1);
                if (readyCountEl) readyCountEl.textContent = (parseInt(readyCountEl.textContent) || 0) + 1;
            }
        }
    </script>
}

